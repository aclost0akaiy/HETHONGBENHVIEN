@model IEnumerable<HeThongBenhVien.Models.User>
@using System.Linq

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Nhân Sự";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
}

<style>
    /* CSS Tùy chỉnh làm đẹp toàn bộ Table và Glass Card */
    .glass-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 1.5rem !important;
    }
    
    /* Tuỳ chỉnh header bảng */
    #nhanSuTable thead th {
        background: #f8fafc; /* Nền nhạt, sáng, sạch sẽ */
        color: #475569;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.8px;
        font-weight: 700;
        padding: 16px 15px;
        border-bottom: 2px solid #e2e8f0;
        white-space: nowrap;
    }

    #nhanSuTable tbody td {
        padding: 16px 15px;
        vertical-align: middle;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.9rem;
    }

    /* Hiệu ứng hover cho dòng */
    #nhanSuTable tbody tr {
        transition: all 0.2s ease;
    }
    #nhanSuTable tbody tr:hover {
        background-color: #f8fafc;
        transform: scale(1.002);
        box-shadow: 0 4px 15px -3px rgba(0,0,0,0.05);
        position: relative;
        z-index: 10;
        border-radius: 8px;
    }

    /* Tuỳ chỉnh DataTables UI: khung tìm kiếm và chọn số dòng */
    .dataTables_wrapper .dataTables_length select,
    .dataTables_wrapper .dataTables_filter input {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 6px 12px;
        color: #475569;
        outline: none;
        transition: all 0.2s;
        font-size: 0.9rem;
    }
    
    /* Đẩy label xuống cho căn giữa */
    .dataTables_wrapper .dataTables_length label,
    .dataTables_wrapper .dataTables_filter label {
        font-weight: 500;
        color: #64748b;
        margin-bottom: 1rem;
    }

    .dataTables_wrapper .dataTables_length select:focus,
    .dataTables_wrapper .dataTables_filter input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }
    
    .dataTables_wrapper .dataTables_filter input {
        margin-left: 10px;
        background: #f8fafc;
        width: 250px;
    }

    /* Phân trang đẹp mắt (Pagination) */
    .dataTables_wrapper .dataTables_info {
        padding-top: 1.5em;
        color: #64748b;
        font-size: 0.9rem;
        font-weight: 500;
    }
    
    .dataTables_wrapper .dataTables_paginate {
        padding-top: 1.5em;
    }
    
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important;
        border: 1px solid transparent !important;
        margin: 0 3px;
        padding: 5px 14px !important;
        transition: all 0.2s;
        color: #475569 !important;
        font-weight: 600;
        font-size: 0.9rem;
        background: transparent !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #f1f5f9 !important;
        color: #6366f1 !important;
        border-color: #e2e8f0 !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current,
    .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
        background: #6366f1 !important;
        color: white !important;
        border-color: #6366f1 !important;
        box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3) !important;
    }
    
    /* Scrollbar tinh tế cho bảng */
    .dataTables_scrollBody::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    .dataTables_scrollBody::-webkit-scrollbar-track {
        background: #f8fafc;
        border-radius: 10px;
    }
    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
        border: 2px solid #f8fafc;
    }
    .dataTables_scrollBody::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }

    /* Custom Badges (Vai trò) */
    .role-badge {
        padding: 6px 14px;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.3px;
        border-radius: 8px;
        display: inline-block;
    }
    .badge-admin {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .badge-doctor {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    
    /* Nút Gửi SMS Cao Cấp */
    .btn-sms {
        background: white;
        color: #0ea5e9;
        border: 1px solid #bae6fd;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
        box-shadow: 0 2px 4px rgba(14, 165, 233, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin: 0 auto;
    }
    .btn-sms:hover {
        background: #0ea5e9;
        color: white;
        border-color: #0ea5e9;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.25);
    }
</style>

<div class="container-fluid p-0">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-2 text-gray-800" style="font-weight: 800; color: #1e293b;">Quản Lý Nhân Sự</h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Danh sách toàn bộ nhân sự bác sĩ và quản trị viên trên hệ thống</p>
        </div>
        <div>
            <a asp-action="ThemNhanSu" asp-controller="Admin" class="btn btn-primary" style="padding: 10px 20px; border-radius: 10px; font-weight: 600; font-size: 0.9rem; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);">
                <i class="fas fa-plus me-2"></i> Thêm Nhân Sự
            </a>
        </div>
    </div>

    <!-- Main Table Card -->
    <div class="glass-card">
        <table id="nhanSuTable" class="table w-100 mb-0 border-0">
            <thead>
                <tr>
                    <th class="text-center" style="width: 50px;">ID</th>
                    <th>Tên Đăng Nhập</th>
                    <th>Họ và Tên</th>
                    <th class="text-center">Vai Trò</th>
                    <th>Email</th>
                    <th>Số Điện Thoại</th>
                    <th class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center text-muted fw-bold">@item.Id</td>
                            <td class="fw-bold" style="color: #475569;">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; background: rgba(99, 102, 241, 0.1); color: #6366f1; font-size: 14px;">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                    @item.Username
                                </div>
                            </td>
                            <td class="fw-semibold">@item.FullName</td>
                            <td class="text-center">
                                @if (item.Role == "Admin")
                                {
                                    <span class="role-badge badge-admin"><i class="fa-solid fa-shield-halved me-1"></i> Quản trị viên</span>
                                }
                                else
                                {
                                    <span class="role-badge badge-doctor"><i class="fa-solid fa-user-doctor me-1"></i> Bác sĩ</span>
                                }
                            </td>
                            <td class="text-muted">@item.Email</td>
                            <td class="fw-medium text-dark">@item.SDT</td>
                            <td>
                                @if (item.Role == "Doctor" && item.Username != ViewBag.CurrentUsername)
                                {
                                    <button class="btn-sms" onclick="sendSMS(@item.Id, '@Html.Raw(item.FullName?.Replace("'", "\\'"))')">
                                        <i class="fa-solid fa-comment-sms"></i> Gửi SMS
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Gửi SMS -->
<div class="modal fade" id="smsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light" style="border-radius: 20px 20px 0 0; padding: 20px 30px;">
                <h5 class="modal-title fw-bold" style="color: #1e293b;">
                    <i class="fa-solid fa-paper-plane me-2 text-primary"></i> Gửi Tin Nhắn Admin
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">NGƯỜI NHẬN</label>
                    <div id="smsRecipient" class="fw-bold text-dark fs-5"></div>
                </div>
                <div class="mb-3">
                    <label for="smsMessage" class="form-label text-muted small fw-bold">NỘI DUNG TIN NHẮN</label>
                    <textarea class="form-control" id="smsMessage" rows="4" style="border-radius: 12px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 15px;" placeholder="Nhập nội dung tin nhắn gửi đến bác sĩ..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px; padding: 20px 30px;">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-primary px-4 py-2" id="btnConfirmSend" style="border-radius: 10px; font-weight: 600;">
                    <i class="fa-solid fa-paper-plane me-2"></i> Gửi Ngay
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        let currentSmsDoctorId = 0;

        $(document).ready(function () {
            $('#nhanSuTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "search": "<i class='fa-solid fa-magnifying-glass'></i> Tìm kiếm:"
                },
                "scrollY": "450px",
                "scrollCollapse": true,
                "paging": true,
                "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "Tất cả"]],
                "pageLength": 10,
                // Không sort mặc định theo cột ID do data đang demo rải rác
                "order": [[ 0, "asc" ]]
            });

            $('#btnConfirmSend').click(function() {
                const message = $('#smsMessage').val().trim();
                if (!message) {
                    alert("Vui lòng nhập nội dung tin nhắn!");
                    return;
                }

                const token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Admin/SendDoctorSMS',
                    type: 'POST',
                    data: {
                        doctorId: currentSmsDoctorId,
                        message: message,
                        __RequestVerificationToken: token
                    },
                    success: function(res) {
                        if (res && res.success) {
                            alert('✅ ' + res.message);
                            $('#smsModal').modal('hide');
                            $('#smsMessage').val('');
                        } else {
                            alert('❌ ' + (res ? res.message : 'Gửi tin nhắn thất bại!'));
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('SMS Error:', xhr.status, xhr.responseText);
                        alert('❌ Lỗi kết nối! HTTP ' + xhr.status + ': ' + (xhr.responseJSON?.message || error));
                    }
                });
            });
        });
        
        function sendSMS(id, name) {
            currentSmsDoctorId = id;
            $('#smsRecipient').text(name);
            $('#smsModal').modal('show');
        }
    </script>
}