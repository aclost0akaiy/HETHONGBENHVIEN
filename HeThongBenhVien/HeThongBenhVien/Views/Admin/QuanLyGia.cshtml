@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Bảng Giá Viện Phí";
    var services = ViewBag.Services as List<HeThongBenhVien.Models.MedicalService> ?? new List<HeThongBenhVien.Models.MedicalService>();
    var medicines = ViewBag.Medicines as List<HeThongBenhVien.Models.Medicine> ?? new List<HeThongBenhVien.Models.Medicine>();
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1" style="font-weight: 700; color: #1e293b;">Bảng Giá Viện Phí</h2>
            <p class="text-muted mb-0">Tổng hợp giá dịch vụ y tế và thuốc trong bệnh viện.</p>
        </div>
        <button class="btn btn-primary px-4" onclick="window.print()">
            <i class="fa-solid fa-print me-2"></i> In Bảng Giá
        </button>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-primary">
                <p class="text-muted fw-bold mb-1">Tổng Dịch Vụ</p>
                <h2 class="fw-bold m-0">@services.Count</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-success">
                <p class="text-muted fw-bold mb-1">Tổng Loại Thuốc</p>
                <h2 class="fw-bold m-0">@medicines.Count</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-warning">
                <p class="text-muted fw-bold mb-1">Giá DV Cao Nhất</p>
                <h2 class="fw-bold m-0">@(services.Any() ? string.Format("{0:N0} đ", services.Max(s => s.Price)) : "0 đ")</h2>
            </div>
        </div>
    </div>

    <!-- Bảng giá dịch vụ -->
    <div class="glass-card p-4 mb-4">
        <h5 class="fw-bold mb-4"><i class="fa-solid fa-stethoscope text-primary me-2"></i>Giá Dịch Vụ Khám Chữa Bệnh</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Mã DV</th>
                        <th>Tên Dịch Vụ</th>
                        <th>Mô Tả</th>
                        <th class="text-end">Đơn Giá (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (services.Any())
                    {
                        int stt = 1;
                        @foreach (var svc in services)
                        {
                            <tr>
                                <td class="fw-bold">@(stt++)</td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary">@svc.ServiceCode</span></td>
                                <td class="fw-bold">@svc.ServiceName</td>
                                <td><small class="text-muted">@svc.Description</small></td>
                                <td class="text-end fw-bold text-success">@string.Format("{0:N0}", svc.Price) đ</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có dịch vụ nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Bảng giá thuốc -->
    <div class="glass-card p-4">
        <h5 class="fw-bold mb-4"><i class="fa-solid fa-pills text-info me-2"></i>Giá Thuốc</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Tên Thuốc</th>
                        <th class="text-end">Đơn Giá (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (medicines.Any())
                    {
                        int stt2 = 1;
                        @foreach (var med in medicines)
                        {
                            <tr>
                                <td class="fw-bold">@(stt2++)</td>
                                <td class="fw-bold">@med.Name</td>
                                <td class="text-end fw-bold text-success">@string.Format("{0:N0}", med.Price) đ</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="text-center py-4 text-muted">Chưa có thuốc nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
