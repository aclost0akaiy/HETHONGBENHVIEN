@model HeThongBenhVien.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Bệnh Nhân";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Thêm Bệnh Nhân Mới</h2>
            <p class="text-muted mb-0">Tạo tài khoản bệnh nhân mới với vai trò <strong>BenhNhan</strong>.</p>
        </div>

        <div>
            <a asp-action="QuanLyBenhNhan" asp-controller="Admin" class="btn btn-secondary shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50 me-1"></i> Quay lại danh sách
            </a>
        </div>
    </div>

    <div class="glass-card p-4">
        <form asp-action="ThemBenhNhan" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Tên đăng nhập (Username) <span class="text-danger">*</span></label>
                    <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản..." required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Mật khẩu <span class="text-danger">*</span></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="VD: Nguyễn Văn A" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="example@benhvien.com" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Số điện thoại</label>
                    <input asp-for="SDT" class="form-control" placeholder="Nhập số điện thoại..." />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold mb-2">Vai trò</label>
                    <input asp-for="Role" class="form-control" readonly />
                </div>
            </div>

            <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary px-4 shadow-sm" style="background-color: #4e73df; border: none;">
                    <i class="fas fa-user-plus me-1"></i> Lưu bệnh nhân
                </button>
                <button type="reset" class="btn btn-light px-4 ms-2">Hủy</button>
            </div>
        </form>
    </div>
</div>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        border-radius: 15px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .form-control {
        border-radius: 8px;
        padding: 0.6rem 1rem;
        border: 1px solid #d1d3e2;
    }

    .form-control:focus {
        border-color: #bac8f3;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
    }

    label {
        color: #4e73df;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>
