@model List<HeThongBenhVien.Models.MedicalService>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dịch Vụ Khám Chữa Bệnh";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1" style="font-weight: 700; color: #1e293b;">Dịch Vụ Khám Chữa Bệnh</h2>
            <p class="text-muted mb-0">Quản lý danh mục các dịch vụ y tế trong bệnh viện.</p>
        </div>
        <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#modalThemDichVu">
            <i class="fa-solid fa-plus me-2"></i> Thêm Dịch Vụ
        </button>
    </div>

    <!-- Thống kê -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-primary">
                <p class="text-muted fw-bold mb-1">Tổng Dịch Vụ</p>
                <h2 class="fw-bold m-0">@Model.Count</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-success">
                <p class="text-muted fw-bold mb-1">Đang Hoạt Động</p>
                <h2 class="fw-bold m-0">@Model.Count(s => s.IsActive)</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-start border-4 border-danger">
                <p class="text-muted fw-bold mb-1">Tạm Ngưng</p>
                <h2 class="fw-bold m-0">@Model.Count(s => !s.IsActive)</h2>
            </div>
        </div>
    </div>

    <!-- Bảng dịch vụ -->
    <div class="glass-card p-4">
        <h5 class="fw-bold mb-4">Danh Sách Dịch Vụ</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã DV</th>
                        <th>Tên Dịch Vụ</th>
                        <th>Mô Tả</th>
                        <th class="text-end">Giá (VNĐ)</th>
                        <th class="text-center">Trạng Thái</th>
                        <th class="text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var svc in Model)
                        {
                            <tr>
                                <td><span class="badge bg-info bg-opacity-10 text-info fw-bold">@svc.ServiceCode</span></td>
                                <td class="fw-bold">@svc.ServiceName</td>
                                <td><small class="text-muted">@svc.Description</small></td>
                                <td class="text-end fw-bold">@string.Format("{0:N0}", svc.Price) đ</td>
                                <td class="text-center">
                                    @if (svc.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger">Tạm ngưng</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form method="post" action="@Url.Action("ToggleDichVu", "Admin")" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@svc.Id" />
                                        <button type="submit" class="btn btn-sm @(svc.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(svc.IsActive ? "Tạm ngưng" : "Kích hoạt")">
                                            <i class="fa-solid @(svc.IsActive ? "fa-pause" : "fa-play")"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="@Url.Action("XoaDichVu", "Admin")" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@svc.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xác nhận xóa dịch vụ này?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-stethoscope fs-1 mb-3 d-block opacity-25"></i>
                                Chưa có dịch vụ nào. Nhấn <strong>"Thêm Dịch Vụ"</strong> để bắt đầu.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm Dịch Vụ -->
<div class="modal fade" id="modalThemDichVu" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-plus me-2"></i>Thêm Dịch Vụ Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="@Url.Action("ThemDichVu", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Mã Dịch Vụ</label>
                            <input type="text" class="form-control" name="ServiceCode" placeholder="VD: DV-KTQ" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Tên Dịch Vụ <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="ServiceName" placeholder="VD: Khám tổng quát" required />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Mô Tả</label>
                            <textarea class="form-control" name="Description" rows="2" placeholder="Mô tả dịch vụ..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giá (VNĐ) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="Price" placeholder="150000" min="0" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-2"></i>Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>
