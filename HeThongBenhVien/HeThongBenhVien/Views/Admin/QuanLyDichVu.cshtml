@model IEnumerable<HeThongBenhVien.Models.MedicalService>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Dịch Vụ"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Dịch Vụ Khám Chữa Bệnh</h2><p class="text-muted mb-0">Danh mục các dịch vụ y tế của bệnh viện</p></div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Thêm Dịch Vụ</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Dịch Vụ</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Đang Hoạt Động</p><h3 class="fw-bold m-0 text-success">@Model.Count(s => s.IsActive)</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Giá Trung Bình</p><h3 class="fw-bold m-0">@(Model.Any() ? Model.Average(s => s.Price).ToString("N0") : "0") đ</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Mã DV</th><th>Tên Dịch Vụ</th><th>Mô Tả</th><th>Giá (VNĐ)</th><th>Trạng Thái</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold text-primary">@item.ServiceCode</td>
                    <td class="fw-bold">@item.ServiceName</td>
                    <td class="text-muted">@item.Description</td>
                    <td class="fw-bold text-success">@item.Price.ToString("N0") đ</td>
                    <td>@if(item.IsActive){<span class="badge bg-success">Hoạt động</span>}else{<span class="badge bg-secondary">Tạm ngưng</span>}</td>
                    <td class="text-center"><form asp-action="XoaDichVu" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xác nhận xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="6" class="text-center py-5 text-muted"><i class="fas fa-stethoscope fa-3x mb-3"></i><p>Chưa có dịch vụ nào.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-plus me-2"></i>Thêm Dịch Vụ</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemDichVu" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="mb-3"><label class="form-label fw-bold">Mã Dịch Vụ</label><input name="ServiceCode" class="form-control" required/></div>
            <div class="mb-3"><label class="form-label fw-bold">Tên Dịch Vụ</label><input name="ServiceName" class="form-control" required/></div>
            <div class="mb-3"><label class="form-label fw-bold">Mô Tả</label><input name="Description" class="form-control"/></div>
            <div class="mb-3"><label class="form-label fw-bold">Giá (VNĐ)</label><input name="Price" type="number" class="form-control" required/></div>
            <div class="form-check"><input type="checkbox" name="IsActive" value="true" class="form-check-input" checked/><label class="form-check-label">Đang hoạt động</label></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>
