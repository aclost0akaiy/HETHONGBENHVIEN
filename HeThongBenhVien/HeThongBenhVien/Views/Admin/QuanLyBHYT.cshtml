@model IEnumerable<HeThongBenhVien.Models.InsuranceCard>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý BHYT"; var patients = ViewBag.Patients as List<HeThongBenhVien.Models.Patient>; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Bảo Hiểm Y Tế</h2><p class="text-muted mb-0">Quản lý thẻ BHYT của bệnh nhân</p></div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Thêm Thẻ BHYT</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Thẻ BHYT</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Còn Hiệu Lực</p><h3 class="fw-bold m-0 text-success">@Model.Count(c => c.Status == "Còn hiệu lực")</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-danger"><p class="text-muted fw-bold mb-1 small">Hết Hạn</p><h3 class="fw-bold m-0 text-danger">@Model.Count(c => c.Status == "Hết hạn")</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Số Thẻ</th><th>Bệnh Nhân</th><th>Nơi ĐK KCB</th><th>Hiệu Lực</th><th>% Chi Trả</th><th>Trạng Thái</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold text-primary">@item.CardNumber</td>
                    <td class="fw-bold">@(item.Patient?.FullName ?? "N/A")</td>
                    <td>@item.RegisteredHospital</td>
                    <td>@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-primary">@item.CoveragePercent%</span></td>
                    <td>@if(item.Status=="Còn hiệu lực"){<span class="badge bg-success">Còn hiệu lực</span>}else{<span class="badge bg-danger">Hết hạn</span>}</td>
                    <td class="text-center"><form asp-action="XoaBHYT" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="7" class="text-center py-5 text-muted"><i class="fas fa-id-card fa-3x mb-3"></i><p>Chưa có thẻ BHYT nào.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-plus me-2"></i>Thêm Thẻ BHYT</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemBHYT" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="mb-3"><label class="form-label fw-bold">Số Thẻ BHYT</label><input name="CardNumber" class="form-control" required/></div>
            <div class="mb-3"><label class="form-label fw-bold">Bệnh Nhân</label><select name="PatientId" class="form-select">@if(patients!=null){foreach(var p in patients){<option value="@p.Id">@p.FullName (@p.PatientCode)</option>}}</select></div>
            <div class="mb-3"><label class="form-label fw-bold">Nơi ĐK KCB Ban Đầu</label><input name="RegisteredHospital" class="form-control"/></div>
            <div class="row"><div class="col-md-6 mb-3"><label class="form-label fw-bold">Từ Ngày</label><input name="StartDate" type="date" class="form-control" required/></div>
            <div class="col-md-6 mb-3"><label class="form-label fw-bold">Đến Ngày</label><input name="EndDate" type="date" class="form-control" required/></div></div>
            <div class="mb-3"><label class="form-label fw-bold">% Chi Trả</label><input name="CoveragePercent" type="number" class="form-control" value="80"/></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>
