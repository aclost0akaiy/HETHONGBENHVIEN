@model IEnumerable<HeThongBenhVien.Models.MedicalRecord>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Viện Phí"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Viện Phí</h2><p class="text-muted mb-0">Theo dõi chi phí khám chữa bệnh và thanh toán</p></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Tổng Doanh Thu</p><h3 class="fw-bold m-0 text-success">@((Model.Count() * 500000).ToString("N0")) đ</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Hồ Sơ</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-4"><div class="glass-card p-3 border-start border-4 border-info"><p class="text-muted fw-bold mb-1 small">TB / Hồ Sơ</p><h3 class="fw-bold m-0">500,000 đ</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Mã HS</th><th>Bệnh Nhân</th><th>Chẩn Đoán</th><th>Ngày Khám</th><th>Chi Phí</th><th>Trạng Thái</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold text-primary">HS-@item.Id.ToString("D5")</td>
                    <td class="fw-bold">@(item.Appointment?.Patient?.FullName ?? "N/A")</td>
                    <td>@item.Diagnosis</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-bold text-success">500,000 đ</td>
                    <td><span class="badge bg-success">Đã thanh toán</span></td>
                </tr>
                }}else{<tr><td colspan="6" class="text-center py-5 text-muted"><i class="fas fa-file-invoice-dollar fa-3x mb-3"></i><p>Chưa có hồ sơ viện phí nào.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>
