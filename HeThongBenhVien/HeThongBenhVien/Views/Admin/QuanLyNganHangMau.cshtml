@model IEnumerable<HeThongBenhVien.Models.BloodBank>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Ngân Hàng Máu"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Ngân Hàng Máu</h2><p class="text-muted mb-0">Quản lý lưu trữ và cung cấp máu</p></div>
        <button class="btn btn-danger shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Nhập Túi Máu</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-danger"><p class="text-muted fw-bold mb-1 small">Tổng Túi Máu</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Khả Dụng</p><h3 class="fw-bold m-0 text-success">@Model.Count(b => b.Status == "Khả dụng")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-info"><p class="text-muted fw-bold mb-1 small">Đã Sử Dụng</p><h3 class="fw-bold m-0 text-info">@Model.Count(b => b.Status == "Đã sử dụng")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Tổng ML</p><h3 class="fw-bold m-0">@Model.Where(b => b.Status == "Khả dụng").Sum(b => b.VolumeMl) ml</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Mã Túi</th><th>Nhóm Máu</th><th>Thành Phần</th><th>ML</th><th>Người Hiến</th><th>Ngày Thu</th><th>Hạn SD</th><th>Trạng Thái</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold text-primary">@item.BagCode</td>
                    <td><span class="badge bg-danger fs-6">@item.BloodType</span></td>
                    <td>@item.Component</td>
                    <td>@item.VolumeMl ml</td>
                    <td>@item.DonorName</td>
                    <td>@item.CollectionDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.ExpiryDate.ToString("dd/MM/yyyy")</td>
                    <td>@if(item.Status=="Khả dụng"){<span class="badge bg-success">Khả dụng</span>}else if(item.Status=="Đã sử dụng"){<span class="badge bg-info">Đã dùng</span>}else{<span class="badge bg-secondary">@item.Status</span>}</td>
                    <td class="text-center"><form asp-action="XoaMau" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="9" class="text-center py-5 text-muted"><i class="fas fa-droplet fa-3x mb-3 text-danger"></i><p>Chưa có túi máu nào trong kho.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-danger text-white"><h5 class="modal-title"><i class="fas fa-droplet me-2"></i>Nhập Túi Máu</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemMau" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="row">
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Nhóm Máu</label><select name="BloodType" class="form-select"><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>AB+</option><option>AB-</option><option>O+</option><option>O-</option></select></div>
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Thành Phần</label><select name="Component" class="form-select"><option>Máu toàn phần</option><option>Hồng cầu</option><option>Tiểu cầu</option><option>Huyết tương</option></select></div>
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Thể Tích (ml)</label><input name="VolumeMl" type="number" class="form-control" value="350"/></div>
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Hạn SD</label><input name="ExpiryDate" type="date" class="form-control" required/></div>
            </div>
            <div class="mb-3"><label class="form-label fw-bold">Tên Người Hiến</label><input name="DonorName" class="form-control"/></div>
            <div class="mb-3"><label class="form-label fw-bold">SĐT Người Hiến</label><input name="DonorPhone" class="form-control"/></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-danger">Nhập Kho</button></div>
    </form>
</div></div></div>
