@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Báo Cáo Hoạt Động"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Báo Cáo Hoạt Động</h2><p class="text-muted mb-0">Tổng quan hoạt động toàn bệnh viện</p></div>
        <button class="btn btn-primary shadow-sm"><i class="fas fa-download me-1"></i> Xuất Báo Cáo</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fas fa-user-injured fa-2x text-primary mb-2"></i><h3 class="fw-bold">@ViewBag.TotalPatients</h3><p class="text-muted mb-0">Bệnh Nhân</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fas fa-calendar-check fa-2x text-success mb-2"></i><h3 class="fw-bold">@ViewBag.TotalAppointments</h3><p class="text-muted mb-0">Lượt Khám</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fas fa-file-medical fa-2x text-info mb-2"></i><h3 class="fw-bold">@ViewBag.TotalRecords</h3><p class="text-muted mb-0">Hồ Sơ Bệnh Án</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fas fa-user-doctor fa-2x text-warning mb-2"></i><h3 class="fw-bold">@ViewBag.TotalDoctors</h3><p class="text-muted mb-0">Bác Sĩ</p></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="fas fa-chart-bar text-primary me-2"></i>Thống Kê Theo Bộ Phận</h5>
                <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="fw-bold">Xét Nghiệm</span><span class="text-primary fw-bold">@ViewBag.TotalLabTests</span></div><div class="progress" style="height:8px;"><div class="progress-bar bg-primary" style="width:@(ViewBag.TotalLabTests > 0 ? 100 : 0)%"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="fw-bold">Kho Dược (loại thuốc)</span><span class="text-success fw-bold">@ViewBag.TotalMedicines</span></div><div class="progress" style="height:8px;"><div class="progress-bar bg-success" style="width:@(ViewBag.TotalMedicines > 0 ? 100 : 0)%"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="fw-bold">Khoa Phòng</span><span class="text-info fw-bold">@ViewBag.TotalDepartments</span></div><div class="progress" style="height:8px;"><div class="progress-bar bg-info" style="width:@(ViewBag.TotalDepartments > 0 ? 100 : 0)%"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="fw-bold">Thiết Bị Y Tế</span><span class="text-warning fw-bold">@ViewBag.TotalEquipments</span></div><div class="progress" style="height:8px;"><div class="progress-bar bg-warning" style="width:@(ViewBag.TotalEquipments > 0 ? 100 : 0)%"></div></div></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="fas fa-list-check text-success me-2"></i>Hoạt Động Gần Đây</h5>
                <div class="d-flex mb-3 pb-3 border-bottom align-items-start"><div class="bg-primary bg-opacity-10 p-2 rounded text-primary me-3"><i class="fas fa-user-plus"></i></div><div><p class="fw-bold mb-0">Hệ thống đang vận hành ổn định</p><small class="text-muted">Tất cả module đã được kích hoạt</small></div></div>
                <div class="d-flex mb-3 pb-3 border-bottom align-items-start"><div class="bg-success bg-opacity-10 p-2 rounded text-success me-3"><i class="fas fa-check-circle"></i></div><div><p class="fw-bold mb-0">@ViewBag.TotalRecords hồ sơ bệnh án đã xử lý</p><small class="text-muted">Tổng kết từ đầu hệ thống</small></div></div>
                <div class="d-flex align-items-start"><div class="bg-info bg-opacity-10 p-2 rounded text-info me-3"><i class="fas fa-database"></i></div><div><p class="fw-bold mb-0">Dữ liệu được đồng bộ đầy đủ</p><small class="text-muted">Cập nhật lần cuối: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small></div></div>
            </div>
        </div>
    </div>
</div>
