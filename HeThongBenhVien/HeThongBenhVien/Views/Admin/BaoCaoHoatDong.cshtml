@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Báo Cáo Hoạt Động";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Báo Cáo Hoạt Động</h2>
            <p class="text-muted mb-0">Theo dõi các chỉ số và hiệu suất hoạt động của bệnh viện.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary"><i class="fa-solid fa-print"></i> In Báo Cáo</button>
            <button class="btn btn-primary"><i class="fa-solid fa-file-export"></i> Xuất PDF</button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="glass-card p-4 border-top border-4 border-primary h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-2 rounded text-primary me-3">
                        <i class="fa-solid fa-user-injured fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Lượt Khám Ngoại Trú</h5>
                </div>
                <h2 class="fw-bold">1,245 <span class="text-success fs-6"><i class="fa-solid fa-arrow-up"></i> 8%</span></h2>
                <p class="text-muted small m-0">So với tuần trước</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 border-top border-4 border-danger h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-danger bg-opacity-10 p-2 rounded text-danger me-3">
                        <i class="fa-solid fa-truck-medical fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Ca Cấp Cứu</h5>
                </div>
                <h2 class="fw-bold">86 <span class="text-danger fs-6"><i class="fa-solid fa-arrow-down"></i> 2%</span></h2>
                <p class="text-muted small m-0">So với tuần trước</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 border-top border-4 border-success h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 p-2 rounded text-success me-3">
                        <i class="fa-solid fa-bed fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Bệnh Nhân Nhập Viện</h5>
                </div>
                <h2 class="fw-bold">312 <span class="text-success fs-6"><i class="fa-solid fa-arrow-up"></i> 15%</span></h2>
                <p class="text-muted small m-0">Công suất giường hiện tại: 85%</p>
            </div>
        </div>
    </div>

    <div class="glass-card p-4">
        <h5 class="fw-bold mb-4">Lịch Sử Hoạt Động Gần Đây</h5>
        <div class="timeline-container">
            <div class="table-responsive">
                <table class="table align-middle">
                    <tbody>
                        <tr>
                            <td style="width: 50px;"><div class="bg-info bg-opacity-10 p-2 text-center rounded text-info"><i class="fa-solid fa-plus"></i></div></td>
                            <td><span class="fw-bold text-dark">Bệnh nhân nhập viện mới</span><br><small class="text-muted">Khoa Nội Tổng Hợp - Giường 12A</small></td>
                            <td class="text-end text-muted small">10 phút trước</td>
                        </tr>
                        <tr>
                            <td><div class="bg-success bg-opacity-10 p-2 text-center rounded text-success"><i class="fa-solid fa-check"></i></div></td>
                            <td><span class="fw-bold text-dark">Hoàn tất ca phẫu thuật</span><br><small class="text-muted">Mổ ruột thừa - Bác sĩ Nguyễn Văn A</small></td>
                            <td class="text-end text-muted small">1 giờ trước</td>
                        </tr>
                        <tr>
                            <td><div class="bg-warning bg-opacity-10 p-2 text-center rounded text-warning"><i class="fa-solid fa-triangle-exclamation"></i></div></td>
                            <td><span class="fw-bold text-dark">Cảnh báo tồn kho</span><br><small class="text-muted">Thuốc kháng sinh Amoxicillin sắp hết</small></td>
                            <td class="text-end text-muted small">3 giờ trước</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
