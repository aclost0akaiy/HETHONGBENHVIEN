@model IEnumerable<HeThongBenhVien.Models.QualityReview>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Đánh Giá Chất Lượng"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Đánh Giá Chất Lượng</h2><p class="text-muted mb-0">Đánh giá và cải thiện chất lượng dịch vụ bệnh viện</p></div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Thêm Đánh Giá</button>
    </div>

    @if(Model.Any()){
    <div class="row g-3 mb-4">
        <div class="col-md-2"><div class="glass-card p-3 text-center"><i class="fas fa-concierge-bell text-primary fs-4 mb-1"></i><h4 class="fw-bold m-0">@(Model.Average(r => r.ServiceScore).ToString("F1"))</h4><small class="text-muted">Dịch vụ</small></div></div>
        <div class="col-md-2"><div class="glass-card p-3 text-center"><i class="fas fa-broom text-success fs-4 mb-1"></i><h4 class="fw-bold m-0">@(Model.Average(r => r.CleanlinessScore).ToString("F1"))</h4><small class="text-muted">Vệ sinh</small></div></div>
        <div class="col-md-2"><div class="glass-card p-3 text-center"><i class="fas fa-user-nurse text-info fs-4 mb-1"></i><h4 class="fw-bold m-0">@(Model.Average(r => r.StaffScore).ToString("F1"))</h4><small class="text-muted">Nhân viên</small></div></div>
        <div class="col-md-2"><div class="glass-card p-3 text-center"><i class="fas fa-building text-warning fs-4 mb-1"></i><h4 class="fw-bold m-0">@(Model.Average(r => r.FacilityScore).ToString("F1"))</h4><small class="text-muted">Cơ sở VC</small></div></div>
        <div class="col-md-2"><div class="glass-card p-3 text-center"><i class="fas fa-clock text-danger fs-4 mb-1"></i><h4 class="fw-bold m-0">@(Model.Average(r => r.WaitTimeScore).ToString("F1"))</h4><small class="text-muted">Thời gian chờ</small></div></div>
        <div class="col-md-2"><div class="glass-card p-3 text-center border border-2 border-primary"><i class="fas fa-star text-primary fs-4 mb-1"></i><h4 class="fw-bold m-0 text-primary">@(((Model.Average(r=>r.ServiceScore)+Model.Average(r=>r.CleanlinessScore)+Model.Average(r=>r.StaffScore)+Model.Average(r=>r.FacilityScore)+Model.Average(r=>r.WaitTimeScore))/5).ToString("F1"))</h4><small class="text-muted fw-bold">Tổng TB</small></div></div>
    </div>}

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Khoa</th><th>Người ĐG</th><th>DV</th><th>VS</th><th>NV</th><th>CSVC</th><th>TGC</th><th>TB</th><th>Trạng Thái</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                    var avg = (item.ServiceScore+item.CleanlinessScore+item.StaffScore+item.FacilityScore+item.WaitTimeScore)/5.0;
                <tr>
                    <td class="fw-bold">@item.Department</td>
                    <td>@item.ReviewerName</td>
                    <td class="text-center">@item.ServiceScore</td>
                    <td class="text-center">@item.CleanlinessScore</td>
                    <td class="text-center">@item.StaffScore</td>
                    <td class="text-center">@item.FacilityScore</td>
                    <td class="text-center">@item.WaitTimeScore</td>
                    <td class="text-center"><span class="badge @(avg >= 7 ? "bg-success" : avg >= 5 ? "bg-warning text-dark" : "bg-danger") fs-6">@avg.ToString("F1")</span></td>
                    <td>@if(item.Status=="Chờ xử lý"){<span class="badge bg-warning text-dark">Chờ xử lý</span>}else{<span class="badge bg-success">Đã xử lý</span>}</td>
                    <td class="text-center"><form asp-action="XoaDanhGia" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="10" class="text-center py-5 text-muted"><i class="fas fa-star fa-3x mb-3 text-warning"></i><p>Chưa có đánh giá nào.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-star me-2"></i>Thêm Đánh Giá</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemDanhGia" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="mb-3"><label class="form-label fw-bold">Khoa Đánh Giá</label><select name="Department" class="form-select"><option>Khoa Nội</option><option>Khoa Ngoại</option><option>Khoa Sản</option><option>Khoa Nhi</option><option>Khoa Cấp Cứu</option><option>Khoa Xét Nghiệm</option></select></div>
            <div class="mb-3"><label class="form-label fw-bold">Người Đánh Giá</label><input name="ReviewerName" class="form-control" required/></div>
            <div class="row">
                <div class="col-6 mb-3"><label class="form-label fw-bold">Dịch vụ (1-10)</label><input name="ServiceScore" type="number" min="1" max="10" class="form-control" value="7"/></div>
                <div class="col-6 mb-3"><label class="form-label fw-bold">Vệ sinh (1-10)</label><input name="CleanlinessScore" type="number" min="1" max="10" class="form-control" value="7"/></div>
                <div class="col-6 mb-3"><label class="form-label fw-bold">Nhân viên (1-10)</label><input name="StaffScore" type="number" min="1" max="10" class="form-control" value="7"/></div>
                <div class="col-6 mb-3"><label class="form-label fw-bold">Cơ sở VC (1-10)</label><input name="FacilityScore" type="number" min="1" max="10" class="form-control" value="7"/></div>
                <div class="col-6 mb-3"><label class="form-label fw-bold">Thời gian chờ (1-10)</label><input name="WaitTimeScore" type="number" min="1" max="10" class="form-control" value="7"/></div>
            </div>
            <div class="mb-3"><label class="form-label fw-bold">Nhận xét</label><textarea name="Comment" class="form-control" rows="3"></textarea></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>
