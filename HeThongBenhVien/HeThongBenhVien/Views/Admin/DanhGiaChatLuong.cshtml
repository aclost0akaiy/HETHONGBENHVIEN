@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Đánh Giá Chất Lượng";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Đánh Giá Chất Lượng Dịch Vụ</h2>
            <p class="text-muted mb-0">Phản hồi và mức độ hài lòng của bệnh nhân.</p>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="glass-card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <h5 class="fw-bold text-muted mb-3">Điểm Đánh Giá Trung Bình</h5>
                <h1 class="display-3 fw-bold text-warning mb-0">4.8</h1>
                <div class="text-warning fs-4 mb-2">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star-half-stroke"></i>
                </div>
                <p class="text-muted m-0">Dựa trên 1,245 đánh giá</p>
            </div>
        </div>
        <div class="col-md-8">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4">Phân Bố Đánh Giá</h5>
                
                <div class="d-flex align-items-center mb-2">
                    <div style="width: 50px;" class="text-end me-2 text-muted fw-bold">5 Sao</div>
                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 80%" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div style="width: 50px;" class="text-end text-muted small">80%</div>
                </div>
                
                <div class="d-flex align-items-center mb-2">
                    <div style="width: 50px;" class="text-end me-2 text-muted fw-bold">4 Sao</div>
                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 15%" aria-valuenow="15" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div style="width: 50px;" class="text-end text-muted small">15%</div>
                </div>
                
                <div class="d-flex align-items-center mb-2">
                    <div style="width: 50px;" class="text-end me-2 text-muted fw-bold">3 Sao</div>
                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 3%" aria-valuenow="3" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div style="width: 50px;" class="text-end text-muted small">3%</div>
                </div>
                
                <div class="d-flex align-items-center mb-2">
                    <div style="width: 50px;" class="text-end me-2 text-muted fw-bold">2 Sao</div>
                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 1%" aria-valuenow="1" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div style="width: 50px;" class="text-end text-muted small">1%</div>
                </div>
                
                <div class="d-flex align-items-center">
                    <div style="width: 50px;" class="text-end me-2 text-muted fw-bold">1 Sao</div>
                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: 1%" aria-valuenow="1" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div style="width: 50px;" class="text-end text-muted small">1%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-card p-4">
        <h5 class="fw-bold mb-4">Phản Hồi Mới Nhất</h5>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="border rounded p-3 bg-light bg-opacity-50">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-bold"><i class="fa-solid fa-user-circle text-secondary me-2"></i> Trần Thị B.</div>
                        <div class="text-warning"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    </div>
                    <p class="text-muted small fst-italic">"Bác sĩ tư vấn rất nhiệt tình, cơ sở vật chất khang trang sạch sẽ. Tôi rất hài lòng với dịch vụ ở đây."</p>
                    <div class="text-end text-muted" style="font-size: 11px;">10/05/2026 - Khoa Nội</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 bg-light bg-opacity-50">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-bold"><i class="fa-solid fa-user-circle text-secondary me-2"></i> Lê Văn C.</div>
                        <div class="text-warning"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i></div>
                    </div>
                    <p class="text-muted small fst-italic">"Dịch vụ tốt nhưng thời gian chờ lấy kết quả xét nghiệm hơi lâu, hy vọng bệnh viện sẽ cải thiện."</p>
                    <div class="text-end text-muted" style="font-size: 11px;">09/05/2026 - Khoa Xét Nghiệm</div>
                </div>
            </div>
        </div>
    </div>
</div>
