</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const labels = @Html.Raw(ViewBag.ChartLabels);
        const appointmentsData = @Html.Raw(ViewBag.ChartAppointments);
        const revenueData = @Html.Raw(ViewBag.ChartRevenue);

        // Cập nhật tổng lượt khám tuần
        const totalAppts = appointmentsData.reduce((a, b) => a + b, 0);
        document.getElementById('weekTotalAppointments').textContent = totalAppts.toLocaleString('vi-VN');

        const ctx = document.getElementById('weeklyChart').getContext('2d');

        // Gradient cho cột lượt khám
        const barGradient = ctx.createLinearGradient(0, 0, 0, 300);
        barGradient.addColorStop(0, 'rgba(79, 70, 229, 0.85)');
        barGradient.addColorStop(1, 'rgba(124, 58, 237, 0.4)');

        // Gradient cho đường doanh thu
        const lineGradient = ctx.createLinearGradient(0, 0, 0, 300);
        lineGradient.addColorStop(0, 'rgba(16, 185, 129, 0.25)');
        lineGradient.addColorStop(1, 'rgba(16, 185, 129, 0.02)');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Lượt khám',
                        data: appointmentsData,
                        backgroundColor: barGradient,
                        borderColor: '#4f46e5',
                        borderWidth: 2,
                        borderRadius: 8,
                        borderSkipped: false,
                        yAxisID: 'y',
                        order: 2,
                        barPercentage: 0.6,
                        categoryPercentage: 0.7
                    },
                    {
                        label: 'Doanh thu (VNĐ)',
                        data: revenueData,
                        type: 'line',
                        borderColor: '#10b981',
                        backgroundColor: lineGradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#10b981',
                        pointBorderWidth: 3,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        tension: 0.4,
                        fill: true,
                        yAxisID: 'y1',
                        order: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleColor: '#fff',
                        bodyColor: '#e2e8f0',
                        borderColor: 'rgba(255,255,255,0.1)',
                        borderWidth: 1,
                        cornerRadius: 12,
                        padding: 14,
                        titleFont: { weight: 'bold', size: 13 },
                        bodyFont: { size: 12 },
                        displayColors: true,
                        boxPadding: 6,
                        callbacks: {
                            label: function (context) {
                                if (context.dataset.yAxisID === 'y1') {
                                    return ' Doanh thu: ' + context.parsed.y.toLocaleString('vi-VN') + ' đ';
                                }
                                return ' Lượt khám: ' + context.parsed.y;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            color: '#94a3b8',
                            font: { weight: '600', size: 11 }
                        },
                        border: { display: false }
                    },
                    y: {
                        type: 'linear',
                        position: 'left',
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(148, 163, 184, 0.1)',
                            drawBorder: false
                        },
                        ticks: {
                            color: '#4f46e5',
                            font: { weight: '600', size: 11 },
                            stepSize: 1,
                            callback: function(value) {
                                if (Number.isInteger(value)) return value;
                                return null;
                            }
                        },
                        title: {
                            display: true,
                            text: 'Lượt khám',
                            color: '#4f46e5',
                            font: { weight: 'bold', size: 12 }
                        },
                        border: { display: false }
                    },
                    y1: {
                        type: 'linear',
                        position: 'right',
                        beginAtZero: true,
                        grid: {
                            drawOnChartArea: false
                        },
                        ticks: {
                            color: '#10b981',
                            font: { weight: '600', size: 11 },
                            callback: function (value) {
                                if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                                if (value >= 1000) return (value / 1000).toFixed(0) + 'K';
                                return value;
                            }
                        },
                        title: {
                            display: true,
                            text: 'Doanh thu (VNĐ)',
                            color: '#10b981',
                            font: { weight: 'bold', size: 12 }
                        },
                        border: { display: false }
                    }
                }
            }
        });
    });
</script>
