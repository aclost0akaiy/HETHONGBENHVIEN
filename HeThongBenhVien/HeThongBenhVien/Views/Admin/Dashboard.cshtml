                    </a>
                </div>
                <!-- 10 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("CauHinhHeThong", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-gears fs-2 text-secondary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Cấu Hình Hệ Thống</h6>
                        </div>
                    </a>
                </div>
                <!-- 11 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyBenhNhan", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-bed-pulse fs-2 text-danger mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Bệnh Nhân</h6>
                        </div>
                    </a>
                </div>
                <!-- 12 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyVienPhi", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
