@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Tổng Quan Hệ Thống</h2>
            <p class="text-muted mb-0">Hiệu suất và số liệu thống kê bệnh viện trong ngày.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4"><i class="fa-solid fa-download me-2"></i> Xuất Báo Cáo</button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="glass-card p-4 h-100 border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1">Tổng Lượt Khám</p>
                        <h2 class="fw-bold m-0">@ViewBag.TotalAppointments.ToString("N0")</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                        <i class="fa-solid fa-users fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-success fw-bold text-sm">
                    <i class="fa-solid fa-arrow-trend-up"></i> +12% so với hôm qua
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 h-100 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1">Doanh Thu Ngày</p>
                        <h2 class="fw-bold m-0">@string.Format("{0:N0}", (decimal)ViewBag.DailyRevenue) đ</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                        <i class="fa-solid fa-money-bill-wave fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-success fw-bold text-sm">
                    <i class="fa-solid fa-arrow-trend-up"></i> +5.4% so với hôm qua
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 h-100 border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1">Giường Trống</p>
                        <h2 class="fw-bold m-0">@ViewBag.PatientOccupancy/500</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                        <i class="fa-solid fa-bed fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-danger fw-bold text-sm">
                    <i class="fa-solid fa-arrow-trend-down"></i> -2% so với hôm qua
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 h-100 border-start border-4 border-danger">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1">Ca Cấp Cứu</p>
                        <h2 class="fw-bold m-0">@ViewBag.EmergencyCases.ToString("N0")</h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="fa-solid fa-truck-medical fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted fw-bold text-sm">
                    <i class="fa-solid fa-minus"></i> Không đổi
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Chart Area (Mockup) -->
        <div class="col-lg-8">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Biểu Đồ Lượt Khám & Doanh Thu (Tuần)</h5>
                    <select class="form-select w-auto">
                        <option>7 ngày qua</option>
                        <option>Tháng này</option>
                    </select>
                </div>
                <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted" style="height: 300px; border: 1px dashed #cbd5e1;">
                    <div class="text-center">
                        <i class="fa-solid fa-chart-column fs-1 mb-2 text-primary opacity-50"></i>
                        <p>Khu vực hiển thị biểu đồ Chart.js / ApexCharts</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Alerts -->
        <div class="col-lg-4">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4">Cảnh Báo Hệ Thống</h5>
                
                <div class="d-flex mb-3 align-items-start pb-3 border-bottom">
                    <div class="bg-danger bg-opacity-10 p-2 rounded text-danger me-3 mt-1">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Kho Dược - Cảnh Báo Hết Thuốc</h6>
                        <p class="text-muted small m-0">Paracetamol 500mg (Kho trung tâm) chỉ còn 15 hộp. Cần nhập gấp.</p>
                        <small class="text-danger">10 phút trước</small>
                    </div>
                </div>

                <div class="d-flex mb-3 align-items-start pb-3 border-bottom">
                    <div class="bg-warning bg-opacity-10 p-2 rounded text-warning me-3 mt-1">
                        <i class="fa-solid fa-server"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Tải Server Cao</h6>
                        <p class="text-muted small m-0">CPU Server CSDL đang ở mức 85%. Vui lòng kiểm tra các query chậm.</p>
                        <small class="text-muted">1 giờ trước</small>
                    </div>
                </div>

                <div class="d-flex align-items-start">
                    <div class="bg-info bg-opacity-10 p-2 rounded text-info me-3 mt-1">
                        <i class="fa-solid fa-bed-pulse"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Công suất giường Khoa Hồi Sức</h6>
                        <p class="text-muted small m-0">Khoa Hồi Sức (ICU) đã đạt 95% công suất (19/20 giường).</p>
                        <small class="text-muted">2 giờ trước</small>
                    </div>
                </div>
                
                <button class="btn btn-outline-primary w-100 mt-4">Xem tất cả cảnh báo</button>
            </div>
        </div>
    </div>

    <!-- 20 Admin Functions Grid -->
    <div class="row mt-4">
        <div class="col-12">
            <h4 class="fw-bold mb-4">Các Chức Năng Quản Trị Hệ Thống</h4>
            <div class="row g-3">
                <!-- 1 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyTaiKhoan", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-users-gear fs-2 text-primary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Tài Khoản</h6>
                        </div>
                    </a>
                </div>
                <!-- 2 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyNhanSu", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-user-doctor fs-2 text-success mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Nhân Sự</h6>
                        </div>
                    </a>
                </div>
                <!-- 3 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyKhoaPhong", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-hospital-user fs-2 text-info mb-2"></i>
                            <h6 class="fw- bold text-dark m-0">Quản Lý Khoa Phòng</h6>
                        </div>
                    </a>
                </div>
                <!-- 4 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyLichLamViec", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-calendar-days fs-2 text-warning mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Lịch Làm Việc</h6>
                        </div>
                    </a>
                </div>
                <!-- 5 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyDichVu", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-stethoscope fs-2 text-danger mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Dịch Vụ</h6>
                        </div>
                    </a>
                </div>
                <!-- 6 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyGia", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-money-bill-wave fs-2 text-success mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Giá</h6>
                        </div>
                    </a>
                </div>
                <!-- 7 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyKhoDuoc", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-pills fs-2 text-primary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Kho Dược</h6>
                        </div>
                    </a>
                </div>
                <!-- 8 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyThietBi", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-microscope fs-2 text-info mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Thiết Bị</h6>
                        </div>
                    </a>
                </div>
                <!-- 9 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("ThongKeDoanhThu", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-chart-line fs-2 text-warning mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Thống Kê Doanh Thu</h6>
                        </div>
                    </a>
                </div>
                <!-- 10 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("CauHinhHeThong", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-gears fs-2 text-secondary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Cấu Hình Hệ Thống</h6>
                        </div>
                    </a>
                </div>
                <!-- 11 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyBenhNhan", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-bed-pulse fs-2 text-danger mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Bệnh Nhân</h6>
                        </div>
                    </a>
                </div>
                <!-- 12 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyVienPhi", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-file-invoice-dollar fs-2 text-success mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Viện Phí</h6>
                        </div>
                    </a>
                </div>
                <!-- 13 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyBHYT", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-id-card fs-2 text-primary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý BHYT</h6>
                        </div>
                    </a>
                </div>
                <!-- 14 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("BaoCaoHoatDong", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-chart-pie fs-2 text-info mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Báo Cáo Hoạt Động</h6>
                        </div>
                    </a>
                </div>
                <!-- 15 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyTiepDon", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-bell-concierge fs-2 text-warning mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Tiếp Đón</h6>
                        </div>
                    </a>
                </div>
                <!-- 16 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyXetNghiem", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-vials fs-2 text-danger mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Xét Nghiệm</h6>
                        </div>
                    </a>
                </div>
                <!-- 17 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyCDHA", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-x-ray fs-2 text-secondary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Chẩn Đoán Hình Ảnh</h6>
                        </div>
                    </a>
                </div>
                <!-- 18 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyPhauThuat", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-scissors fs-2 text-primary mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Quản Lý Phẫu Thuật</h6>
                        </div>
                    </a>
                </div>
                <!-- 19 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("QuanLyNganHangMau", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-droplet fs-2 text-danger mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Ngân Hàng Máu</h6>
                        </div>
                    </a>
                </div>
                <!-- 20 -->
                <div class="col-md-3 col-sm-6">
                    <a href="@Url.Action("DanhGiaChatLuong", "Admin")" class="text-decoration-none">
                        <div class="glass-card p-3 text-center admin-module-card h-100">
                            <i class="fa-solid fa-star fs-2 text-warning mb-2"></i>
                            <h6 class="fw-bold text-dark m-0">Đánh Giá Chất Lượng</h6>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
