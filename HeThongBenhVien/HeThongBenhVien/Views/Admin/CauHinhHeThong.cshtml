@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cấu Hình Hệ Thống";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Cấu Hình Hệ Thống</h2>
            <p class="text-muted mb-0">Quản lý các tham số cài đặt toàn cầu của hệ thống.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4"><i class="fa-solid fa-floppy-disk me-2"></i> Lưu Thay Đổi</button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="glass-card p-4 mb-4">
                <h5 class="fw-bold mb-4 border-bottom pb-2">Thông Tin Bệnh Viện</h5>
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Tên Bệnh Viện</label>
                        <input type="text" class="form-control" value="Bệnh Viện Đa Khoa Trung Ương" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Địa Chỉ</label>
                        <input type="text" class="form-control" value="123 Đường Y Tế, Phường Sức Khỏe, Quận Trung Tâm" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Số Điện Thoại Cấp Cứu</label>
                            <input type="text" class="form-control" value="1900 115" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Email Liên Hệ</label>
                            <input type="email" class="form-control" value="contact@hospital.com" />
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-4 border-bottom pb-2">Tham Số Khám Bệnh</h5>
                <form>
                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <div>
                            <label class="form-label fw-medium mb-0">Tự động duyệt lịch hẹn</label>
                            <p class="text-muted small mb-0">Lịch hẹn từ website sẽ được duyệt tự động.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="autoApprove" checked>
                        </div>
                    </div>
                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <div>
                            <label class="form-label fw-medium mb-0">Gửi SMS nhắc lịch</label>
                            <p class="text-muted small mb-0">Gửi tin nhắn cho bệnh nhân trước 24h.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="sendSms" checked>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="glass-card p-4 mb-4">
                <h5 class="fw-bold mb-4 border-bottom pb-2">Tích Hợp API</h5>
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Cổng Thanh Toán (VNPAY/MOMO)</label>
                        <input type="text" class="form-control font-monospace" value="sk_test_51Hv..." type="password" />
                        <div class="form-text">Khóa bảo mật để kết nối thanh toán viện phí trực tuyến.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Cổng SMS Brandname API Key</label>
                        <input type="text" class="form-control font-monospace" value="****************" type="password" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
