@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cấu Hình Hệ Thống";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1" style="font-weight: 700; color: #1e293b;">Cấu Hình Hệ Thống</h2>
            <p class="text-muted mb-0">Quản lý các thiết lập và cấu hình chung của hệ thống bệnh viện.</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Thông tin bệnh viện -->
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="fa-solid fa-hospital text-primary me-2"></i>Thông Tin Bệnh Viện</h5>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Bệnh Viện</label>
                    <input type="text" class="form-control" value="Bệnh Viện Đa Khoa Trung Ương" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Địa Chỉ</label>
                    <input type="text" class="form-control" value="123 Nguyễn Trãi, Quận 5, TP.HCM" readonly />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số Điện Thoại</label>
                        <input type="text" class="form-control" value="028-3855-0000" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Email</label>
                        <input type="text" class="form-control" value="info@benhvien.com" readonly />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Website</label>
                    <input type="text" class="form-control" value="https://benhvien.com" readonly />
                </div>
            </div>
        </div>

        <!-- Cấu hình chung -->
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="fa-solid fa-gears text-info me-2"></i>Cấu Hình Chung</h5>
                <div class="mb-3">
                    <label class="form-label fw-bold">Múi Giờ</label>
                    <select class="form-select" disabled>
                        <option selected>Asia/Ho_Chi_Minh (UTC+7)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngôn Ngữ Mặc Định</label>
                    <select class="form-select" disabled>
                        <option selected>Tiếng Việt</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Định Dạng Ngày</label>
                    <select class="form-select" disabled>
                        <option selected>dd/MM/yyyy</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Đơn Vị Tiền Tệ</label>
                    <select class="form-select" disabled>
                        <option selected>VNĐ (Việt Nam Đồng)</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Bảo mật -->
        <div class="col-lg-6">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-4"><i class="fa-solid fa-shield-halved text-danger me-2"></i>Bảo Mật</h5>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Bắt buộc đổi mật khẩu sau 90 ngày</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Khóa tài khoản sau 5 lần nhập sai</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" disabled>
                    <label class="form-check-label fw-bold">Xác thực hai yếu tố (2FA)</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Ghi nhật ký hoạt động</label>
                </div>
            </div>
        </div>

        <!-- Thông báo -->
        <div class="col-lg-6">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-4"><i class="fa-solid fa-bell text-warning me-2"></i>Thông Báo</h5>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Gửi email khi có lịch hẹn mới</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Cảnh báo kho thuốc sắp hết</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label fw-bold">Thông báo bảo trì thiết bị</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" disabled>
                    <label class="form-check-label fw-bold">Báo cáo tự động hàng tuần</label>
                </div>
            </div>
        </div>
    </div>
</div>
