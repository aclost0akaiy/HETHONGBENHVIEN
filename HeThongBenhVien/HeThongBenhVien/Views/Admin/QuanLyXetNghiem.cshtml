@model IEnumerable<HeThongBenhVien.Models.LabTest>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Xét Nghiệm"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Xét Nghiệm</h2><p class="text-muted mb-0">Theo dõi các yêu cầu xét nghiệm và kết quả</p></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng XN</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Chờ XN</p><h3 class="fw-bold m-0 text-warning">@Model.Count(l => l.Status == "Chờ xét nghiệm")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-info"><p class="text-muted fw-bold mb-1 small">Đang XN</p><h3 class="fw-bold m-0 text-info">@Model.Count(l => l.Status == "Đang xét nghiệm")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Có Kết Quả</p><h3 class="fw-bold m-0 text-success">@Model.Count(l => l.Status == "Đã có kết quả")</h3></div></div>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            var groupedByPatient = Model.GroupBy(l => l.MedicalRecord?.Appointment?.Patient?.FullName ?? "N/A").ToList();
            foreach (var group in groupedByPatient)
            {
                <div class="col-12">
                    <div class="glass-card p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold text-primary m-0"><i class="fas fa-user-circle me-2"></i>Bệnh nhân: @group.Key</h5>
                            <span class="badge bg-primary rounded-pill">@group.Count() xét nghiệm</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 15%">ID</th>
                                        <th style="width: 30%">Tên Xét Nghiệm</th>
                                        <th style="width: 20%">Ngày Tạo</th>
                                        <th style="width: 20%">Kết Quả</th>
                                        <th style="width: 15%">Trạng Thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">XN-@item.Id.ToString("D4")</td>
                                            <td class="fw-bold">@item.TestName</td>
                                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(string.IsNullOrEmpty(item.Result) ? "Chưa có" : item.Result)</td>
                                            <td>
                                                @if (item.Status == "Chờ xét nghiệm")
                                                {<span class="badge bg-warning text-dark">Chờ XN</span>}
                                                else if (item.Status == "Đang xét nghiệm")
                                                {<span class="badge bg-info">Đang XN</span>}
                                                else
                                                {<span class="badge bg-success">Đã có KQ</span>}
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="glass-card p-5 text-center text-muted">
                    <i class="fas fa-vials fa-3x mb-3"></i>
                    <p>Chưa có xét nghiệm nào được phân công.</p>
                </div>
            </div>
        }
    </div>
</div>
