@model IEnumerable<HeThongBenhVien.Models.Medicine>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Kho Dược"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Kho Dược</h2><p class="text-muted mb-0">Quản lý thuốc, tồn kho và nhập xuất kho dược phẩm</p></div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Thêm Thuốc</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Loại Thuốc</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Tổng Tồn Kho</p><h3 class="fw-bold m-0 text-success">@Model.Sum(m => m.StockQuantity)</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-danger"><p class="text-muted fw-bold mb-1 small">Sắp Hết</p><h3 class="fw-bold m-0 text-danger">@Model.Count(m => m.StockQuantity <= m.MinStock)</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Sắp Hết Hạn</p><h3 class="fw-bold m-0 text-warning">@Model.Count(m => m.ExpiryDate.HasValue && m.ExpiryDate.Value <= DateTime.Now.AddMonths(3))</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Tên Thuốc</th><th>Danh Mục</th><th>Đơn Vị</th><th>Giá</th><th>Tồn Kho</th><th>Hạn SD</th><th>NSX</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold">@item.Name</td>
                    <td><span class="badge bg-info bg-opacity-10 text-info">@item.Category</span></td>
                    <td>@item.Unit</td>
                    <td class="text-success fw-bold">@item.Price.ToString("N0") đ</td>
                    <td>
                        @if(item.StockQuantity <= item.MinStock){<span class="badge bg-danger">@item.StockQuantity ⚠️</span>}
                        else{<span class="badge bg-success">@item.StockQuantity</span>}
                    </td>
                    <td>@(item.ExpiryDate.HasValue ? item.ExpiryDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                    <td class="small text-muted">@item.Manufacturer</td>
                    <td class="text-center"><form asp-action="XoaThuoc" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xác nhận xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="8" class="text-center py-5 text-muted"><i class="fas fa-pills fa-3x mb-3"></i><p>Chưa có thuốc nào trong kho.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-plus me-2"></i>Thêm Thuốc Mới</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemThuoc" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="row">
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Tên Thuốc</label><input name="Name" class="form-control" required/></div>
                <div class="col-md-6 mb-3"><label class="form-label fw-bold">Danh Mục</label><select name="Category" class="form-select"><option>Kháng sinh</option><option>Giảm đau</option><option>Tim mạch</option><option>Tiêu hóa</option><option>Hô hấp</option><option>Vitamin</option><option>Khác</option></select></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Đơn Vị</label><select name="Unit" class="form-select"><option>Viên</option><option>Hộp</option><option>Chai</option><option>Ống</option><option>Gói</option></select></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Giá (VNĐ)</label><input name="Price" type="number" class="form-control" required/></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Số Lượng</label><input name="StockQuantity" type="number" class="form-control" value="0"/></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Tồn Kho Tối Thiểu</label><input name="MinStock" type="number" class="form-control" value="10"/></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Hạn Sử Dụng</label><input name="ExpiryDate" type="date" class="form-control"/></div>
                <div class="col-md-4 mb-3"><label class="form-label fw-bold">Nhà Sản Xuất</label><input name="Manufacturer" class="form-control"/></div>
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>
