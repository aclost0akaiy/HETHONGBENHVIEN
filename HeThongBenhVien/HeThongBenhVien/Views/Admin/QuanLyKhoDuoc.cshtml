@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Kho Dược";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Quản Lý Kho Dược</h2>
            <p class="text-muted mb-0">Quản lý tất cả các loại thuốc trong hệ thống và theo dõi đơn thuốc được cấp phát.</p>
        </div>
    </div>

    <!-- Tổng số thuốc Card -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="glass-card p-4 h-100 border-start border-4 border-info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1">Tổng Số Thuốc</p>
                        <h2 class="fw-bold m-0">@ViewBag.TotalMedicines</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                        <i class="fa-solid fa-pills fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-success fw-bold text-sm">
                    <i class="fa-solid fa-check-circle"></i> Dữ liệu được cập nhật
                </div>
            </div>
        </div>
    </div>

    <!-- Thêm thuốc mới -->
    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold text-dark mb-3">Thêm Thuốc Mới</h5>
                <form method="post" action="@Url.Action("ThemThuoc", "Admin")">
                    @Html.AntiForgeryToken()
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="medicineName" class="form-label fw-bold">Tên Thuốc</label>
                            <input type="text" class="form-control" id="medicineName" name="medicineName" placeholder="Nhập tên thuốc" required />
                        </div>
                        <div class="col-md-4">
                            <label for="medicinePrice" class="form-label fw-bold">Giá (đ)</label>
                            <input type="number" class="form-control" id="medicinePrice" name="medicinePrice" placeholder="Nhập giá thuốc" step="0.01" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fa-solid fa-plus me-2"></i>Thêm Thuốc
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Danh sách tất cả loại thuốc -->
    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold text-dark">Danh Sách Tất Cả Loại Thuốc Trong Hệ Thống</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>STT</th>
                                <th>Tên Thuốc</th>
                                <th>Giá (đ)</th>
                                <th>Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AllMedicines != null && ((List<HeThongBenhVien.Models.Medicine>)ViewBag.AllMedicines).Any())
                            {
                                @foreach (var medicine in ((List<HeThongBenhVien.Models.Medicine>)ViewBag.AllMedicines).Select((m, i) => new { item = m, index = i + 1 }))
                                {
                                    <tr>
                                        <td class="fw-bold">@medicine.index</td>
                                        <td class="fw-bold">@medicine.item.Name</td>
                                        <td class="text-end">@string.Format("{0:N0}", medicine.item.Price)</td>
                                        <td><span class="badge bg-success">Sẵn sàng sử dụng</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Không có thuốc nào trong hệ thống.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách thuốc từ đơn thuốc -->
    <div class="row g-4">
        <div class="col-lg-12 mb-4">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold text-dark">Danh Sách Chi Tiết Đơn Thuốc</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Bệnh Nhân</th>
                                <th>Tên Thuốc</th>
                                <th>Số Lượng</th>
                                <th>Đơn Vị</th>
                                <th>Đơn Giá (đ)</th>
                                <th>Thành Tiền (đ)</th>
                                <th>Hướng Dùng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AllPrescriptionDetails != null && ((List<HeThongBenhVien.Models.PrescriptionDetail>)ViewBag.AllPrescriptionDetails).Any())
                            {
                                @foreach (var detail in (List<HeThongBenhVien.Models.PrescriptionDetail>)ViewBag.AllPrescriptionDetails)
                                {
                                    <tr>
                                        <td class="fw-bold">
                                            @detail.Prescription?.MedicalRecord?.Appointment?.Patient?.FullName<br />
                                            <small class="text-muted">BN: @detail.Prescription?.MedicalRecord?.Appointment?.Patient?.PatientCode</small>
                                        </td>
                                        <td>@detail.MedicineName</td>
                                        <td class="text-center">@detail.Quantity</td>
                                        <td>@detail.Unit</td>
                                        <td class="text-end">@string.Format("{0:N0}", detail.Price)</td>
                                        <td class="text-end fw-bold">@string.Format("{0:N0}", detail.Price * detail.Quantity)</td>
                                        <td><small>@detail.DosageInstruction</small></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Không có đơn thuốc nào trong hệ thống.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
