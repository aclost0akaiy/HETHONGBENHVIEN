@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nhật Ký Hệ Thống";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Nhật Ký Hệ Thống</h2>
            <p class="text-muted mb-0">Theo dõi các hoạt động và lỗi phát sinh trong hệ thống.</p>
        </div>
        <div>
            <button class="btn btn-outline-danger px-4"><i class="fa-solid fa-trash-can me-2"></i> Xóa Nhật Ký Cũ</button>
        </div>
    </div>

    <div class="glass-card p-4">
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <select class="form-select">
                    <option>Tất cả mức độ</option>
                    <option>Thông tin (Info)</option>
                    <option>Cảnh báo (Warning)</option>
                    <option>Lỗi (Error)</option>
                </select>
            </div>
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" class="form-control" placeholder="Tìm kiếm theo từ khóa...">
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Thời Gian</th>
                        <th>Mức Độ</th>
                        <th>Nguồn</th>
                        <th>Thông Điệp</th>
                        <th>Người Dùng</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>12/05/2026 10:45:12</td>
                        <td><span class="badge bg-danger">Error</span></td>
                        <td>DatabaseService</td>
                        <td class="text-danger fw-medium">Lỗi kết nối timeout khi truy vấn bảng Patients.</td>
                        <td>System</td>
                    </tr>
                    <tr>
                        <td>12/05/2026 10:15:00</td>
                        <td><span class="badge bg-warning text-dark">Warning</span></td>
                        <td>AuthMiddleware</td>
                        <td>Đăng nhập sai mật khẩu 3 lần liên tiếp.</td>
                        <td>admin_user</td>
                    </tr>
                    <tr>
                        <td>12/05/2026 09:30:22</td>
                        <td><span class="badge bg-info">Info</span></td>
                        <td>AdminController</td>
                        <td>Cập nhật cấu hình hệ thống thành công.</td>
                        <td>Administrator</td>
                    </tr>
                    <tr>
                        <td>12/05/2026 08:00:00</td>
                        <td><span class="badge bg-info">Info</span></td>
                        <td>BackupJob</td>
                        <td>Đã hoàn thành sao lưu tự động định kỳ.</td>
                        <td>System</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
