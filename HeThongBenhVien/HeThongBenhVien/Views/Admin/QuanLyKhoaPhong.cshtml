@model IEnumerable<HeThongBenhVien.Models.Department>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Khoa Phòng"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Quản Lý Khoa Phòng</h2>
            <p class="text-muted mb-0">Quản lý danh sách các khoa, phòng ban trong bệnh viện</p>
        </div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Thêm Khoa Phòng
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Khoa Phòng</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Đang Hoạt Động</p><h3 class="fw-bold m-0 text-success">@Model.Count(d => d.IsActive)</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Tổng Giường Bệnh</p><h3 class="fw-bold m-0">@Model.Sum(d => d.TotalBeds)</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-info"><p class="text-muted fw-bold mb-1 small">Giường Đang Dùng</p><h3 class="fw-bold m-0">@Model.Sum(d => d.OccupiedBeds)</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr>
                    <th>Mã Khoa</th><th>Tên Khoa</th><th>Trưởng Khoa</th><th>Giường</th><th>SĐT</th><th>Trạng Thái</th><th class="text-center">Hành Động</th>
                </tr></thead>
                <tbody>
                @if (Model.Any()) {
                    foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold text-primary">@item.DepartmentCode</td>
                        <td class="fw-bold">@item.DepartmentName</td>
                        <td>@item.HeadDoctor</td>
                        <td><span class="badge bg-info text-white">@item.OccupiedBeds/@item.TotalBeds</span></td>
                        <td>@item.Phone</td>
                        <td>
                            @if(item.IsActive){<span class="badge bg-success">Hoạt động</span>}
                            else{<span class="badge bg-secondary">Tạm ngưng</span>}
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#editModal@(item.Id)">
                                <i class="fas fa-edit me-1"></i> Chỉnh sửa
                            </button>

                        </td>
                    </tr>
                    }
                } else {
                    <tr><td colspan="7" class="text-center py-5 text-muted"><i class="fas fa-hospital fa-3x mb-3"></i><p>Chưa có khoa phòng nào.</p></td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm -->
<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-plus me-2"></i>Thêm Khoa Phòng</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemKhoaPhong" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body">
            <input type="hidden" name="DepartmentCode" value="" />
            <div class="mb-3"><label class="form-label fw-bold">Tên Khoa</label><input name="DepartmentName" class="form-control" required placeholder="Vui lòng nhập tên khoa"/></div>
            <div class="mb-3"><label class="form-label fw-bold">Mô tả</label><input name="Description" class="form-control" required placeholder="Vui lòng nhập mô tả khoa"/></div>
            <div class="mb-3"><label class="form-label fw-bold">Trưởng Khoa</label><input name="HeadDoctor" class="form-control" required placeholder="Vui lòng nhập tên trưởng khoa"/></div>
            <div class="row"><div class="col-md-6 mb-3"><label class="form-label fw-bold">Tổng Giường</label><input name="TotalBeds" type="number" class="form-control bg-light" value="50" readonly/></div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">SĐT</label>
                <input name="Phone" type="tel" class="form-control" required pattern="^0\d{9}$" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" placeholder="0123456789" />
            </div></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>

@foreach (var item in Model)
{
    <!-- Modal Chỉnh Sửa cho @item.DepartmentName -->
    <div class="modal fade" id="editModal@(item.Id)" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Chỉnh sửa Khoa Phòng</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="CapNhatKhoaPhong" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@item.Id" />
                    <input type="hidden" name="DepartmentCode" value="@item.DepartmentCode" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên Khoa</label>
                            <input name="DepartmentName" class="form-control" value="@item.DepartmentName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả</label>
                            <input name="Description" class="form-control" value="@item.Description" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Trưởng Khoa</label>
                            <input name="HeadDoctor" class="form-control" value="@item.HeadDoctor" required />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tổng Giường</label>
                                <input name="TotalBeds" type="number" class="form-control bg-light" value="50" readonly />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">SĐT</label>
                                <input name="Phone" type="tel" class="form-control" value="@item.Phone" required pattern="^0\d{9}$" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" placeholder="0123456789" />
                                <small class="text-muted">Nhập 10 số, bắt đầu bằng 0</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold d-block">Trạng thái hoạt động</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="IsActive" id="active@(item.Id)" value="true" @(item.IsActive ? "checked" : "")>
                                <label class="form-check-label text-success fw-bold" for="active@(item.Id)">Hoạt động</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="IsActive" id="inactive@(item.Id)" value="false" @(!item.IsActive ? "checked" : "")>
                                <label class="form-check-label text-danger fw-bold" for="inactive@(item.Id)">Ngưng hoạt động</label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
