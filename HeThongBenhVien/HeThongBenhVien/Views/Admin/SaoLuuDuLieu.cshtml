@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sao Lưu Dữ Liệu";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Sao Lưu & Phục Hồi Dữ Liệu</h2>
            <p class="text-muted mb-0">Quản lý các bản sao lưu để đảm bảo an toàn dữ liệu hệ thống.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4"><i class="fa-solid fa-plus me-2"></i> Tạo Bản Sao Lưu Mới</button>
        </div>
    </div>

    <div class="glass-card p-4">
        <h5 class="fw-bold mb-4">Lịch Sử Sao Lưu</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên File</th>
                        <th>Kích Thước</th>
                        <th>Ngày Tạo</th>
                        <th>Người Tạo</th>
                        <th>Trạng Thái</th>
                        <th class="text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><i class="fa-solid fa-file-zipper text-warning me-2"></i><span class="fw-bold">backup_2026_05_12.zip</span></td>
                        <td>250 MB</td>
                        <td>12/05/2026 01:00 AM</td>
                        <td>Hệ thống (Auto)</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success">Hoàn thành</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" title="Tải xuống"><i class="fa-solid fa-download"></i></button>
                            <button class="btn btn-sm btn-outline-warning" title="Phục hồi"><i class="fa-solid fa-rotate-left"></i></button>
                            <button class="btn btn-sm btn-outline-danger" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><i class="fa-solid fa-file-zipper text-warning me-2"></i><span class="fw-bold">backup_2026_05_11.zip</span></td>
                        <td>248 MB</td>
                        <td>11/05/2026 01:00 AM</td>
                        <td>Hệ thống (Auto)</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success">Hoàn thành</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download"></i></button>
                            <button class="btn btn-sm btn-outline-warning"><i class="fa-solid fa-rotate-left"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
