@model IEnumerable<HeThongBenhVien.Models.MedicalEquipment>
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Quản Lý Thiết Bị Y Tế"; }

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div><h2 class="h3 mb-1" style="font-weight:700;">Quản Lý Thiết Bị Y Tế</h2><p class="text-muted mb-0">Theo dõi và quản lý thiết bị, máy móc y tế</p></div>
        <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="fas fa-plus me-1"></i> Thêm Thiết Bị</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-primary"><p class="text-muted fw-bold mb-1 small">Tổng Thiết Bị</p><h3 class="fw-bold m-0">@Model.Count()</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-success"><p class="text-muted fw-bold mb-1 small">Hoạt Động</p><h3 class="fw-bold m-0 text-success">@Model.Count(e => e.Status == "Hoạt động")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-warning"><p class="text-muted fw-bold mb-1 small">Bảo Trì</p><h3 class="fw-bold m-0 text-warning">@Model.Count(e => e.Status == "Bảo trì")</h3></div></div>
        <div class="col-md-3"><div class="glass-card p-3 border-start border-4 border-danger"><p class="text-muted fw-bold mb-1 small">Hỏng</p><h3 class="fw-bold m-0 text-danger">@Model.Count(e => e.Status == "Hỏng")</h3></div></div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>Mã TB</th><th>Tên Thiết Bị</th><th>Loại</th><th>SL</th><th>Trạng Thái</th><th>Bảo Trì Cuối</th><th class="text-center">Xóa</th></tr></thead>
                <tbody>
                @if(Model.Any()){ foreach(var item in Model){
                <tr>
                    <td class="fw-bold text-primary">@item.EquipmentCode</td>
                    <td class="fw-bold">@item.EquipmentName</td>
                    <td><span class="badge bg-info bg-opacity-10 text-info">@item.Category</span></td>
                    <td>@item.Quantity</td>
                    <td>
                        @if(item.Status=="Hoạt động"){<span class="badge bg-success">Hoạt động</span>}
                        else if(item.Status=="Bảo trì"){<span class="badge bg-warning text-dark">Bảo trì</span>}
                        else{<span class="badge bg-danger">Hỏng</span>}
                    </td>
                    <td>@item.LastMaintenanceDate.ToString("dd/MM/yyyy")</td>
                    <td class="text-center"><form asp-action="XoaThietBi" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id"/><button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Xác nhận xóa?');"><i class="fas fa-trash"></i></button></form></td>
                </tr>
                }}else{<tr><td colspan="7" class="text-center py-5 text-muted"><i class="fas fa-microscope fa-3x mb-3"></i><p>Chưa có thiết bị nào.</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="fas fa-plus me-2"></i>Thêm Thiết Bị</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
    <form asp-action="ThemThietBi" method="post">@Html.AntiForgeryToken()
        <div class="modal-body">
            <div class="mb-3"><label class="form-label fw-bold">Mã Thiết Bị</label><input name="EquipmentCode" class="form-control" required/></div>
            <div class="mb-3"><label class="form-label fw-bold">Tên Thiết Bị</label><input name="EquipmentName" class="form-control" required/></div>
            <div class="mb-3"><label class="form-label fw-bold">Loại</label><select name="Category" class="form-select"><option>Chẩn đoán hình ảnh</option><option>Xét nghiệm</option><option>Phẫu thuật</option><option>Hồi sức</option><option>Vật tư tiêu hao</option></select></div>
            <div class="row"><div class="col-md-6 mb-3"><label class="form-label fw-bold">Số Lượng</label><input name="Quantity" type="number" class="form-control" value="1"/></div>
            <div class="col-md-6 mb-3"><label class="form-label fw-bold">Trạng Thái</label><select name="Status" class="form-select"><option>Hoạt động</option><option>Bảo trì</option><option>Hỏng</option></select></div></div>
            <div class="mb-3"><label class="form-label fw-bold">Bảo Trì Cuối</label><input name="LastMaintenanceDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")"/></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
    </form>
</div></div></div>
