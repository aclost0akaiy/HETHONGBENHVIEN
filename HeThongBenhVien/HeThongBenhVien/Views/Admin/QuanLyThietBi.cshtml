@model IEnumerable<HeThongBenhVien.Models.MedicalEquipment>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Thiết Bị Y Tế";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700;">Thiết Bị Y Tế</h2>
            <p class="text-muted mb-0">Theo dõi trạng thái và số lượng trang thiết bị y tế.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4"><i class="fa-solid fa-plus me-2"></i> Thêm Thiết Bị</button>
        </div>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="glass-card p-3 border-start border-4 border-primary">
                <div class="text-muted small fw-bold">Tổng thiết bị</div>
                <h3 class="mb-0 fw-bold">@(Model?.Count() ?? 0)</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-start border-4 border-success">
                <div class="text-muted small fw-bold">Đang hoạt động</div>
                <h3 class="mb-0 fw-bold">@(Model?.Count(x => x.Status == "Hoạt động") ?? 0)</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-start border-4 border-warning">
                <div class="text-muted small fw-bold">Đang bảo trì</div>
                <h3 class="mb-0 fw-bold">@(Model?.Count(x => x.Status == "Bảo trì") ?? 0)</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-start border-4 border-danger">
                <div class="text-muted small fw-bold">Báo hỏng</div>
                <h3 class="mb-0 fw-bold">@(Model?.Count(x => x.Status == "Hỏng") ?? 0)</h3>
            </div>
        </div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã TB</th>
                        <th>Tên Thiết Bị</th>
                        <th>Phân Loại</th>
                        <th>Số Lượng</th>
                        <th>Bảo Trì Lần Cuối</th>
                        <th>Trạng Thái</th>
                        <th class="text-end">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@item.EquipmentCode</span></td>
                                <td class="fw-bold">@item.EquipmentName</td>
                                <td>@item.Category</td>
                                <td>@item.Quantity</td>
                                <td>@item.LastMaintenanceDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Status == "Hoạt động")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success"><i class="fa-solid fa-circle-check"></i> Hoạt động</span>
                                    }
                                    else if (item.Status == "Bảo trì")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning"><i class="fa-solid fa-wrench"></i> Bảo trì</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Hỏng</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-info" title="Lịch sử bảo trì"><i class="fa-solid fa-clock-rotate-left"></i></button>
                                    <button class="btn btn-sm btn-outline-primary" title="Chỉnh sửa"><i class="fa-solid fa-pen-to-square"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-microscope fs-1 mb-3 opacity-25"></i>
                                <p class="mb-0">Chưa có dữ liệu thiết bị.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
