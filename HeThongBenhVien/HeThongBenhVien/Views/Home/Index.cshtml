@{
    ViewData["Title"] = "Hệ thống Quản lý Bệnh viện Toàn diện";
}

<div class="container-fluid p-0">
    <!-- Hero Section -->
    <div class="row align-items-center min-vh-75 py-5">
        <div class="col-lg-6 mb-5 mb-lg-0 pe-lg-5">
            <div class="badge bg-primary bg-opacity-10 text-primary mb-3 px-3 py-2 rounded-pill fw-bold" style="letter-spacing: 1px;">
                GIẢI PHÁP Y TẾ SỐ #1
            </div>
            <h1 class="display-4 fw-bold mb-4" style="color: #0f172a; line-height: 1.2;">
                Hệ sinh thái <br />
                <span style="color: #0ea5e9;">Quản lý Bệnh viện</span><br />
                thông minh.
            </h1>
            <p class="lead text-muted mb-5" style="font-size: 1.15rem; line-height: 1.7;">
                MediCare mang đến trải nghiệm y tế tối ưu cho cả bệnh nhân và bác sĩ. Quản lý lịch khám, hồ sơ bệnh án và quy trình lâm sàng trên một nền tảng duy nhất, an toàn và bảo mật.
            </p>
            
            <div class="d-flex gap-3 flex-wrap">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow-sm d-flex align-items-center fw-bold text-white" style="background-color: #0ea5e9; border: none;">
                            <i class="fa-solid fa-chart-line me-2 fs-5"></i> Vào Bảng Điều Khiển
                        </a>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow-sm d-flex align-items-center fw-bold text-white" style="background-color: #0ea5e9; border: none;">
                            <i class="fa-solid fa-user-doctor me-2 fs-5"></i> Khám Bệnh Ngay
                        </a>
                    }
                    else 
                    {
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow-sm d-flex align-items-center fw-bold text-white" style="background-color: #0ea5e9; border: none;">
                            <i class="fa-solid fa-house me-2 fs-5"></i> Trang Chủ
                        </a>
                    }
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow-sm d-flex align-items-center fw-bold text-white" style="background-color: #0ea5e9; border: none;">
                        <i class="fa-solid fa-right-to-bracket me-2 fs-5"></i> Đăng Nhập Hệ Thống
                    </a>
                    <a href="#" class="btn btn-light btn-lg px-5 py-3 rounded-3 border d-flex align-items-center fw-bold text-dark" style="background-color: #ffffff;">
                        <i class="fa-regular fa-circle-play me-2 fs-5 text-primary"></i> Xem Demo
                    </a>
                }
            </div>

            <div class="d-flex align-items-center mt-5 gap-4">
                <div class="d-flex -space-x-4">
                    <img class="rounded-circle border border-2 border-white shadow-sm" style="width: 45px; height: 45px; object-fit: cover; z-index: 3;" src="https://ui-avatars.com/api/?name=User+1&background=random" alt="User 1">
                    <img class="rounded-circle border border-2 border-white shadow-sm" style="width: 45px; height: 45px; object-fit: cover; z-index: 2; margin-left: -15px;" src="https://ui-avatars.com/api/?name=User+2&background=random" alt="User 2">
                    <img class="rounded-circle border border-2 border-white shadow-sm" style="width: 45px; height: 45px; object-fit: cover; z-index: 1; margin-left: -15px;" src="https://ui-avatars.com/api/?name=User+3&background=random" alt="User 3">
                </div>
                <div>
                    <div class="d-flex text-warning fs-5">
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <span class="text-muted small fw-medium">Hơn 50+ bệnh viện tin dùng</span>
                </div>
            </div>
        </div>

        <div class="col-lg-6 position-relative text-center mt-5 mt-lg-0">
            <!-- Decorative background elements -->
            <div class="position-absolute top-50 start-50 translate-middle" style="width: 120%; height: 120%; background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, rgba(255,255,255,0) 70%); z-index: -1;"></div>
            
            <div class="row g-4 position-relative z-1">
                <!-- Card 1 -->
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-start h-100 feature-card transition-all" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 24px;">
                            <i class="fa-solid fa-file-medical"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Hồ Sơ Điện Tử</h5>
                        <p class="text-muted mb-0 small">Lưu trữ và trích xuất bệnh án trực tuyến tức thì, an toàn chuẩn HIPAA.</p>
                    </div>
                </div>
                <!-- Card 2 -->
                <div class="col-6" style="margin-top: 40px;">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-start h-100 feature-card transition-all" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                        <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 24px;">
                            <i class="fa-solid fa-calendar-check"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Lịch Khám Thông Minh</h5>
                        <p class="text-muted mb-0 small">Quản lý và sắp xếp lịch hẹn tự động, giảm thiểu thời gian chờ đợi.</p>
                    </div>
                </div>
                <!-- Card 3 -->
                <div class="col-6" style="margin-top: -40px;">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-start h-100 feature-card transition-all" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 24px;">
                            <i class="fa-solid fa-pills"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Quản Lý Dược Phẩm</h5>
                        <p class="text-muted mb-0 small">Kiểm soát kho thuốc, kê đơn điện tử và cảnh báo tương tác thuốc tự động.</p>
                    </div>
                </div>
                <!-- Card 4 -->
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-start h-100 feature-card transition-all" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                        <div class="icon-box bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 24px;">
                            <i class="fa-solid fa-chart-pie"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Báo Cáo Quản Trị</h5>
                        <p class="text-muted mb-0 small">Hệ thống biểu đồ phân tích trực quan giúp tối ưu hiệu suất bệnh viện.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .min-vh-75 {
        min-height: 75vh;
    }
    .feature-card {
        transition: all 0.3s ease;
    }
    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
</style>
