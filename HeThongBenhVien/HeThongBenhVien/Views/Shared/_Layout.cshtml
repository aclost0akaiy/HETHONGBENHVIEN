<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Khám Chữa Bệnh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeThongBenhVien.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #f8fafc;
            --text-color: #1e293b;
            --navbar-bg: rgba(255, 255, 255, 0.95);
            --border-color: rgba(0,0,0,0.05);
            --link-color: #475569;
            --footer-bg: #ffffff;
        }
        [data-theme="dark"] {
            --bg-color: #0f172a;
            --text-color: #f8fafc;
            --navbar-bg: rgba(15, 23, 42, 0.95);
            --border-color: rgba(255,255,255,0.1);
            --link-color: #cbd5e1;
            --footer-bg: #1e293b;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: background-color 0.3s, color 0.3s;
        }
        .navbar {
            background-color: var(--navbar-bg) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color) !important;
            transition: background-color 0.3s;
        }
        .navbar-brand {
            font-weight: 700;
            color: #0b57d0 !important;
            font-size: 1.5rem;
        }
        .nav-link {
            font-weight: 500;
            color: var(--link-color) !important;
            transition: color 0.3s ease;
            position: relative;
        }
        .nav-link:hover {
            color: #0b57d0 !important;
        }
        .nav-link.active-link {
            color: #0b57d0 !important;
            font-weight: 600;
        }
        .nav-link.active-link::after {
            content: '';
            position: absolute;
            bottom: -23px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #0b57d0;
            border-radius: 2px;
        }
        .btn-outline-primary {
            border-color: #0b57d0;
            color: #0b57d0 !important;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.2s ease;
        }
        .btn-outline-primary:hover {
            background-color: #0b57d0;
            color: white !important;
        }
        .footer {
            background-color: var(--footer-bg);
            border-top: 1px solid var(--border-color) !important;
            padding: 20px 0;
            color: var(--link-color);
            transition: background-color 0.3s;
        }
        .theme-toggle {
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
            background: transparent;
            border: none;
            color: var(--link-color);
            font-size: 1.2rem;
        }
        .theme-toggle:hover {
            background: var(--border-color);
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            (function () {
                var isNewLogin = '@(TempData["NewLogin"]?.ToString() == "true" ? "true" : "false")' === 'true';
                if (isNewLogin) {
                    sessionStorage.setItem('isLoggedInTab', 'true');
                } else if (!sessionStorage.getItem('isLoggedInTab')) {
                    window.location.href = '/Account/Logout';
                }
            })();
        </script>
    }
    @{
        var isHomePage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && 
                         ViewContext.RouteData.Values["Action"]?.ToString() == "Index";
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-0 py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-square-h text-primary fs-3"></i> 
                    QL KCB
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link @(isHomePage ? "active-link" : "")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("BenhNhan") || User.IsInRole("Patient")))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "UserGuide" ? "active-link" : "")" asp-controller="Patient" asp-action="UserGuide">Hướng dẫn</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Patient" ? "active-link" : "")" asp-controller="Patient" asp-action="Portal" style="color: var(--link-color) !important;">
                                    <i class="fa-regular fa-circle-user fs-5"></i> Cổng Bệnh Nhân
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <button id="themeToggle" class="theme-toggle" title="Chuyển đổi Sáng/Tối">
                                <i class="fa-solid fa-moon"></i>
                            </button>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("BenhNhan") || User.IsInRole("Patient"))
                            {
                                <li class="nav-item me-3 position-relative d-flex align-items-center">
                                    <a class="text-secondary" asp-controller="Patient" asp-action="Notifications" style="font-size: 1.25rem; transition: color 0.2s;" title="Thông báo">
                                        <i class="fa-regular fa-bell"></i>
                                        @if (ViewBag.UnreadNotificationCount as int? > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="width: 8px; height: 8px;"></span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item me-3 d-flex align-items-center">
                                    <a class="text-secondary" href="#" style="font-size: 1.25rem; transition: color 0.2s;" title="Cài đặt"><i class="fa-solid fa-gear"></i></a>
                                </li>
                                <li class="nav-item">
                                    <div class="d-flex align-items-center gap-3 ps-3 border-start" style="border-color: #cbd5e1 !important;">
                                        <div class="text-end d-none d-sm-block">
                                            <div class="fw-bold mb-0" style="font-size: 14px; color: var(--text-color); line-height: 1.2;">@User.FindFirst("FullName")?.Value</div>
                                            <div class="text-secondary small fw-medium" style="font-size: 11px;">ID: @(ViewBag.PatientCode as string ?? "Bệnh nhân")</div>
                                        </div>
                                        <a asp-controller="Patient" asp-action="Portal">
                                            <img src="/uploads/patient_avatar.png" alt="Avatar" class="rounded-circle border border-2 border-white shadow-sm" style="width: 38px; height: 38px; object-fit: cover;" />
                                        </a>
                                        <a class="btn btn-sm btn-outline-danger ms-2 py-1 px-2 fw-semibold" asp-controller="Account" asp-action="Logout" style="font-size: 11px; border-radius: 6px;">Đăng Xuất</a>
                                    </div>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item d-flex align-items-center">
                                    <span class="navbar-text me-3" style="color: var(--text-color)">
                                        Xin chào, @User.FindFirst("FullName")?.Value (@(User.IsInRole("Admin") ? "Admin" : "Bác sĩ"))
                                    </span>
                                </li>
                                <li class="nav-item">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="nav-link text-primary" asp-controller="Admin" asp-action="Dashboard">Trang Quản Trị</a>
                                    }
                                    else if (User.IsInRole("Doctor"))
                                    {
                                        <a class="nav-link text-primary" asp-controller="Doctor" asp-action="Dashboard">Trang Bác Sĩ</a>
                                    }
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">Đăng Xuất</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary text-primary px-3 ms-2" asp-controller="Account" asp-action="Login">Đăng Nhập NV Y Tế</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (isHomePage)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container pb-5">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    @if (!isHomePage)
    {
        <footer class="footer text-center">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <span>&copy; 2026 - Phần mềm Quản Lý Khám Chữa Bệnh</span>
                    <div>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none me-3" style="color: var(--link-color)">Chính sách bảo mật</a>
                    </div>
                </div>
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
        if(savedTheme === 'dark') {
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }

        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            
            if(newTheme === 'dark') {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
