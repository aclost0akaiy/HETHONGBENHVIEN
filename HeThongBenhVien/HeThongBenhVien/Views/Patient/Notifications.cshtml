@{
    ViewData["Title"] = "Nhắc Nhở";
    var upcomingAppointments = ViewBag.UpcomingAppointments as List<HeThongBenhVien.Models.Appointment>;
    var recentPrescription = ViewBag.RecentPrescription as HeThongBenhVien.Models.Prescription;
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--text-color);"><i class="fa-solid fa-bell text-info me-2"></i>Nhắc Nhở</h2>
            <p class="text-muted mb-0">Theo dõi lịch uống thuốc, hẹn tái khám và thông báo từ bác sĩ.</p>
        </div>
        <a href="@Url.Action("Portal", "Patient")" class="btn btn-outline-primary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background-color: var(--card-bg);">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: var(--text-color);">Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</h5>
                    
                    @if (recentPrescription != null && recentPrescription.PrescriptionDetails.Any())
                    {
                        foreach (var detail in recentPrescription.PrescriptionDetails)
                        {
                            <div class="alert border-0 rounded-4 p-3 d-flex align-items-start mb-3 shadow-sm" style="background-color: rgba(239, 68, 68, 0.1); border-left: 5px solid #ef4444 !important;">
                                <div class="bg-danger bg-opacity-25 p-3 rounded-circle text-danger me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="fa-solid fa-capsules fs-4"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold text-danger mb-1">Nhắc nhở uống thuốc định kỳ</h6>
                                    <p class="mb-0 small" style="color: var(--text-color);">@detail.MedicineName - Hướng dẫn: @detail.DosageInstruction</p>
                                    <button class="btn btn-sm btn-outline-danger mt-2 rounded-pill">Xác nhận đã uống</button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary">Hiện tại bạn không có đơn thuốc nào cần uống.</div>
                    }

                    @if (upcomingAppointments != null && upcomingAppointments.Any())
                    {
                        foreach (var app in upcomingAppointments)
                        {
                            <div class="alert border-0 rounded-4 p-3 d-flex align-items-start mb-3 shadow-sm" style="background-color: rgba(245, 158, 11, 0.1); border-left: 5px solid #f59e0b !important;">
                                <div class="bg-warning bg-opacity-25 p-3 rounded-circle text-warning me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="fa-solid fa-calendar-check fs-4"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold text-warning mb-1">Lịch hẹn sắp tới</h6>
                                    <p class="mb-0 small" style="color: var(--text-color);">Bạn có lịch hẹn vào lúc <strong>@app.AppointmentTime.ToString("HH:mm, dd/MM/yyyy")</strong>.</p>
                                </div>
                            </div>
                        }
                    }

                    <div class="mt-4">
                        <h5 class="fw-bold" style="color: var(--text-color);">Thông báo mới từ bác sĩ</h5>
                        @{
                            var notifications = ViewBag.Notifications as List<HeThongBenhVien.Models.Notification>;
                        }
                        @if (notifications != null && notifications.Any())
                        {
                            foreach (var note in notifications)
                            {
                                <div class="alert border-0 rounded-4 p-3 mb-3 shadow-sm" style="background-color: rgba(14, 165, 233, 0.08); border-left: 5px solid #0ea5e9 !important;">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="fw-bold text-info mb-1">@note.Doctor?.FullName</h6>
                                            <small class="text-muted">@note.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                    </div>
                                    <p class="mb-0" style="color: var(--text-color);">@note.Message</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-secondary">Bạn chưa có thông báo nào mới từ bác sĩ.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</div>
