@{
    ViewData["Title"] = "Nhắc Nhở Tự Động";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--text-color);"><i class="fa-solid fa-bell text-info me-2"></i>Nhắc Nhở Tự Động</h2>
            <p class="text-muted mb-0">Theo dõi lịch uống thuốc và hẹn tái khám của bạn.</p>
        </div>
        <a href="@Url.Action("Portal", "Patient")" class="btn btn-outline-primary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background-color: var(--card-bg);">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: var(--text-color);">Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</h5>
                    
                    <div class="alert border-0 rounded-4 p-3 d-flex align-items-start mb-3 shadow-sm" style="background-color: rgba(14, 165, 233, 0.1); border-left: 5px solid #0ea5e9 !important;">
                        <div class="bg-info bg-opacity-25 p-3 rounded-circle text-info me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fa-solid fa-capsules fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold text-info mb-1">Đến giờ uống thuốc (08:00 AM)</h6>
                            <p class="mb-0 small" style="color: var(--text-color);">Amoxicillin 500mg - 1 Viên (Sau khi ăn sáng)</p>
                            <span class="badge bg-success mt-2">Đã xác nhận uống</span>
                        </div>
                    </div>

                    <div class="alert border-0 rounded-4 p-3 d-flex align-items-start mb-3 shadow-sm" style="background-color: rgba(239, 68, 68, 0.1); border-left: 5px solid #ef4444 !important;">
                        <div class="bg-danger bg-opacity-25 p-3 rounded-circle text-danger me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fa-solid fa-syringe fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold text-danger mb-1">Sắp đến giờ uống thuốc (12:00 PM)</h6>
                            <p class="mb-0 small" style="color: var(--text-color);">Paracetamol 500mg - 1 Viên (Sau khi ăn trưa)</p>
                            <button class="btn btn-sm btn-outline-danger mt-2 rounded-pill">Xác nhận đã uống</button>
                        </div>
                    </div>

                    <div class="alert border-0 rounded-4 p-3 d-flex align-items-start mb-0 shadow-sm" style="background-color: rgba(245, 158, 11, 0.1); border-left: 5px solid #f59e0b !important;">
                        <div class="bg-warning bg-opacity-25 p-3 rounded-circle text-warning me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fa-solid fa-calendar-check fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold text-warning mb-1">Lịch hẹn tái khám tuần sau</h6>
                            <p class="mb-0 small" style="color: var(--text-color);">Bạn có lịch hẹn tái khám với BS. Nguyễn Văn A vào lúc <strong>09:00 AM, Thứ 3 tuần sau</strong>.</p>
                            <a href="@Url.Action("Booking", "Patient")" class="btn btn-sm btn-warning mt-2 rounded-pill text-dark fw-bold">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background-color: var(--card-bg);">
                <div class="card-body p-4 text-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/1041/1041916.png" class="img-fluid mb-3" style="width: 120px; opacity: 0.8;" />
                    <h5 class="fw-bold mb-3" style="color: var(--text-color);">Tùy chỉnh thông báo</h5>
                    <div class="form-check form-switch text-start mb-3">
                        <input class="form-check-input" type="checkbox" id="smsNotif" checked>
                        <label class="form-check-label" for="smsNotif" style="color: var(--text-color);">Thông báo qua SMS</label>
                    </div>
                    <div class="form-check form-switch text-start mb-3">
                        <input class="form-check-input" type="checkbox" id="zaloNotif" checked>
                        <label class="form-check-label" for="zaloNotif" style="color: var(--text-color);">Thông báo qua Zalo</label>
                    </div>
                    <div class="form-check form-switch text-start mb-3">
                        <input class="form-check-input" type="checkbox" id="appNotif" checked>
                        <label class="form-check-label" for="appNotif" style="color: var(--text-color);">Thông báo trên App</label>
                    </div>
                    <button class="btn btn-primary w-100 rounded-pill mt-3">Lưu Cài Đặt</button>
                </div>
            </div>
        </div>
    </div>
</div>
