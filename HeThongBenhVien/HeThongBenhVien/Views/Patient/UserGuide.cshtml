                        <!-- Tab 5: Đánh giá dịch vụ (Active by default!) -->
                        <button class="nav-link active text-start py-3 px-4 d-flex align-items-center gap-3" id="v-pills-rating-tab" data-bs-toggle="pill" data-bs-target="#v-pills-rating" type="button" role="tab" aria-controls="v-pills-rating" aria-selected="true">
                            <i class="fa-regular fa-star fs-5"></i>
                            <span>Đánh Giá Dịch Vụ</span>
                        </button>
                        <!-- Tab 6: Sơ đồ bệnh viện -->
                        <button class="nav-link text-start py-3 px-4 d-flex align-items-center gap-3" id="v-pills-map-tab" data-bs-toggle="pill" data-bs-target="#v-pills-map" type="button" role="tab" aria-controls="v-pills-map" aria-selected="false">
                            <i class="fa-solid fa-map-location-dot fs-5"></i>
                            <span>Sơ Đồ Bệnh Viện</span>
                        </button>
                    </div>

                    <!-- Bottom Action button in sidebar -->
                    <a href="@Url.Action("Booking", "Patient")" class="btn btn-primary-custom w-100 py-2.5 rounded-3 fw-bold text-white mt-4" style="font-size: 13px;">
                        Đặt lịch khám ngay
                    </a>
                </div>
            </div>

            <!-- Main Content Column (Right Column) -->
            <div class="col-md-8 col-lg-9">
                <div class="ps-md-2">
                    
                    <!-- Header title section -->
                    <div class="mb-4 text-start">
                        <a href="@Url.Action("Portal", "Patient")" class="btn btn-link text-decoration-none p-0 text-secondary hover-primary mb-3 fw-semibold" style="font-size: 0.9rem;">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại Cổng Bệnh Nhân
                        </a>
                        <h2 class="fw-bold text-dark mb-1" style="font-weight: 850 !important; font-size: 1.8rem; letter-spacing: -0.5px;">Hướng dẫn chi tiết</h2>
                        <p class="text-secondary mb-0" style="font-size: 0.95rem; color: #64748b !important;">Học cách quản lý lịch khám và hồ sơ sức khỏe trực tuyến của bạn một cách nhanh chóng và hiệu quả nhất.</p>
                    </div>

                    <!-- Tab Contents Panes -->
                    <div class="tab-content" id="v-pills-tabContent">
                        
                        <!-- Pane 1: Đặt Lịch Khám -->
                        <div class="tab-pane fade" id="v-pills-booking" role="tabpanel" aria-labelledby="v-pills-booking-tab">
                            <div class="row g-4">
                                <div class="col-lg-8">
                                    <div class="card portal-sidebar-card p-4 h-100">
                                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-4" style="background-color: rgba(11, 87, 208, 0.04); border: 1.5px solid rgba(11, 87, 208, 0.08);">
                                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-opacity-10 text-primary" style="width: 48px; height: 48px; background-color: rgba(11, 87, 208, 0.1); color: #0b57d0 !important; font-size: 1.25rem;">
                                                <i class="fa-regular fa-calendar"></i>
                                            </div>
                                            <div class="text-start">
                                                <h5 class="fw-bold text-dark mb-0" style="font-size: 14.5px; color: #0b57d0 !important;">Chức năng: Đặt Lịch Khám</h5>
                                                <p class="text-secondary small mb-0" style="font-size: 11px;">Chủ động đặt lịch hẹn khám bệnh trực tuyến nhanh chóng</p>
                                            </div>
                                        </div>

                                        <p class="text-secondary mb-4 small" style="line-height: 1.7; font-size: 0.9rem;">
                                            Đặt lịch hẹn khám chữa bệnh tại các khoa lâm sàng chỉ với vài bước đơn giản, giúp bệnh nhân chủ động thời gian và giảm thiểu xếp hàng chờ đợi.
                                        </p>

                                        <!-- Timeline Steps -->
                                        <div class="timeline-steps position-relative ps-2">
                                            <div class="position-absolute start-0 top-0 bottom-0 ms-3" style="border-left: 2px dotted #e2e8f0; width: 0; z-index: 1; top: 16px; bottom: 16px;"></div>
                                            
                                            <div class="d-flex gap-4 mb-4 position-relative" style="z-index: 2;">
                                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 32px; height: 32px; background-color: #0b57d0; font-size: 13px; flex-shrink: 0;">1</div>
                                                <div>
                                                    <h6 class="fw-bold text-dark mb-1">Bước 1: Nhấn chọn Đặt Lịch Khám</h6>
                                                    <p class="text-secondary small mb-0">Nhấp chọn thẻ **Đặt Lịch Khám** hoặc nút **Đặt lịch khám ngay** ở cột bên trái.</p>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-4 mb-4 position-relative" style="z-index: 2;">
                                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 32px; height: 32px; background-color: #0b57d0; font-size: 13px; flex-shrink: 0;">2</div>
                                                <div>
                                                    <h6 class="fw-bold text-dark mb-1">Bước 2: Chọn Chuyên khoa & Giờ khám</h6>
                                                    <p class="text-secondary small mb-0">Lựa chọn chuyên khoa, chọn bác sĩ khám mong muốn cùng ngày hẹn và khung giờ khám rảnh phù hợp với bạn.</p>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-4 position-relative" style="z-index: 2;">
                                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 32px; height: 32px; background-color: #0b57d0; font-size: 13px; flex-shrink: 0;">3</div>
                                                <div>
                                                    <h6 class="fw-bold text-dark mb-1">Bước 3: Nhận Số thứ tự (E-ticket)</h6>
                                                    <p class="text-secondary small mb-0">Xác nhận lịch hẹn. Hệ thống sẽ sinh mã số thứ tự điện tử. Bạn chỉ cần đến phòng khám đúng giờ để khám ngay.</p>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="text-center mt-5">
                                            <a href="@Url.Action("Booking", "Patient")" class="btn btn-primary-custom px-4 py-2.5 rounded-3 fw-bold text-white d-flex align-items-center justify-content-center gap-2 mx-auto" style="width: fit-content;">
                                                Bắt đầu đặt lịch ngay <i class="fa-solid fa-arrow-right"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 d-flex flex-column gap-4">
                                    <div class="card portal-sidebar-card overflow-hidden text-start">
                                        <img src="/uploads/patient_hero.png" alt="Booking illustration" style="height: 150px; object-fit: contain; background-color: #e6f0ff;" />
                                        <div class="p-3">
                                            <h6 class="fw-bold text-dark mb-1">Đặt lịch 24/7</h6>
                                            <p class="text-secondary small mb-0">Tiết kiệm thời gian, không còn phải xếp hàng đăng ký số khám bệnh tại bệnh viện.</p>
                                        </div>
                                    </div>
                                    <div class="card portal-sidebar-card p-3 text-start bg-light border-0">
                                        <h6 class="fw-bold text-dark mb-2">Cần hỗ trợ?</h6>
                                        <div class="bg-white rounded-pill text-center py-2 text-primary fw-bold shadow-sm d-flex align-items-center justify-content-center gap-2 border" style="color: #0b57d0 !important;">
                                            <i class="fa-solid fa-phone"></i> Hotline: 1900 1234
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pane 2: Hồ Sơ Bệnh Án -->
                        <div class="tab-pane fade" id="v-pills-ehr" role="tabpanel" aria-labelledby="v-pills-ehr-tab">
                            <div class="row g-4">
                                <div class="col-lg-8">
                                    <div class="card portal-sidebar-card p-4 h-100">
                                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-4" style="background-color: rgba(139, 92, 246, 0.04); border: 1.5px solid rgba(139, 92, 246, 0.08);">
