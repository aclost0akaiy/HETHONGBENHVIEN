                            <i class="fa-regular fa-file-lines fs-5"></i>
                            <span>Hồ Sơ Bệnh Án</span>
                        </button>
                        <!-- Tab 3: Thanh toán QR -->
                        <button class="nav-link text-start py-3 px-4 d-flex align-items-center gap-3" id="v-pills-payment-tab" data-bs-toggle="pill" data-bs-target="#v-pills-payment" type="button" role="tab" aria-controls="v-pills-payment" aria-selected="false">
