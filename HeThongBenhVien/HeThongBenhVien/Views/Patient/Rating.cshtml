@{
    ViewData["Title"] = "Đánh Giá Dịch Vụ";
}

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--text-color);"><i class="fa-solid fa-star text-warning me-2"></i>Đánh Giá Dịch Vụ</h2>
            <p class="text-muted mb-0">Phản hồi của bạn giúp chúng tôi cải thiện chất lượng tốt hơn.</p>
        </div>
        <a href="@Url.Action("Portal", "Patient")" class="btn btn-outline-primary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4" style="background-color: var(--card-bg);">
                <div class="card-body p-5 text-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135690.png" class="img-fluid mb-4 rounded-circle bg-light p-2 shadow-sm" style="width: 120px;" />
                    <h5 class="fw-bold mb-1" style="color: var(--text-color);">Lượt khám gần nhất</h5>
                    <p class="text-muted small mb-4">Ngày 20/05/2026 - BS. Nguyễn Văn A - Khoa Nội Tổng Hợp</p>
                    
                    <h4 class="fw-bold mb-3" style="color: var(--text-color);">Bạn cảm thấy hài lòng không?</h4>
                    <div class="d-flex justify-content-center gap-3 mb-4 rating-stars">
                        <i class="fa-regular fa-star fa-2x text-warning" style="cursor:pointer;" onclick="rate(1)"></i>
                        <i class="fa-regular fa-star fa-2x text-warning" style="cursor:pointer;" onclick="rate(2)"></i>
                        <i class="fa-regular fa-star fa-2x text-warning" style="cursor:pointer;" onclick="rate(3)"></i>
                        <i class="fa-regular fa-star fa-2x text-warning" style="cursor:pointer;" onclick="rate(4)"></i>
                        <i class="fa-regular fa-star fa-2x text-warning" style="cursor:pointer;" onclick="rate(5)"></i>
                    </div>

                    <div class="form-group text-start mb-4">
                        <label class="fw-bold mb-2" style="color: var(--text-color);">Góp ý thêm (Tùy chọn)</label>
                        <textarea class="form-control rounded-3" rows="4" placeholder="Chia sẻ trải nghiệm của bạn với bác sĩ và nhân viên y tế..."></textarea>
                    </div>

                    <button class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 shadow" onclick="submitRating()">
                        <i class="fa-solid fa-paper-plane me-2"></i>Gửi Đánh Giá
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let currentRating = 0;
    function rate(stars) {
        currentRating = stars;
        const starElements = document.querySelectorAll('.rating-stars i');
        starElements.forEach((el, index) => {
            if (index < stars) {
                el.classList.remove('fa-regular');
                el.classList.add('fa-solid');
            } else {
                el.classList.remove('fa-solid');
                el.classList.add('fa-regular');
            }
        });
    }

    function submitRating() {
        if (currentRating === 0) {
            alert('Vui lòng chọn số sao để đánh giá!');
            return;
        }
        alert('Cảm ơn bạn đã đánh giá ' + currentRating + ' sao! Phản hồi của bạn đã được ghi nhận.');
        window.location.href = '@Url.Action("Portal", "Patient")';
    }
</script>
