@model HeThongBenhVien.Models.Appointment
@using HeThongBenhVien.Models
@{
    ViewData["Title"] = "Đặt Lịch Khám Trực Tuyến";
    var myBookings = ViewBag.MyBookings as List<PatientBookingStatusItem> ?? new List<PatientBookingStatusItem>();
}

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--text-color);">
                <i class="fa-regular fa-calendar-check text-primary me-2"></i>Đặt Lịch Khám Trực Tuyến
            </h2>
            <p class="text-muted mb-0">Điền thông tin và theo dõi trạng thái xác nhận từ bác sĩ</p>
        </div>
        <a asp-action="Portal" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="booking-form-card shadow-sm">
                <div class="booking-form-header">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>Thông tin đặt lịch</span>
                </div>
                                <div class="p-3 p-sm-4 p-md-5">
                    <form asp-action="Booking" method="post">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">S&#7889; &#272;i&#7879;n Tho&#7841;i</label>
                                <input type="tel" class="form-control form-control-lg booking-input" name="PhoneNumber" value="@ViewBag.UserPhone" placeholder="0912345678" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">L&#253; do kh&#225;m (Tri&#7879;u ch&#7913;ng)</label>
                                <textarea id="symptomsText" name="Reason" class="form-control booking-input" rows="2" placeholder="V&iacute; d&#7909;: &#272;au &#273;&#7847;u, ch&#243;ng m&#7867;t, s&#7889;t cao..." required></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Ng&#224;y &amp; Gi&#7901; Kh&#225;m (mong mu&#7889;n)</label>
                                <div class="row g-2">
                                    <div class="col-12 col-sm-7">
                                        <input type="date" id="bookingDate" class="form-control form-control-lg booking-input" required>
                                    </div>
                                    <div class="col-12 col-sm-5">
                                        <div class="dropdown">
                                            <button class="form-select form-control-lg booking-input text-start d-flex justify-content-between align-items-center" type="button" id="timeDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" style="color: #64748b; font-weight: 500; font-size: 0.95rem;">
                                                <span id="selectedTimeText">-- Gi&#7901; --</span>
                                            </button>
                                            <ul class="dropdown-menu w-100 shadow border-0 mt-1" id="timeDropdownMenu" aria-labelledby="timeDropdownBtn" style="max-height: 250px; overflow-y: auto; border-radius: 12px; padding: 0.5rem 0; z-index: 1050;">
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('08:00', '08:00 SA')">08:00 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('08:30', '08:30 SA')">08:30 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('09:00', '09:00 SA')">09:00 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('09:30', '09:30 SA')">09:30 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('10:00', '10:00 SA')">10:00 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('10:30', '10:30 SA')">10:30 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('11:00', '11:00 SA')">11:00 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('11:30', '11:30 SA')">11:30 SA</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('13:30', '01:30 CH')">01:30 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('14:00', '02:00 CH')">02:00 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('14:30', '02:30 CH')">02:30 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('15:00', '03:00 CH')">03:00 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('15:30', '03:30 CH')">03:30 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('16:00', '04:00 CH')">04:00 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 border-bottom text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('16:30', '04:30 CH')">04:30 CH</a></li>
                                                <li><a class="dropdown-item py-2 px-3 text-dark fw-semibold" href="javascript:void(0)" onclick="selectTime('17:00', '05:00 CH')">05:00 CH</a></li>
                                            </ul>
                                            <input type="hidden" id="bookingTime" required>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" name="AppointmentTime" id="AppointmentTime" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">B&#225;c s&#297; kh&#225;m</label>
                                <div class="dropdown">
                                    <button class="form-select form-control-lg booking-input text-start d-flex justify-content-between align-items-center" type="button" id="doctorDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" style="color: #64748b; font-weight: 500; font-size: 0.95rem;">
                                        <span id="selectedDoctorText">-- Ch&#7885;n b&#225;c s&#297; --</span>
                                    </button>
                                    <ul class="dropdown-menu w-100 shadow border-0 mt-1" id="doctorDropdownMenu" aria-labelledby="doctorDropdownBtn" style="max-height: 280px; overflow-y: auto; border-radius: 12px; padding: 0.5rem 0; z-index: 1050;">
                                        <li class="p-3 text-center text-muted">&#272;ang t&#7843;i danh s&#225;ch b&#225;c s&#297;...</li>
                                    </ul>
                                    <input type="hidden" name="DoctorId" id="DoctorId">
                                </div>
                            </div>
                        </div>

                        <!-- Warning Alert Box -->
                        <div id="bookingWarningAlert" class="alert alert-danger border-0 rounded-4 mt-4 d-none align-items-start gap-3 shadow-sm" role="alert">
                            <div class="pending-icon bg-danger bg-opacity-10 text-danger" style="width: 32px; height: 32px; font-size: 0.9rem;"><i class="fa-solid fa-triangle-exclamation"></i></div>
                            <div>
                                <h6 class="fw-bold mb-1 text-danger" style="font-size: 0.9rem;">Th&ocirc;ng b&aacute;o</h6>
                                <p id="bookingWarningText" class="mb-0 small" style="font-size: 0.8rem;"></p>
                            </div>
                        </div>

                        <div class="mt-4 text-center">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
                                <i class="fa-solid fa-paper-plane me-2"></i>G&#7917;i y&#234;u c&#7847;u &#273;&#7863;t l&#7883;ch
                            </button>
                        </div>
                    </form>
                    
                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            const doctorDropdownMenu = document.getElementById('doctorDropdownMenu');
                            const selectedDoctorText = document.getElementById('selectedDoctorText');
                            const doctorDropdownBtn = document.getElementById('doctorDropdownBtn');
                            const doctorIdInput = document.getElementById('DoctorId');
                            
                            const bookingDate = document.getElementById('bookingDate');
                            const bookingTime = document.getElementById('bookingTime');
                            const selectedTimeText = document.getElementById('selectedTimeText');
                            const timeDropdownBtn = document.getElementById('timeDropdownBtn');
                            const appointmentTime = document.getElementById('AppointmentTime');

                            function updateAppointmentTime() {
                                if (bookingDate.value && bookingTime.value) {
                                    appointmentTime.value = bookingDate.value + 'T' + bookingTime.value;
                                } else {
                                    appointmentTime.value = '';
                                }
                            }

                            bookingDate.addEventListener('change', updateAppointmentTime);

                            window.selectTime = function(value, text) {
                                bookingTime.value = value;
                                selectedTimeText.textContent = text;
                                timeDropdownBtn.style.color = 'var(--text-color)';
                                updateAppointmentTime();
                            };

                            function showBookingWarning(message) {
                                const alertEl = document.getElementById('bookingWarningAlert');
                                const textEl = document.getElementById('bookingWarningText');
                                if (alertEl && textEl) {
                                    textEl.textContent = message;
                                    alertEl.classList.remove('d-none');
                                    alertEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                                }
                            }

                            function hideBookingWarning() {
                                const alertEl = document.getElementById('bookingWarningAlert');
                                if (alertEl) {
                                    alertEl.classList.add('d-none');
                                }
                            }

                            window.selectDoctor = function(id, name, dept, isBusy) {
                                if (isBusy === true || isBusy === 'true') {
                                    showBookingWarning("B\u00e1c s\u0129 \u0111ang b\u1eadn, vui l\u00f2ng ch\u1ecdn b\u00e1c s\u0129 kh\u00e1c!");
                                    doctorIdInput.value = '';
                                    selectedDoctorText.textContent = '-- Ch\u1ecdn b\u00e1c s\u0129 --';
                                    doctorDropdownBtn.style.color = '#64748b';
                                    return;
                                }
                                hideBookingWarning();
                                doctorIdInput.value = id;
                                selectedDoctorText.textContent = name;
                                doctorDropdownBtn.style.color = 'var(--text-color)';
                            };

                            function loadDoctors() {
                                fetch(`/Patient/GetDoctorsByDepartment?departmentId=0`)
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.length > 0) {
                                            let html = '';
                                            data.forEach(d => {
                                                let name = d.fullName;
                                                let depts = '';
                                                const match = d.fullName.match(/^(.*?)\s*\((.*?)\)$/);
                                                if (match) {
                                                    name = match[1];
                                                    depts = match[2];
                                                }
                                                html += `
                                                    <li>
                                                        <a class="dropdown-item py-2 px-3 border-bottom d-block" href="javascript:void(0)" onclick="selectDoctor('${d.id}', '${name}', '${depts}', ${d.isBusy})" style="white-space: normal;">
                                                            <div class="d-flex align-items-center justify-content-between">
                                                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">${name}</div>
                                                                ${d.isBusy ? '<span class="badge bg-danger text-white ms-2" style="font-size: 0.75rem;">B&#7853;n</span>' : '<span class="badge bg-success text-white ms-2" style="font-size: 0.75rem;">S&#7861;n S&#224;ng</span>'}
                                                            </div>
                                                            ${depts ? `<div class="text-muted small mt-0.5" style="font-size: 0.75rem;"><i class="fa-solid fa-stethoscope me-1 text-primary"></i>${depts}</div>` : ''}
                                                        </a>
                                                    </li>
                                                `;
                                            });
                                            doctorDropdownMenu.innerHTML = html;
                                        } else {
                                            doctorDropdownMenu.innerHTML = '<li class="dropdown-item text-muted text-center py-3">Kh&#244;ng c&#243; b&#225;c s&#297;</li>';
                                        }
                                    })
                                    .catch(err => {
                                        console.error("L\u1ed7i khi t\u1ea3i danh s\u00e1ch b\u00e1c s\u0129:", err);
                                        doctorDropdownMenu.innerHTML = '<li class="dropdown-item text-danger text-center py-3">Kh&#244;ng th\u1ec3 t\u1ea3i danh s\u00e1ch b\u00e1c s\u0129</li>';
                                    });
                            }

                            loadDoctors();

                            const bookingForm = doctorIdInput.closest('form');
                            if (bookingForm) {
                                bookingForm.addEventListener('submit', function(e) {
                                    if (!doctorIdInput.value) {
                                        showBookingWarning("Vui l\u00f2ng ch\u1ecdn b\u00e1c s\u0129 s\u1eb5n s\u00e0ng \u0111\u1ec3 ti\u1ebfp t\u1ee5c \u0111\u1eb7t l\u1ecbch!");
                                        e.preventDefault();
                                        return false;
                                    }
                                });
                            }
                        });
                    </script>

                    @if (TempData["PendingMessage"] != null)
                    {
                        <div class="alert alert-warning border-0 rounded-4 mt-4 d-flex align-items-start gap-3 shadow-sm" role="alert">
                            <div class="pending-icon"><i class="fa-solid fa-hourglass-half"></i></div>
                            <div>
                                <h6 class="fw-bold mb-1 text-warning">Đã gửi yêu cầu — Chờ xác nhận</h6>
                                <p class="mb-0 small">@TempData["PendingMessage"]</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="booking-status-card shadow-sm h-100">
                <div class="booking-status-header">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Lịch hẹn của bạn</span>
                </div>
                <div class="p-4">
                    @if (myBookings.Any())
                    {
                        <div class="booking-timeline">
                            @foreach (var item in myBookings)
                            {
                                var apt = item.Appointment;
                                var isPending = apt.Status == 0;
                                <div class="booking-item @(isPending ? "booking-pending" : "booking-confirmed")">
                                    <div class="booking-item-icon">
                                        <i class="fa-solid @(isPending ? "fa-clock" : "fa-circle-check")"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                                            <h6 class="fw-bold mb-0">@apt.Reason</h6>
                                            @if (isPending)
                                            {
                                                <span class="badge rounded-pill status-badge-pending">
                                                    <i class="fa-solid fa-spinner fa-spin-pulse me-1"></i>Chờ xác nhận
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill status-badge-confirmed">
                                                    <i class="fa-solid fa-check me-1"></i>Đã xác nhận
                                                </span>
                                            }
                                        </div>
                                        <p class="mb-1 small text-muted">
                                            <i class="fa-regular fa-calendar me-1"></i>
                                            @apt.AppointmentTime.ToString("HH:mm — dd/MM/yyyy")
                                        </p>

                                        @if (!isPending)
                                        {
                                            <div class="success-banner mt-3">
                                                <i class="fa-solid fa-circle-check me-2"></i>
                                                <strong>Đặt lịch thành công!</strong> Bác sĩ đã xác nhận lịch khám của bạn.
                                            </div>
                                            @if (!string.IsNullOrEmpty(item.DoctorSms))
                                            {
                                                <div class="sms-bubble mt-3">
                                                    <div class="sms-bubble-header">
                                                        <i class="fa-solid fa-comment-sms me-2"></i>
                                                        SMS từ @(item.DoctorName ?? "Bác sĩ")
                                                    </div>
                                                    <p class="mb-0">@item.DoctorSms</p>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="mb-0 small text-muted mt-2">
                                                <i class="fa-solid fa-info-circle me-1"></i>
                                                Bác sĩ sẽ xem xét và gửi SMS xác nhận ngày giờ khám.
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-booking text-center py-5">
                            <div class="empty-icon mb-3">
                                <i class="fa-regular fa-calendar-xmark"></i>
                            </div>
                            <h6 class="fw-bold text-muted">Chưa có lịch hẹn nào</h6>
                            <p class="text-muted small mb-0">Điền form bên trái để đặt lịch khám trực tuyến</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .booking-form-card, .booking-status-card {
        background: var(--footer-bg);
        border-radius: 20px;
        border: 1px solid rgba(14, 165, 233, 0.12);
        overflow: hidden;
    }
    .booking-form-header, .booking-status-header {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        color: white;
        padding: 1rem 1.5rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .booking-status-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }
    .booking-input {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .booking-input:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
    }
    .pending-icon {
        width: 42px; height: 42px;
        background: rgba(245, 158, 11, 0.15);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #f59e0b; font-size: 1.1rem; flex-shrink: 0;
    }
    .booking-item {
        display: flex;
        gap: 1rem;
        padding: 1.25rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        transition: transform 0.2s;
    }
    .booking-item:hover { transform: translateY(-2px); }
    .booking-pending {
        background: linear-gradient(135deg, rgba(245,158,11,0.08) 0%, rgba(245,158,11,0.03) 100%);
        border: 1px solid rgba(245, 158, 11, 0.2);
    }
    .booking-confirmed {
        background: linear-gradient(135deg, rgba(16,185,129,0.08) 0%, rgba(16,185,129,0.03) 100%);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .booking-item-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; flex-shrink: 0;
    }
    .booking-pending .booking-item-icon { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .booking-confirmed .booking-item-icon { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-badge-pending { background: #fef3c7; color: #b45309; font-weight: 600; }
    .status-badge-confirmed { background: #d1fae5; color: #047857; font-weight: 600; }
    .success-banner {
        background: rgba(16, 185, 129, 0.12);
        border-left: 4px solid #10b981;
        padding: 0.75rem 1rem;
        border-radius: 0 12px 12px 0;
        font-size: 0.875rem;
        color: #047857;
    }
    .sms-bubble {
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 16px;
        padding: 1rem;
        position: relative;
    }
    .sms-bubble-header {
        font-weight: 600;
        color: #0369a1;
        font-size: 0.8rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
        .empty-icon {
        width: 72px; height: 72px;
        margin: 0 auto;
        background: #f1f5f9;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; color: #94a3b8;
    }
    
    .dropdown-item {
        transition: background-color 0.2s;
    }
    .dropdown-item:hover {
        background-color: rgba(14, 165, 233, 0.08) !important;
    }
    #doctorDropdownMenu li:last-child a {
        border-bottom: none !important;
    }
</style>
