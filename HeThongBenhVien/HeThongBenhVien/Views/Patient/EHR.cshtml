@{
    ViewData["Title"] = "Hồ Sơ Sức Khỏe (EHR)";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--text-color);"><i class="fa-solid fa-file-medical text-success"></i> Hồ Sơ Sức Khỏe (EHR)</h2>
        <a asp-action="Portal" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
    
    <div class="card shadow-sm border-0 rounded-4" style="background-color: var(--navbar-bg);">
        <div class="card-body">
            <h5 style="color: var(--text-color)"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử khám gần đây</h5>
            <div class="table-responsive mt-3">
                <table class="table table-hover" style="color: var(--text-color);">
                    <thead>
                        <tr>
                            <th>Ngày Khám</th>
                            <th>Khoa</th>
                            <th>Bác Sĩ</th>
                            <th>Chẩn Đoán</th>
                            <th>Trạng Thái</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>12/05/2026</td>
                            <td>Nội khoa</td>
                            <td>BS. Trần Văn B</td>
                            <td>Viêm họng hạt</td>
                            <td><span class="badge bg-success">Đã hoàn tất</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-info"><i class="fa-solid fa-eye"></i> Xem chi tiết</button>
                                <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download"></i> Đơn thuốc</button>
                            </td>
                        </tr>
                        <tr>
                            <td>01/03/2026</td>
                            <td>Da liễu</td>
                            <td>BS. Lê Thị C</td>
                            <td>Viêm da cơ địa</td>
                            <td><span class="badge bg-success">Đã hoàn tất</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-info"><i class="fa-solid fa-eye"></i> Xem chi tiết</button>
                                <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download"></i> Đơn thuốc</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
