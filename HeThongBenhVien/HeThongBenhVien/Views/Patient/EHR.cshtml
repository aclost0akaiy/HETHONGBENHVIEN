@model IEnumerable<HeThongBenhVien.Models.MedicalRecord>
@{
    ViewData["Title"] = "Hồ Sơ Sức Khỏe (EHR)";
    var prescriptions = ViewBag.Prescriptions as List<HeThongBenhVien.Models.Prescription>;
    var labTests = ViewBag.LabTests as List<HeThongBenhVien.Models.LabTest>;
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--text-color);"><i class="fa-solid fa-file-medical text-success"></i> Hồ Sơ Sức Khỏe (EHR)</h2>
        <a asp-action="Portal" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
    
    <div class="card shadow-sm border-0 rounded-4" style="background-color: var(--navbar-bg);">
        <div class="card-body">
            <h5 style="color: var(--text-color)"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử khám gần đây</h5>
            <div class="table-responsive mt-3">
                <table class="table table-hover" style="color: var(--text-color);">
                    <thead>
                        <tr>
                            <th>Ngày Khám</th>
                            <th>Khoa</th>
                            <th>Chẩn Đoán</th>
                            <th>Đơn Thuốc</th>
                            <th>Xét Nghiệm</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model != null && Model.Any())
                        {
                            foreach(var item in Model)
                            {
                                <tr>
                                    <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(item.Department?.DepartmentName ?? "Chưa rõ")</td>
                                    <td>@item.Diagnosis</td>
                                    <td>
                                        @{
                                            var pr = prescriptions?.FirstOrDefault(p => p.MedicalRecordId == item.Id);
                                            if (pr != null)
                                            {
                                                <span class="badge bg-primary">@pr.PrescriptionDetails.Count loại thuốc</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Không kê đơn</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var lt = labTests?.Where(l => l.MedicalRecordId == item.Id).ToList();
                                            if (lt != null && lt.Any())
                                            {
                                                <span class="badge bg-info">@lt.Count xét nghiệm</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Không xét nghiệm</span>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted">Chưa có lịch sử khám bệnh.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
