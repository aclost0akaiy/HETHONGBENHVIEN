@model IEnumerable<HeThongBenhVien.Models.Appointment>
@using HeThongBenhVien.Models
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Hẹn Tái Khám";

    var notifiedIds = ViewBag.NotifiedPatientIds as List<int> ?? new List<int>();
    var notifiedIdsNullable = ViewBag.NotifiedPatientIds as List<int?> ?? new List<int?>();
    
    var totalCount = Model.Count();
    var notifiedCount = Model.Count(a => notifiedIds.Contains(a.PatientId) || notifiedIdsNullable.Contains(a.PatientId));
    var overdueCount = Model.Count(a => a.AppointmentTime.Date < DateTime.Today);
    var todayCount = Model.Count(a => a.AppointmentTime.Date == DateTime.Today);

    string FormatCount(int count) => count.ToString("D2");
}

<style>
    /* Custom style overrides to match the mockup */
    .custom-table-container {
        background: #ffffff;
        border: none !important;
        box-shadow: none !important;
    }
    
    .custom-table-container .table {
        border: none !important;
    }
    
    .custom-table-container th {
        border: none !important;
        background-color: #ffffff !important;
        color: #64748b !important;
        font-weight: 600 !important;
        padding-top: 16px !important;
        padding-bottom: 16px !important;
    }
    
    .custom-table-container td {
        border-top: none !important;
        border-bottom: 1px solid #f1f5f9 !important;
        padding-top: 20px !important;
        padding-bottom: 20px !important;
    }
    
    /* Pagination styling */
    #pagination-controls .page-item .page-link {
        border: none !important;
        background: transparent !important;
        color: #64748b !important;
        font-weight: 500 !important;
        padding: 6px 12px !important;
        border-radius: 6px !important;
        margin: 0 2px !important;
        transition: all 0.2s;
    }
    
    #pagination-controls .page-item.active .page-link {
        background-color: #0284c7 !important;
        color: #ffffff !important;
        font-weight: bold !important;
    }
    
    #pagination-controls .page-item.disabled .page-link {
        color: #cbd5e1 !important;
    }
    
    #pagination-controls .page-item:hover:not(.active):not(.disabled) .page-link {
        background-color: #f1f5f9 !important;
        color: #0f172a !important;
    }
</style>

<div class="container-fluid p-0">
    <!-- Header -->
    <div class="mb-4">
        <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Gửi Thông Báo Thông Minh (AI Smart Auto-Notification)</h2>
        <p class="text-muted mb-0">Hệ thống quét lịch hẹn tái khám của bệnh nhân để tự động gửi thông báo SMS trước ngày hẹn 1 ngày.</p>
    </div>

    <!-- Stats Bar Card -->
    <div class="glass-card mb-4 p-3 d-flex align-items-center justify-content-between bg-white" style="border: 1px solid var(--border-color) !important; border-radius: 12px;">
        <!-- Col 1: TỔNG HẸN -->
        <div class="d-flex align-items-center gap-3 flex-grow-1 justify-content-center py-1">
            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1;">
                <i class="fa-regular fa-calendar fs-5"></i>
            </div>
            <div>
                <div class="text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Tổng hẹn</div>
                <div class="fs-4 fw-bold text-dark" id="stat-total" style="line-height: 1.1;">@FormatCount(totalCount)</div>
            </div>
        </div>
        <div style="width: 1px; height: 40px; background: #cbd5e1;"></div>
        
        <!-- Col 2: ĐÃ NHẮC -->
        <div class="d-flex align-items-center gap-3 flex-grow-1 justify-content-center py-1">
            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1;">
                <i class="fa-regular fa-message fs-5"></i>
            </div>
            <div>
                <div class="text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Đã nhắc</div>
                <div class="fs-4 fw-bold text-dark" id="stat-notified" style="line-height: 1.1;">@FormatCount(notifiedCount)</div>
            </div>
        </div>
        <div style="width: 1px; height: 40px; background: #cbd5e1;"></div>
        
        <!-- Col 3: QUÁ HẠN -->
        <div class="d-flex align-items-center gap-3 flex-grow-1 justify-content-center py-1">
            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: #f1f5f9; color: #ef4444; border: 1px solid #fca5a5;">
                <i class="fa-solid fa-clock-rotate-left fs-5"></i>
            </div>
            <div>
                <div class="text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Quá hạn</div>
                <div class="fs-4 fw-bold text-danger" id="stat-overdue" style="line-height: 1.1;">@FormatCount(overdueCount)</div>
            </div>
        </div>
        <div style="width: 1px; height: 40px; background: #cbd5e1;"></div>
        
        <!-- Col 4: MỚI HÔM NAY -->
        <div class="d-flex align-items-center gap-3 flex-grow-1 justify-content-center py-1">
            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: #f1f5f9; color: #eab308; border: 1px solid #fef08a;">
                <i class="fa-solid fa-user-plus fs-5"></i>
            </div>
            <div>
                <div class="text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Mới hôm nay</div>
                <div class="fs-4 fw-bold text-dark" id="stat-today" style="line-height: 1.1;">@FormatCount(todayCount)</div>
            </div>
        </div>
    </div>

    <!-- Layout Split -->
    <div class="row">
        <!-- Main Table Column -->
        <div class="col-md-8 mb-4">
            <!-- Notification Alerts -->
            @if (TempData["DoctorNotificationSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 12px; background-color: #eafaf1 !important; border: 1px solid #bbf7d0 !important; color: #15803d !important; padding: 12px 20px;">
                    <i class="fa-regular fa-circle-check fs-5 text-success"></i>
                    <div class="fw-semibold" style="font-size: 0.9rem;">@TempData["DoctorNotificationSuccess"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; color: #15803d;"></button>
                </div>
            }
            @if (TempData["DoctorNotificationError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 12px; background-color: #fef2f2 !important; border: 1px solid #fca5a5 !important; color: #b91c1c !important; padding: 12px 20px;">
                    <i class="fa-solid fa-triangle-exclamation fs-5 text-danger"></i>
                    <div class="fw-semibold" style="font-size: 0.9rem;">@TempData["DoctorNotificationError"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; color: #b91c1c;"></button>
                </div>
            }

            <!-- Table Card -->
            <div class="glass-card p-0 overflow-hidden bg-white custom-table-container">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #ffffff;">
                        <tr style="border-bottom: 1px solid #f1f5f9 !important;">
                            <th class="ps-4 py-3 text-uppercase fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px;">Bệnh Nhân</th>
                            <th class="py-3 text-uppercase fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px;">Thời Gian Hẹn Gần Nhất</th>
                            <th class="py-3 text-uppercase fw-bold text-secondary text-center" style="font-size: 0.75rem; letter-spacing: 0.5px;">Tình Trạng</th>
                            <th class="py-3 text-uppercase fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px;">Lý Do Khám Cũ</th>
                            <th class="py-3 text-uppercase fw-bold text-secondary text-center" style="font-size: 0.75rem; letter-spacing: 0.5px;">SMS Nhắc Hẹn</th>
                            <th class="pe-4 py-3 text-uppercase fw-bold text-secondary text-end" style="font-size: 0.75rem; letter-spacing: 0.5px;">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody id="appointment-tbody">
                        @foreach(var item in Model)
                        {
                            var hasNotified = notifiedIds.Contains(item.PatientId) || notifiedIdsNullable.Contains(item.PatientId);
                            var isOverdue = item.AppointmentTime.Date < DateTime.Today;
                            var isToday = item.AppointmentTime.Date == DateTime.Today;

                            <tr class="patient-row" 
                                style="border-bottom: 1px solid #e2e8f0;"
                                data-date="@item.AppointmentTime.ToString("yyyy-MM-dd")" 
                                data-name="@item.Patient?.FullName" 
                                data-code="@item.Patient?.PatientCode" 
                                data-notified="@(hasNotified ? "true" : "false")"
                                data-overdue="@(isOverdue ? "true" : "false")"
                                data-today="@(isToday ? "true" : "false")">
                                
                                <td class="ps-4">
                                    <div class="fw-bold text-dark" style="font-size: 0.95rem;">@item.Patient?.FullName</div>
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1 fw-bold" style="border: 1px solid #bfdbfe !important; font-size: 0.7rem !important; border-radius: 4px;">@item.Patient?.PatientCode</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-primary" style="font-size: 0.9rem;">
                                        <i class="fa-regular fa-clock me-1 text-primary"></i> @item.AppointmentTime.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if(isOverdue) {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill fw-bold" style="font-size: 0.75rem !important; letter-spacing: 0.5px; padding: 6px 12px !important;">QUÁ HẠN</span>
                                    } else if (isToday) {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill fw-bold" style="font-size: 0.75rem !important; letter-spacing: 0.5px; padding: 6px 12px !important; color: #b45309 !important;">HÔM NAY</span>
                                    } else {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill fw-bold" style="font-size: 0.75rem !important; letter-spacing: 0.5px; padding: 6px 12px !important;">CÒN HẠN</span>
                                    }
                                </td>
                                <td class="text-secondary" style="font-size: 0.85rem;">@item.Reason</td>
                                <td class="text-center">
                                    @if (hasNotified)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-semibold d-inline-flex align-items-center gap-1.5" style="font-size: 0.8rem !important; padding: 6px 12px !important;">
                                            <i class="fa-regular fa-circle-check text-success"></i> Đã gửi SMS
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 rounded-pill fw-semibold d-inline-flex align-items-center gap-1.5" style="font-size: 0.8rem !important; padding: 6px 12px !important;">
                                            <i class="fa-solid fa-clock-rotate-left text-secondary"></i> Chưa gửi
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button type="button" class="btn btn-sm btn-light border d-inline-flex align-items-center justify-content-center rounded-3" style="width: 36px; height: 36px; background-color: #ffffff; border-color: #e2e8f0; color: #64748b; transition: all 0.2s;" onclick="openNotificationModal(@item.PatientId, '@item.Patient?.FullName')" title="Gửi SMS"><i class="fa-regular fa-paper-plane" style="font-size: 0.9rem;"></i></button>
                                        <button type="button" class="btn btn-sm btn-primary px-3 py-1 fw-bold d-inline-flex align-items-center gap-1" style="border-radius: 10px; background-color: #0056b3; border-color: #0056b3; height: 36px; font-size: 0.85rem;" onclick="openUpdateAppointmentModal(@item.Id, '@item.AppointmentTime.ToString("yyyy-MM-ddTHH:mm")')"><i class="fa-solid fa-pencil" style="font-size: 0.8rem;"></i> Chi tiết</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr id="emptyTablePlaceholder" style="display: none;">
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-folder-open fs-2 mb-2 d-block"></i>
                                Không có bệnh nhân hẹn tái khám.
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <!-- Pagination Footer -->
                <div class="d-flex justify-content-between align-items-center px-4 py-3" style="border-top: 1px solid #f1f5f9 !important; background: #ffffff;">
                    <div class="text-muted small" style="font-weight: 500;">
                        Hiển thị <span id="visible-count-label">0</span> trong số <span id="total-filtered-label">0</span> bệnh nhân
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0 gap-1" id="pagination-controls">
                            <!-- Dynamic page items -->
                        </ul>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Sidebar Filter Column -->
        <div class="col-md-4 mb-4">
            <!-- AI AUTO-SENDER SYSTEM STATUS CARD -->
            <div class="glass-card p-4 mb-4 bg-white shadow-sm" style="border: 1px solid var(--border-color) !important; border-radius: 12px;">
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                    <h6 class="fw-bold m-0 text-dark d-flex align-items-center gap-2" style="font-size: 0.9rem; letter-spacing: 0.5px;">
                        <i class="fa-solid fa-robot text-primary"></i> HỆ THỐNG GỬI TỰ ĐỘNG (AI)
                    </h6>
                    <div class="d-flex align-items-center gap-1.5">
                        <span class="position-relative d-inline-flex" style="width: 10px; height: 10px;">
                            <span class="animate-ping position-absolute inline-flex h-full w-full rounded-circle bg-success opacity-75" style="animation: pulse 1.5s infinite; position: absolute; width: 10px; height: 10px; border-radius: 50%; background-color: #22c55e;"></span>
                            <span class="relative inline-flex rounded-circle h-3 w-3 bg-success" style="width: 10px; height: 10px; background-color: #22c55e; border-radius: 50%;"></span>
                        </span>
                        <span class="small fw-bold text-success" style="font-size: 0.75rem;">ONLINE</span>
                    </div>
                </div>

                <style>
                    @@keyframes pulse {
                        0% { transform: scale(0.95); opacity: 0.5; }
                        50% { transform: scale(1.3); opacity: 0; }
                        100% { transform: scale(0.95); opacity: 0; }
                    }
                </style>

                <div class="mb-3">
                    <div class="small text-muted mb-1" style="font-size: 0.8rem; font-weight: 500;">
                        Quét nền tự động: <strong class="text-success">Đang hoạt động liên tục</strong>
                    </div>
                    <div class="small text-muted" style="font-size: 0.8rem; font-weight: 500;">
                        Cập nhật cuối: <strong class="text-primary" id="bg-worker-last-updated">--:--:--</strong>
                    </div>
                </div>

                <label class="form-label fw-bold text-uppercase text-muted mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Nhật ký hệ thống (Live Logs)</label>
                <div id="bg-worker-logs" class="p-2.5 bg-dark text-success rounded font-monospace" style="font-size: 0.75rem; height: 160px; overflow-y: auto; border: 1px solid #1e293b; line-height: 1.4; background-color: #0f172a !important; color: #38bdf8 !important;">
                    <div class="text-secondary">[Đang tải nhật ký từ máy chủ...]</div>
                </div>
            </div>

            <!-- FILTERS CARD -->
            <div class="glass-card p-4 bg-white" style="border: 1px solid var(--border-color) !important; border-radius: 12px; position: sticky; top: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold m-0 text-dark" style="font-size: 0.9rem; letter-spacing: 0.5px;">BỘ LỌC DỮ LIỆU</h6>
                    <a href="javascript:void(0)" class="text-decoration-none small fw-semibold text-primary" onclick="clearFilters()">Đặt lại</a>
                </div>
                
                <!-- Date Picker -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase text-muted mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Ngày tái khám</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" style="border-color: var(--border-color);"><i class="fa-regular fa-calendar"></i></span>
                        <input type="date" id="filterDate" class="form-control border-start-0" style="border-color: var(--border-color);" value="" onchange="applyFilters()">
                    </div>
                </div>
                
                <!-- Checkboxes -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase text-muted mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Trạng thái nhắc nhớ</label>
                    <div class="d-flex flex-column gap-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="expiryAll" value="all" checked onchange="handleExpiryCheckboxChange('all')">
                            <label class="form-check-label small text-dark fw-semibold" for="expiryAll">Tất cả</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="expiryActive" value="active" onchange="handleExpiryCheckboxChange('active')">
                            <label class="form-check-label small text-dark fw-semibold" for="expiryActive">Còn hạn tái khám</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="expiryOverdue" value="overdue" onchange="handleExpiryCheckboxChange('overdue')">
                            <label class="form-check-label small text-dark fw-semibold" for="expiryOverdue">Hết hạn tái khám</label>
                        </div>
                    </div>
                </div>

                <!-- Text Search -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase text-muted mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Tìm kiếm từ khóa</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" style="border-color: var(--border-color);"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" id="searchKeyword" class="form-control border-start-0" style="border-color: var(--border-color);" placeholder="Tìm tên, mã BN..." onkeyup="applyFilters()">
                    </div>
                </div>
                
                <button class="btn btn-primary w-100 py-2 fw-bold shadow-sm" onclick="applyFilters()" style="border-radius: 8px; background-color: #0284c7; border-color: #0284c7;">Áp dụng bộ lọc</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Gửi Thông Báo -->
<div class="modal fade" id="sendNotificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <div class="modal-header border-0 bg-light" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                <h5 class="modal-title fw-bold text-dark">Gửi Thông Báo Cho Bệnh Nhân</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SendNotificationHenTaiKham" asp-controller="Doctor" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" id="notifPatientId" name="patientId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Bệnh nhân</label>
                        <input type="text" id="notifPatientName" class="form-control bg-light fw-bold" readonly style="border-color: var(--border-color);" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Nội dung thông báo</label>
                        <textarea name="message" class="form-control" rows="4" required placeholder="Nhập nội dung thông báo/SMS..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold" style="border-radius: 8px; background-color: #0284c7; border-color: #0284c7;"><i class="fa-solid fa-paper-plane me-1"></i> Gửi Thông Báo</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Cập Nhật Lịch Hẹn -->
<div class="modal fade" id="updateAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <div class="modal-header border-0 bg-light" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                <h5 class="modal-title fw-bold text-dark">Cập Nhật Lịch Hẹn Khám</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateHenTaiKham" asp-controller="Doctor" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" id="updateAppointmentId" name="appointmentId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Ngày và Giờ Hẹn Khám Mới</label>
                        <input type="datetime-local" id="updateAppointmentTime" name="newAppointmentTime" class="form-control" required style="border-color: var(--border-color);" />
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold" style="border-radius: 8px; background-color: #0284c7; border-color: #0284c7;"><i class="fa-solid fa-save me-1"></i> Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let currentPage = 1;
    const rowsPerPage = 5;
    let filteredRows = [];

    function openNotificationModal(patientId, patientName) {
        document.getElementById('notifPatientId').value = patientId;
        document.getElementById('notifPatientName').value = patientName;
        var myModal = new bootstrap.Modal(document.getElementById('sendNotificationModal'));
        myModal.show();
    }

    function openUpdateAppointmentModal(appointmentId, currentTime) {
        document.getElementById('updateAppointmentId').value = appointmentId;
        document.getElementById('updateAppointmentTime').value = currentTime;
        var updateModal = new bootstrap.Modal(document.getElementById('updateAppointmentModal'));
        updateModal.show();
    }

    function handleExpiryCheckboxChange(type) {
        const allCb = document.getElementById('expiryAll');
        const activeCb = document.getElementById('expiryActive');
        const overdueCb = document.getElementById('expiryOverdue');

        if (type === 'all') {
            if (allCb.checked) {
                activeCb.checked = false;
                overdueCb.checked = false;
            } else {
                allCb.checked = true;
            }
        } else {
            if (activeCb.checked || overdueCb.checked) {
                allCb.checked = false;
            } else {
                allCb.checked = true;
            }
        }
        applyFilters();
    }

    function applyFilters() {
        const keyword = document.getElementById('searchKeyword').value.trim().toLowerCase();
        const selectedDate = document.getElementById('filterDate').value;
        const expiryAll = document.getElementById('expiryAll').checked;
        const expiryActive = document.getElementById('expiryActive').checked;
        const expiryOverdue = document.getElementById('expiryOverdue').checked;

        const rows = Array.from(document.querySelectorAll('.patient-row'));
        filteredRows = [];

        rows.forEach(row => {
            const name = row.getAttribute('data-name').toLowerCase();
            const code = row.getAttribute('data-code').toLowerCase();
            const date = row.getAttribute('data-date');
            const isOverdue = row.getAttribute('data-overdue') === 'true';

            const matchesKeyword = !keyword || name.includes(keyword) || code.includes(keyword);
            const matchesDate = !selectedDate || date === selectedDate;
            
            let matchesExpiry = false;
            if (expiryAll) {
                matchesExpiry = true;
            } else {
                if (expiryActive && !isOverdue) matchesExpiry = true;
                if (expiryOverdue && isOverdue) matchesExpiry = true;
            }

            if (matchesKeyword && matchesDate && matchesExpiry) {
                filteredRows.push(row);
            } else {
                row.style.display = 'none';
            }
        });

        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const placeholder = document.getElementById('emptyTablePlaceholder');
        if (filteredRows.length === 0) {
            if (placeholder) placeholder.style.display = '';
            document.getElementById('visible-count-label').innerText = '0';
            document.getElementById('total-filtered-label').innerText = '0';
            document.getElementById('pagination-controls').innerHTML = '';
            return;
        }

        if (placeholder) placeholder.style.display = 'none';

        // Hide all rows first
        const allRows = document.querySelectorAll('.patient-row');
        allRows.forEach(row => row.style.display = 'none');

        // Show rows for current page
        const startIdx = (currentPage - 1) * rowsPerPage;
        const endIdx = Math.min(startIdx + rowsPerPage, filteredRows.length);

        for (let i = startIdx; i < endIdx; i++) {
            filteredRows[i].style.display = '';
        }

        // Labels
        document.getElementById('visible-count-label').innerText = (endIdx - startIdx).toString();
        document.getElementById('total-filtered-label').innerText = filteredRows.length.toString();

        renderPagination();
    }

    function renderPagination() {
        const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
        const controls = document.getElementById('pagination-controls');
        controls.innerHTML = '';

        if (totalPages <= 1) return;

        // Previous button
        const prevLi = document.createElement('li');
        prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
        prevLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage - 1})" aria-label="Previous">&lt;</a>`;
        controls.appendChild(prevLi);

        // Page numbers
        for (let i = 1; i <= totalPages; i++) {
            const li = document.createElement('li');
            li.className = `page-item ${currentPage === i ? 'active' : ''}`;
            li.innerHTML = `<a class="page-link fw-bold" href="javascript:void(0)" onclick="changePage(${i})">${i}</a>`;
            controls.appendChild(li);
        }

        // Next button
        const nextLi = document.createElement('li');
        nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
        nextLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage + 1})" aria-label="Next">&gt;</a>`;
        controls.appendChild(nextLi);
    }

    function changePage(page) {
        currentPage = page;
        renderTable();
    }

    function clearFilters() {
        document.getElementById('searchKeyword').value = '';
        document.getElementById('filterDate').value = '';
        document.getElementById('expiryAll').checked = true;
        document.getElementById('expiryActive').checked = false;
        document.getElementById('expiryOverdue').checked = false;
        applyFilters();
    }

    // Initialize table filters on load
    document.addEventListener("DOMContentLoaded", () => {
        applyFilters();

        // Poll background worker logs
        function fetchBackgroundLogs() {
            $.get('/Doctor/GetBackgroundSenderLogs', function(res) {
                if (res && res.logs) {
                    $('#bg-worker-last-updated').text(res.lastUpdated);
                    let logHtml = '';
                    res.logs.forEach(log => {
                        let colorClass = 'text-info';
                        if (log.includes('[ERROR]')) colorClass = 'text-danger';
                        else if (log.includes('[AUTO-SMS]')) colorClass = 'text-success fw-bold';
                        else if (log.includes('[SYSTEM]')) colorClass = 'text-info';
                        
                        logHtml += `<div class="${colorClass}" style="margin-bottom: 4px; word-break: break-all;">${log}</div>`;
                    });
                    $('#bg-worker-logs').html(logHtml);
                }
            });
        }
        
        fetchBackgroundLogs();
        setInterval(fetchBackgroundLogs, 3000); // refresh every 3 seconds
    });
</script>
