@model IEnumerable<HeThongBenhVien.Models.Appointment>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Hẹn Tái Khám";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Danh Sách Bệnh Nhân Hẹn Tái Khám</h2>
            <p class="text-muted mb-0">Theo dõi ngày bệnh nhân cần quay lại kiểm tra.</p>
        </div>
        <div class="input-group w-25">
            <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
            <button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button>
        </div>
    </div>

    @if (TempData["DoctorNotificationSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["DoctorNotificationSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["DoctorNotificationError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["DoctorNotificationError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="glass-card p-0 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3">Mã BN</th>
                    <th class="py-3">Họ và Tên</th>
                    <th class="py-3">Ngày Tái Khám (Dự kiến)</th>
                    <th class="py-3">Lý Do Khám Cũ</th>
                    <th class="py-3">Trạng Thái Nhắc Nhở</th>
                    <th class="pe-4 py-3">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Patient?.PatientCode</td>
                        <td><div class="fw-bold text-dark">@item.Patient?.FullName</div></td>
                        <td>
                            @if(item.AppointmentTime.Date < DateTime.Today) {
                                <span class="text-danger fw-bold"><i class="fa-solid fa-circle-exclamation me-1"></i> Quá hạn</span>
                            } else if (item.AppointmentTime.Date == DateTime.Today) {
                                <span class="text-warning fw-bold text-dark"><i class="fa-regular fa-clock me-1"></i> Hôm nay</span>
                            } else {
                                <span class="text-primary fw-bold"><i class="fa-regular fa-calendar me-1"></i> @item.AppointmentTime.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                        <td>@item.Reason</td>
                        <td>
                            @if (ViewBag.NotifiedPatientIds != null && ((List<int>)ViewBag.NotifiedPatientIds).Contains(item.PatientId))
                            {
                                <span class="badge bg-success rounded-pill">Đã gửi SMS</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill">Chưa gửi SMS</span>
                            }
                        </td>
                        <td class="pe-4">
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="openNotificationModal(@item.PatientId, '@item.Patient?.FullName')"><i class="fa-solid fa-bell me-1"></i> Gửi SMS</button>
                            <button type="button" class="btn btn-sm btn-info text-white ms-1" onclick="openUpdateAppointmentModal(@item.Id, '@item.AppointmentTime.ToString("yyyy-MM-ddTHH:mm")')"><i class="fa-solid fa-pen-to-square"></i> Cập nhật</button>
                        </td>
                    </tr>
                }
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Không có bệnh nhân hẹn tái khám.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Gửi Thông Báo -->
<div class="modal fade" id="sendNotificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Gửi Thông Báo Cho Bệnh Nhân</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SendNotificationHenTaiKham" asp-controller="Doctor" method="post">
                <div class="modal-body">
                    <input type="hidden" id="notifPatientId" name="patientId" />
                    <div class="mb-3">
                        <label class="form-label">Bệnh nhân</label>
                        <input type="text" id="notifPatientName" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung thông báo</label>
                        <textarea name="message" class="form-control" rows="4" required placeholder="Nhập nội dung thông báo/SMS..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane me-1"></i> Gửi Thông Báo</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Cập Nhật Lịch Hẹn -->
<div class="modal fade" id="updateAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Cập Nhật Lịch Hẹn Khám</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateHenTaiKham" asp-controller="Doctor" method="post">
                <div class="modal-body">
                    <input type="hidden" id="updateAppointmentId" name="appointmentId" />
                    <div class="mb-3">
                        <label class="form-label">Ngày và Giờ Hẹn Khám Mới</label>
                        <input type="datetime-local" id="updateAppointmentTime" name="newAppointmentTime" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openNotificationModal(patientId, patientName) {
        document.getElementById('notifPatientId').value = patientId;
        document.getElementById('notifPatientName').value = patientName;
        var myModal = new bootstrap.Modal(document.getElementById('sendNotificationModal'));
        myModal.show();
    }

    function openUpdateAppointmentModal(appointmentId, currentTime) {
        document.getElementById('updateAppointmentId').value = appointmentId;
        document.getElementById('updateAppointmentTime').value = currentTime;
        var updateModal = new bootstrap.Modal(document.getElementById('updateAppointmentModal'));
        updateModal.show();
    }
</script>
