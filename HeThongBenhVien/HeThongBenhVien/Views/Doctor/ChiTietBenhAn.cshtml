@model HeThongBenhVien.Models.MedicalRecord
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Chi tiết Bệnh án";

    // Trạng thái hồ sơ
    bool isCompleted = Model.Appointment?.Status == 6 || Model.Appointment?.Status == 7 || Model.Appointment?.Status == 8 || Model.Appointment?.Status == 9 || Model.Appointment?.Status == 10;
    // Bệnh nhân đang ở trong bệnh viện (đã nhập viện và chưa xuất viện)
    bool isAdmitted = Model.AdmissionDate.HasValue && !Model.DischargeDate.HasValue;

    // Tính toán viện phí
    decimal examFee = 150000;
    decimal prescriptionFee = 0;
    var details = ViewBag.Prescription?.PrescriptionDetails as ICollection<HeThongBenhVien.Models.PrescriptionDetail>;
    if (details != null) { prescriptionFee = details.Sum(d => d.Price * d.Quantity); }
    decimal surgeryFee = ViewBag.SurgeryFee?.Price ?? 0;
    
    decimal roomFeeTotal = 0;
    // 1. Tính tiền phòng cho đợt đang nằm viện (nếu có)
    if (Model.AdmissionDate.HasValue && !Model.DischargeDate.HasValue)
    {
        var days = Math.Ceiling((DateTime.Now - Model.AdmissionDate.Value).TotalDays);
        if (days < 1) days = 1;
        roomFeeTotal = Model.RoomFee * (decimal)days;
    }
    
    // 2. Cộng dồn tiền phòng từ các đợt đã xuất viện (nếu có trong Notes)
    if (!string.IsNullOrEmpty(Model.Notes))
    {
        var regex = new System.Text.RegularExpressions.Regex(@"Tiền phòng: ([\d.,]+) VNĐ");
        var matches = regex.Matches(Model.Notes);
        foreach (System.Text.RegularExpressions.Match match in matches)
        {
            string feeString = match.Groups[1].Value.Replace(".", "").Replace(",", "");
            if (decimal.TryParse(feeString, out decimal pastFee))
            {
                roomFeeTotal += pastFee;
            }
        }
    }

    // 3. Tính tiền xét nghiệm / cận lâm sàng
    decimal labTestFee = 0;
    var labTests = ViewBag.LabTests as ICollection<HeThongBenhVien.Models.LabTest>;
    if (labTests != null)
    {
        foreach(var test in labTests)
        {
            if (test.TestName == "CBC") labTestFee += 100000;
            else if (test.TestName == "SinhHoa") labTestFee += 200000;
            else if (test.TestName == "SieuAm") labTestFee += 150000;
            else if (test.TestName == "XQuang") labTestFee += 120000;
            else if (test.TestName == "NuocTieu") labTestFee += 50000;
        }
    }
    
    decimal totalBill = examFee + prescriptionFee + surgeryFee + roomFeeTotal + labTestFee;
}

<style>
@@media print {
    /* ===================== ẨN TOÀN BỘ GIAO DIỆN ===================== */
    #sidebar,
    .top-navbar,
    .d-flex.justify-content-between.align-items-center.mb-4,
    .px-4.py-3.border-top,
    .p-4.bg-light.border-top,
    .btn-outline-primary,
    nav, header,
    #main-content > .top-navbar { display: none !important; }

    /* Reset layout */
    body { background: #fff !important; font-family: 'Times New Roman', serif !important; }
    #main-content { margin-left: 0 !important; padding: 0 !important; }
    .container-fluid { padding: 0 !important; }
    .row.justify-content-center > .col-lg-11 { max-width: 100% !important; flex: 0 0 100% !important; }
    .glass-card { box-shadow: none !important; border: none !important; border-radius: 0 !important; }

    /* ===================== TIÊU ĐỀ BỆNH VIỆN ===================== */
    .print-hospital-header { display: block !important; }

    /* ===================== BANNER BỆNH NHÂN ===================== */
    .p-4.text-white[style*="background-color: #0d56b9"] {
        background-color: #fff !important;
        color: #000 !important;
        border: 2px solid #000 !important;
        border-radius: 0 !important;
        padding: 12px 16px !important;
    }
    .p-4.text-white[style*="background-color: #0d56b9"] h3,
    .p-4.text-white[style*="background-color: #0d56b9"] div,
    .p-4.text-white[style*="background-color: #0d56b9"] span { color: #000 !important; opacity: 1 !important; }
    .p-4.text-white[style*="background-color: #0d56b9"] .bg-white { border: 1px solid #000 !important; }
    .p-4.text-white[style*="background-color: #0d56b9"] .fa-user { color: #000 !important; }
    /* Ẩn nút Khám Chuyên Khoa khi in */
    .p-4.text-white span.btn { display: none !important; }

    /* ===================== NỘI DUNG CHÍNH ===================== */
    .p-4.p-md-5.bg-white { padding: 16px !important; }

    /* Sinh hiệu & Triệu chứng */
    .row.g-4.mb-4 .col-md-6 .h-100 {
        border: 1px solid #999 !important;
        box-shadow: none !important;
        background-image: none !important;
    }

    /* Chẩn đoán */
    div[style*="background-color: #eff6ff"] {
        background-color: #f5f5f5 !important;
        border-left: 4px solid #000 !important;
    }

    /* Điều trị */
    div[style*="background-color: #fffdf5"] {
        background-color: #f5f5f5 !important;
        border-left: 4px solid #555 !important;
        border: 1px solid #999 !important;
    }

    /* Bảng toa thuốc */
    .table { border: 1px solid #000 !important; }
    .table th, .table td { border: 1px solid #555 !important; color: #000 !important; }
    .badge { background-color: #eee !important; color: #000 !important; border: 1px solid #999 !important; }

    /* Ẩn watermark stethoscope */
    .position-absolute.opacity-10 { display: none !important; }

    /* Page settings */
    @@page { size: A4; margin: 15mm 15mm 20mm 15mm; }
}

/* Block in màn hình - chỉ hiện khi print */
.print-hospital-header { display: none; }
</style>

<!-- PRINT HEADER: chỉ hiện khi in -->
<div class="print-hospital-header" style="text-align:center; padding-bottom: 10px; border-bottom: 2px solid #000; margin-bottom: 10px;">
    <table style="width:100%; border:none;">
        <tr>
            <td style="width:30%; vertical-align:middle; text-align:left; font-size:11px; border:none;">
                <strong>BỆNH VIỆN ĐA KHOA QUỐC TẾ</strong><br/>
                Địa chỉ: 123 Đường Y Tế, TP.HCM<br/>
                SĐT: 1900 1234<br/>
                Website: www.benhvien.vn
            </td>
            <td style="width:40%; vertical-align:middle; text-align:center; border:none;">
                <div style="font-size:18px; font-weight:bold; text-transform:uppercase; letter-spacing:1px;">BỆNH ÁN KHÁM BỆNH</div>
                <div style="font-size:12px; margin-top:4px;">Mã hồ sơ: <strong>@Model.Id</strong> &nbsp;|&nbsp; Ngày lập: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
                @if (Model.IsLocked)
                {
                    <div style="font-size:11px; color:#000; margin-top:3px;">✔ Đã khóa & ký số: <em>@Model.DigitalSignature</em></div>
                }
            </td>
            <td style="width:30%; vertical-align:middle; text-align:right; border:none;">
                <div style="font-size:11px;">
                    <strong>Bác sĩ điều trị:</strong><br/>
                    @Model.Appointment?.Doctor?.FullName<br/>
                    @Model.Appointment?.Doctor?.Department?.DepartmentName
                </div>
            </td>
        </tr>
    </table>
</div>

<div class="container-fluid p-0 pb-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 800; color: #1e293b;">
                <i class="fa-solid fa-laptop-medical text-primary me-2"></i>Hồ Sơ Bệnh Án Điện Tử
            </h2>
            @if (Model.IsLocked)
            {
                <div class="mt-2">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill"><i class="fa-solid fa-lock me-1"></i> Hồ sơ khám đã hoàn thành (Đã khóa lưu trữ)</span>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill ms-2" title="Chữ ký số có giá trị pháp lý"><i class="fa-solid fa-file-signature me-1"></i> Đã ký số bởi: @Model.DigitalSignature</span>
                </div>
            }
            else if (Model.Appointment?.Status == 3 || Model.Appointment?.Status == 4)
            {
                <p class="text-info fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-flask me-1"></i> Chờ KQ xét nghiệm</p>
            }
            else if (Model.Appointment?.Status == 5)
            {
                <p class="text-primary fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-file-medical me-1"></i> Đã có KQ xét nghiệm chờ lập đơn thuốc</p>
            }
            else if (Model.Appointment?.Status == 6)
            {
                <p class="text-warning fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-clock me-1"></i> Chờ đơn thuốc</p>
            }
            else if (Model.Appointment?.Status == 7)
            {
                <p class="text-primary fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-prescription me-1"></i> Đã có đơn thuốc</p>
            }
            else if (Model.Appointment?.Status == 8 || Model.Appointment?.Status == 9 || Model.Appointment?.Status == 10)
            {
                <p class="text-success fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-check-double me-1"></i> Hoàn thành khám</p>
            }
            else
            {
                <p class="text-warning fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-stethoscope me-1"></i> Đang khám</p>
            }
        </div>
        <a href="@Url.Action("HoSoBenhAn", "Doctor")" class="btn btn-outline-primary px-4 py-2 fw-bold" style="border-radius: 10px; transition: all 0.3s ease;">
            <i class="fa-solid fa-arrow-left me-2"></i> Trở về danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="glass-card shadow-lg rounded-4 overflow-hidden border-0" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                
                <!-- Bệnh nhân Header -->
                <div class="p-4 text-white" style="background-color: #0d56b9;">
                    <div class="d-flex align-items-center justify-content-between">
                        <!-- Left: Avatar + Info -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-white d-flex align-items-center justify-content-center rounded-3 flex-shrink-0" style="width: 52px; height: 52px;">
                                <i class="fa-solid fa-user" style="font-size: 22px; color: #0d56b9;"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0 text-white" style="font-size: 22px; line-height: 1.3;">@Model.Appointment?.Patient?.FullName</h3>
                                <div class="text-white opacity-90 fw-medium mt-1" style="font-size: 13px;">
                                    <span>Mã BN: @Model.Appointment?.Patient?.PatientCode</span>
                                    <span class="mx-2 opacity-60">|</span>
                                    <span>@Model.Appointment?.Patient?.Gender</span>
                                    <span class="mx-2 opacity-60">|</span>
                                    <span>@Model.Appointment?.Patient?.Age Tuổi</span>
                                </div>
                            </div>
                        </div>
                        <!-- Right: Badge + Date -->
                        <div class="text-end d-flex flex-column align-items-end gap-2">
                            <span class="btn btn-sm fw-bold text-white" style="background-color: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; font-size: 12px; padding: 5px 14px; letter-spacing: 0.2px;">Khám Chuyên Khoa</span>
                            <div class="text-white opacity-85" style="font-size: 12.5px; font-weight: 500;"><i class="fa-solid fa-calendar-check me-1"></i>Ngày khám: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
                        </div>
                    </div>
                </div>

                <!-- Main Content Body -->
                <div class="p-4 p-md-5 bg-white">
                    
                    <!-- Khối 1: Triệu chứng lâm sàng -->
                    <div class="row g-4 mb-4">
                        <div class="col-12">
                            <div class="h-100 p-4 rounded-4 shadow-sm bg-white" style="border: 1px solid #e2e8f0;">
                                <h6 class="fw-bold text-uppercase text-primary mb-3 pb-2 border-bottom d-flex align-items-center gap-2" style="letter-spacing: 0.5px; font-size: 12px; color: #0d56b9 !important;">
                                    <i class="fa-solid fa-user-doctor text-primary"></i>Triệu chứng lâm sàng
                                </h6>
                                @if (string.IsNullOrEmpty(Model.Symptoms))
                                {
                                    <div class="d-flex align-items-center justify-content-center py-5 text-center" style="min-height: 140px;">
                                        <p class="mb-0 text-muted italic" style="font-size: 13px; font-style: italic;">Chưa ghi nhận triệu chứng</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="p-3 rounded-3 text-dark font-medium" style="line-height: 1.7; font-size: 14px; background-color: rgba(99, 102, 241, 0.03); border: 1px solid rgba(99, 102, 241, 0.05); min-height: 140px; white-space: pre-wrap;">@Model.Symptoms</div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Khối 2: Chẩn đoán (Cozy Reading Space) -->
                    <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background-color: #eff6ff; border-left: 5px solid #0056b3;">
                        <i class="fa-solid fa-stethoscope position-absolute opacity-10" style="font-size: 7rem; right: -15px; top: -15px; color: #0056b3;"></i>
                        <h6 class="fw-bold text-uppercase text-primary mb-2 d-flex align-items-center" style="letter-spacing: 0.5px; font-size: 11px; color: #0056b3 !important;">
                            <span class="badge bg-primary bg-opacity-10 text-primary p-1.5 rounded-3 me-2" style="background-color: rgba(13, 110, 253, 0.1); color: #0056b3;"><i class="fa-solid fa-stethoscope"></i></span> CHẨN ĐOÁN BỆNH
                        </h6>
                        <h4 class="fw-bold text-dark mb-0 ms-2 leading-relaxed" style="line-height: 1.5; font-size: 1.15rem; max-width: 90%;">@(string.IsNullOrEmpty(Model.Diagnosis) ? "Chưa có chẩn đoán cụ thể" : Model.Diagnosis)</h4>
                    </div>

                    <!-- Khối 3: Hướng điều trị & Đơn thuốc (Cozy Reading Space) -->
                    <div class="p-4 rounded-4 mb-4 shadow-sm" style="background-color: #fffdf5; border: 1px solid #fef08a; border-left: 5px solid #856404;">
                        <h6 class="fw-bold text-uppercase text-warning mb-2 d-flex align-items-center" style="letter-spacing: 0.5px; font-size: 11px; color: #856404 !important;">
                            <span class="badge bg-warning bg-opacity-10 text-warning p-1.5 rounded-3 me-2" style="background-color: rgba(133, 100, 4, 0.1); color: #856404;"><i class="fa-solid fa-pills"></i></span> HƯỚNG ĐIỀU TRỊ / ĐƠN THUỐC
                        </h6>
                        <div class="text-dark fw-semibold ms-2 mb-3" style="white-space: pre-wrap; font-size: 15px; line-height: 1.6;">@(string.IsNullOrEmpty(Model.TreatmentPlan) ? "Theo dõi lâm sàng" : Model.TreatmentPlan)</div>
                        
                        @if (ViewBag.Prescription != null && ViewBag.Prescription.PrescriptionDetails != null)
                        {
                            var detailsList = ViewBag.Prescription.PrescriptionDetails as ICollection<HeThongBenhVien.Models.PrescriptionDetail>;
                            if (detailsList != null && detailsList.Count > 0)
                            {
                                <div class="bg-white p-3.5 rounded-3 shadow-sm border border-warning border-opacity-20 mt-3">
                                    <h6 class="fw-bold text-dark mb-3" style="font-size: 13.5px;"><i class="fa-solid fa-prescription-bottle-medical text-warning me-2"></i>Chi tiết toa thuốc chỉ định:</h6>
                                    <div class="table-responsive">
                                        <table class="table table-borderless table-hover align-middle mb-0" style="font-size: 13px;">
                                            <thead class="bg-light text-muted small text-uppercase">
                                                <tr>
                                                    <th class="rounded-start ps-3 py-2">Tên thuốc</th>
                                                    <th class="py-2">Số lượng</th>
                                                    <th class="py-2 rounded-end">Cách dùng &amp; Liều lượng</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach(var item in detailsList)
                                                {
                                                    <tr style="border-bottom: 1px dashed #f1f5f9;">
                                                        <td class="fw-bold text-dark py-3 ps-3">@item.MedicineName</td>
                                                        <td><span class="badge bg-primary bg-opacity-10 text-primary px-2.5 py-1 rounded-pill" style="font-size: 12px; font-weight: 700;">@item.Quantity @item.Unit</span></td>
                                                        <td class="text-muted"><i class="fa-solid fa-circle-info text-slate-400 me-1.5"></i>@item.DosageInstruction</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Khối 4: Phẫu thuật (Nếu có) -->
                    @if (ViewBag.SurgeryFee != null)
                    {
                        <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #fef2f2 0%, #fff1f2 100%); border-left: 5px solid #ef4444;">
                            <i class="fa-solid fa-scalpel position-absolute opacity-10" style="font-size: 7rem; right: 10px; top: -10px; color: #ef4444;"></i>
                            <h6 class="fw-bold text-uppercase text-danger mb-3" style="letter-spacing: 0.5px; font-size: 11px;">
                                <i class="fa-solid fa-scissors me-2"></i>Phẫu thuật / Thủ thuật
                            </h6>

                            <div class="row align-items-center ms-1">
                                <div class="col-md-12">
                                    <h5 class="fw-bold text-dark mb-1">@ViewBag.SurgeryFee.FeeName</h5>
                                    <p class="text-muted mb-0 font-medium" style="font-size: 13px;"><i class="fa-solid fa-user-doctor me-1.5"></i> Phẫu thuật viên: <strong class="text-dark">@(ViewBag.Surgeon != null ? ViewBag.Surgeon.FullName : "Chưa phân công")</strong></p>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Khối Cận Lâm Sàng / Xét Nghiệm -->
                    @if (ViewBag.LabTests != null)
                    {
                        var tests = ViewBag.LabTests as ICollection<HeThongBenhVien.Models.LabTest>;
                        if (tests != null && tests.Count > 0)
                        {
                            <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #f0fdfa 0%, #ccfbf1 100%); border-left: 5px solid #14b8a6;">
                                <i class="fa-solid fa-vial-virus position-absolute opacity-10" style="font-size: 7rem; right: 10px; top: -10px; color: #14b8a6;"></i>
                                <h6 class="fw-bold text-uppercase mb-3" style="letter-spacing: 0.5px; color: #0f766e; font-size: 11px;">
                                    <i class="fa-solid fa-microscope me-2"></i>Cận Lâm Sàng / Xét Nghiệm
                                </h6>
                                <div class="ms-1 position-relative z-1">
                                    <div class="row g-3">
                                        @foreach(var test in tests)
                                        {
                                            decimal testPrice = 0;
                                            string displayTestName = test.TestName;
                                            if (test.TestName == "CBC") { testPrice = 100000; displayTestName = "Công thức máu toàn phần (CBC)"; }
                                            else if (test.TestName == "SinhHoa") { testPrice = 200000; displayTestName = "Sinh hóa máu (Đường huyết, Ure, Creatinin)"; }
                                            else if (test.TestName == "SieuAm") { testPrice = 150000; displayTestName = "Siêu âm ổ bụng tổng quát"; }
                                            else if (test.TestName == "XQuang") { testPrice = 120000; displayTestName = "X-Quang ngực thẳng"; }
                                            else if (test.TestName == "NuocTieu") { testPrice = 50000; displayTestName = "Tổng phân tích nước tiểu"; }

                                            <div class="col-md-6">
                                                <div class="bg-white p-3.5 rounded-3 shadow-sm border h-100">
                                                    <div class="d-flex justify-content-between align-items-center mb-2" style="font-size: 13.5px;">
                                                        <span class="fw-bold text-dark">@displayTestName <span class="text-danger ms-2 small">@string.Format("{0:N0}đ", testPrice)</span></span>
                                                        @if(string.IsNullOrEmpty(test.Result)) {
                                                            <span class="badge bg-warning bg-opacity-25 text-dark px-2.5 py-1 rounded-pill border border-warning" style="font-size: 10px;"><i class="fa-regular fa-clock me-1"></i>Chờ KQ</span>
                                                        } else {
                                                            <span class="badge bg-success bg-opacity-25 text-success px-2.5 py-1 rounded-pill border border-success" style="font-size: 10px;"><i class="fa-solid fa-check me-1"></i>Đã có KQ</span>
                                                        }
                                                    </div>
                                                    @if(!string.IsNullOrEmpty(test.Result)) {
                                                        <div class="bg-light p-2 rounded small text-dark mt-2 border" style="font-size: 12px; font-weight: 500;">
                                                            <span class="text-muted"><i class="fa-solid fa-file-medical-alt me-1"></i>Kết quả:</span> <strong class="ms-1">@test.Result</strong>
                                                        </div>
                                                        @if(!string.IsNullOrEmpty(test.ImageUrl)) {
                                                            <div class="mt-2 text-center bg-dark rounded p-1 position-relative" style="cursor: pointer;" onclick="openDICOMViewer('@test.ImageUrl')">
                                                                <img src="@test.ImageUrl" class="img-fluid rounded" style="max-height: 130px; object-fit: contain; transition: transform 0.3s;" alt="Ảnh cận lâm sàng" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'" />
                                                                <div class="position-absolute top-50 start-50 translate-middle text-white" style="background: rgba(0,0,0,0.5); padding: 5px 10px; border-radius: 5px; opacity: 0; transition: opacity 0.3s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                                                                    <i class="fa-solid fa-magnifying-glass-plus"></i> Xem ảnh DICOM
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    <!-- Khối 5: Nhập viện (Nếu có) -->
                    @if (isAdmitted)
                    {
                        <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #f0fdf4 0%, #ecfdf5 100%); border-left: 5px solid #10b981;">
                            <i class="fa-solid fa-bed-pulse position-absolute" style="font-size: 7rem; right: 10px; top: -10px; color: #10b981; opacity: 0.05; z-index: 0; pointer-events: none;"></i>
                            <h6 class="fw-bold text-uppercase text-success mb-3 position-relative z-1" style="letter-spacing: 0.5px; font-size: 11px;">
                                <i class="fa-solid fa-hospital me-2"></i>Thông tin Lưu Trú Nội Trú
                            </h6>
                            <div class="row ms-1 position-relative z-1">
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <span class="text-muted small d-block" style="font-size: 11px; font-weight: 700;">KHOA / PHÒNG ĐIỀU TRỊ</span>
                                        <strong class="text-dark fs-6">@(Model.Department?.DepartmentName ?? "N/A")</strong>
                                    </div>
                                    <div>
                                        <span class="text-muted small d-block" style="font-size: 11px; font-weight: 700;">SỐ GIƯỜNG BỆNH</span>
                                        <span class="badge bg-success px-3 py-2 fs-6 rounded-pill" style="font-size: 13.5px !important; font-weight: 700;">Giường @Model.BedNumber</span>
                                    </div>
                                </div>
                                <div class="col-md-4 border-start border-success border-opacity-25 px-4">
                                    <div class="mb-3">
                                        <span class="text-muted small d-block" style="font-size: 11px; font-weight: 700;">THỜI GIAN NHẬP VIỆN</span>
                                        <strong class="text-dark"><i class="fa-solid fa-calendar-check text-success me-1"></i> @Model.AdmissionDate.Value.ToString("HH:mm - dd/MM/yyyy")</strong>
                                    </div>
                                    <div>
                                        <span class="text-muted small d-block" style="font-size: 11px; font-weight: 700;">THỜI GIAN XUẤT VIỆN</span>
                                        @if (Model.DischargeDate.HasValue)
                                        {
                                            <strong class="text-dark"><i class="fa-solid fa-calendar-xmark text-danger me-1"></i> @Model.DischargeDate.Value.ToString("HH:mm - dd/MM/yyyy")</strong>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-1 rounded-pill" style="font-size: 11px; font-weight: 700;"><i class="fa-solid fa-spinner fa-spin me-1"></i> Đang điều trị</span>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-4 border-start border-success border-opacity-25 px-4 text-md-end">
                                    <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Tạm tính tiền giường</div>
                                    <h4 class="fw-bold text-success mb-0">@string.Format("{0:N0} đ", roomFeeTotal)</h4>
                                    <div class="text-muted small mt-1 font-medium" style="font-size: 11.5px;">(@Model.RoomFee.ToString("N0") đ/ngày)</div>
                                    @if (!isCompleted) {
                                        <div class="mt-3">
                                            <button type="button" class="btn btn-sm btn-outline-success rounded-pill fw-bold px-3 shadow-sm bg-white" data-bs-toggle="modal" data-bs-target="#admissionModel">
                                                <i class="fa-solid fa-bed me-1"></i> Xem / Đổi Giường
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Khối 6: Lịch sử Lưu trú & Nhập viện -->
                    @if (!string.IsNullOrEmpty(Model.Notes) && (Model.Notes.Contains("[NHAPVIEN]") || Model.Notes.Contains("[XUATVIEN]")))
                    {
                        <div class="mt-4">
                            <h6 class="fw-bold text-uppercase text-secondary mb-3 d-flex align-items-center gap-2" style="letter-spacing: 0.5px; font-size: 12px; color: #475569 !important;">
                                <i class="fa-solid fa-clock-rotate-left text-primary"></i>Lịch sử lưu trú nội trú
                            </h6>
                            <div class="table-responsive rounded-3 border">
                                <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                                    <thead>
                                        <tr class="small text-muted text-uppercase" style="background: #f8fafc;">
                                            <th class="ps-4 py-2" style="width: 30%;">Thông tin lưu trú</th>
                                            <th class="py-2" style="width: 25%;">Thời gian nhập viện</th>
                                            <th class="py-2" style="width: 25%;">Thời gian xuất viện</th>
                                            <th class="text-end pe-4 py-2" style="width: 20%;">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var notes = Model.Notes ?? "";
                                            var lines = notes.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                            
                                            for (int i = 0; i < lines.Length; i++)
                                            {
                                                var line = lines[i];
                                                if (line.Contains("[NHAPVIEN]"))
                                                {
                                                    var admitTime = System.Text.RegularExpressions.Regex.Match(line, @"\((.+?)\)").Groups[1].Value;
                                                    string dischargeTime = "---";
                                                    string stayFee = "---";

                                                    if (i + 1 < lines.Length && lines[i+1].Contains("[XUATVIEN]"))
                                                    {
                                                        var nextLine = lines[i+1];
                                                        dischargeTime = System.Text.RegularExpressions.Regex.Match(nextLine, @"\((.+?)\)").Groups[1].Value;
                                                        var rawFee = nextLine.Split('-').LastOrDefault()?.Trim() ?? "---";
                                                        stayFee = System.Text.RegularExpressions.Regex.Replace(rawFee, @"\s*\([\d/:\s]+\)$", "").Trim();
                                                        i++;
                                                    }
                                                    else if (!Model.DischargeDate.HasValue && i == lines.Length - 1)
                                                    {
                                                        dischargeTime = "Đang điều trị";
                                                        stayFee = "Chưa chốt";
                                                    }

                                                    <tr style="border-bottom: 1px solid #f1f5f9;">
                                                        <td class="ps-4 py-2.5">
                                                            <div class="fw-bold"><i class="fa-solid fa-bed-pulse text-primary me-2"></i>Đợt nội trú</div>
                                                            <small class="text-muted ms-4">@(stayFee == "---" ? "Đang nằm viện" : "Đã thanh toán")</small>
                                                        </td>
                                                        <td class="fw-medium text-dark">@admitTime</td>
                                                        <td class="fw-medium text-dark">@dischargeTime</td>
                                                        <td class="text-end pe-4 fw-bold text-danger">@stayFee</td>
                                                    </tr>
                                                }
                                                else if (line.Contains("[XUATVIEN]") && (i == 0 || !lines[i-1].Contains("[NHAPVIEN]")))
                                                {
                                                    var outTime = System.Text.RegularExpressions.Regex.Match(line, @"\((.+?)\)").Groups[1].Value;
                                                    var rawFee = line.Split('-').LastOrDefault()?.Trim() ?? "---";
                                                    
                                                    // Thử tìm xem có thời gian nhập viện bị dư ở cuối không
                                                    var admitTimeMatch = System.Text.RegularExpressions.Regex.Match(rawFee, @"\(([\d/:\s]+)\)$");
                                                    var admitTime = admitTimeMatch.Success ? admitTimeMatch.Groups[1].Value : "---";
                                                    
                                                    // Loại bỏ phần thời gian bị dư ở cuối để lấy số tiền sạch
                                                    var fee = System.Text.RegularExpressions.Regex.Replace(rawFee, @"\s*\([\d/:\s]+\)$", "").Trim();
                                                    
                                                    <tr style="border-bottom: 1px solid #f1f5f9;">
                                                        <td class="ps-4 py-2.5">
                                                            <div class="fw-bold"><i class="fa-solid fa-clock-rotate-left text-secondary me-2"></i>Lịch sử cũ</div>
                                                            <small class="text-muted ms-4">Dữ liệu từ phiên bản trước</small>
                                                        </td>
                                                        <td class="text-dark fw-medium">@admitTime</td>
                                                        <td class="fw-medium text-dark">@outTime</td>
                                                        <td class="text-end pe-4 fw-bold text-danger">@fee</td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                <!-- Footer & Buttons -->
                <div class="px-4 py-3 border-top" style="background-color: #f8fafc;">
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        @if (!Model.IsLocked)
                        {
                            @if (!isCompleted)
                            {

                                <a href="@Url.Action("ChiDinhXetNghiem", "Doctor", new { id = Model.Id })" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #6c757d;">
                                    <i class="fa-solid fa-flask-vial"></i> Xét nghiệm
                                </a>
                                <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = Model.Id })" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #856404;">
                                    <i class="fa-solid fa-prescription-bottle-medical"></i> Kê thuốc
                                </a>                                @if (isAdmitted)
                                {
                                    <button type="button" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#admissionModel" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #2585da; border-color: #2585da;">
                                        <i class="fa-solid fa-bed-pulse"></i> Đổi giường
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#admissionModel" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #2585da; border-color: #2585da;">
                                        <i class="fa-solid fa-hospital"></i> Nhập viện
                                    </button>
                                }
                                <button type="button" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#taiKhamModal" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #fd7e14; border-color: #fd7e14;">
                                    <i class="fa-solid fa-calendar-check"></i> Hẹn tái khám
                                </button>
                                <!-- Lock & Sign button -->
                                <form action="@Url.Action("XacNhanHoSo", "Doctor")" method="post" class="m-0 ms-auto d-inline-block" onsubmit="return confirm('⚠️ Chú ý: Xác nhận hoàn thành sẽ KHÓA HỒ SƠ & KÝ SỐ ĐIỆN TỬ. Bạn sẽ không thể sửa đổi sau khi khóa. Bạn chắc chắn chứ?');">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn text-white fw-bold d-inline-flex align-items-center gap-2" style="border-radius: 8px; font-size: 13px; padding: 8px 16px; background-color: #0f3057; border-color: #0f3057;">
                                        <i class="fa-solid fa-file-signature"></i> Khóa &amp; Ký Số
                                    </button>
                                </form>
                            }
                            else
                            {
                                @if (Model.Appointment?.Status == 8)
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2.5 rounded-3" style="font-size: 12.5px;"><i class="fa-solid fa-clock-rotate-left me-1"></i> Hồ sơ bệnh án hẹn tái khám</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2.5 rounded-3" style="font-size: 12.5px;"><i class="fa-solid fa-check-double me-1"></i> Hồ sơ khám đã hoàn thành</span>
                                    <form action="@Url.Action("ChuyenTaiKham", "Doctor")" method="post" class="m-0 ms-auto d-inline-block">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn text-dark fw-bold d-inline-flex align-items-center gap-1.5" style="border-radius: 8px; font-size: 13px; padding: 8px 14px; background-color: #ffc107; border-color: #ffc107;">
                                            <i class="fa-solid fa-rotate-left"></i> Chuyển trạng thái Tái Khám
                                        </button>
                                    </form>
                                }
                                <button class="btn fw-bold d-inline-flex align-items-center gap-2 ms-auto" onclick="window.print()" style="border-radius: 8px; font-size: 13px; padding: 8px 15px; background-color: #f0f4ff; border: 1px solid #b8ccf8; color: #0056b3;">
                                    <i class="fa-solid fa-print"></i> In hồ sơ
                                </button>
                            }
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-between w-100 px-3 py-2.5 rounded-3" style="background-color: #d1e7dd; border: 1px solid #badbcc;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fa-solid fa-circle-check text-success fs-5"></i>
                                    <span class="fw-bold" style="font-size: 13.5px; color: #0f5132;">Hồ sơ bệnh án điện tử đã khóa và ký số lưu trữ an toàn</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <form action="@Url.Action("MoKhoa", "Doctor")" method="post" class="m-0 d-inline-block" onsubmit="return confirm('Bạn có chắc muốn MỞ KHÓA hồ sơ này không? Thao tác này sẽ cho phép chỉnh sửa lại.');">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn fw-bold d-inline-flex align-items-center gap-2" style="border-radius: 6px; font-size: 13px; padding: 6px 14px; background-color: #fff3cd; border: 1px solid #ffc107; color: #856404;">
                                            <i class="fa-solid fa-unlock"></i> Mở khóa
                                        </button>
                                    </form>
                                        <button class="btn fw-bold d-inline-flex align-items-center gap-2" onclick="window.print()" style="border-radius: 6px; font-size: 13px; padding: 6px 14px; background-color: #f0f4ff; border: 1px solid #b8ccf8; color: #0056b3;">
                                            <i class="fa-solid fa-print"></i> In hồ sơ
                                        </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Modal Nhập Viện -->
<div class="modal fade" id="admissionModel" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden; border: none; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <div class="modal-header bg-primary text-white p-4">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-bed me-2"></i>Chọn Khoa & Giường Bệnh Nằm Viện</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="NhapVienNoiTru" method="post" id="formNhapVien">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="bedNumber" id="selectedBedNumber" value="" />
                <div class="modal-body p-4 bg-light">
                    @if (!(ViewBag.Departments as List<HeThongBenhVien.Models.Department>)?.Any() ?? true)
                    {
                        <div class="alert alert-danger text-center shadow-sm">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> Hệ thống chưa có dữ liệu khoa phòng. Vui lòng liên hệ Admin để thêm mới khoa phòng trước khi nhập viện.
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-6 offset-md-3 text-center">
                                <label class="form-label fw-bold small text-uppercase text-muted mb-2">Bước 1: Chọn Khoa / Phòng nội trú</label>
                                <select name="departmentId" id="deptSelect" class="form-select form-select-lg text-center border-primary shadow-sm" required onchange="loadBeds(this.value)" style="border-radius: 12px;">
                                    <option value="">-- Click để chọn Khoa --</option>
                                    @foreach(var d in ViewBag.Departments as List<HeThongBenhVien.Models.Department>)
                                    {
                                        <option value="@d.Id">@d.DepartmentName (@(d.TotalBeds - d.OccupiedBeds) giường trống)</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div id="bedGridContainer" class="mt-4" style="display:none;">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-3 d-block text-center">Bước 2: Chọn vị trí giường bệnh (Giường trống màu trắng)</label>
                            <div class="bed-scroll-area p-4 bg-white rounded-4 border shadow-inner">
                                <div class="d-flex flex-wrap gap-3 justify-content-center" id="bedGrid">
                                    @for(int i = 1; i <= 50; i++)
                                    {
                                        <div class="bed-item" id="bed-@i" data-bed="@i" onclick="selectBed(@i)">
                                            <div class="bed-icon"><i class="fa-solid fa-bed"></i></div>
                                            <div class="bed-number">G-@i</div>
                                            <div class="bed-patient">Trống</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 text-center">
                            <div class="d-inline-flex gap-4 bg-white p-2 px-4 rounded-pill border shadow-sm">
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#fff; border:1px solid #e2e8f0;"></div> Giường trống</div>
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#fee2e2; border:1px solid #ef4444;"></div> Đã có bệnh</div>
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#0d6efd; border:1px solid #0044cc;"></div> Đang chọn</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-white border-0 px-4 py-3 shadow-top">
                    <button type="button" class="btn btn-outline-secondary px-4 fw-bold rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" id="btnSubmitAdmission" class="btn btn-primary px-5 fw-bold shadow-lg rounded-pill" disabled>
                        <i class="fa-solid fa-check-circle me-2"></i>Xác nhận Nhập viện
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Hẹn Tái Khám -->
<div class="modal fade" id="taiKhamModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden; border: none; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <div class="modal-header bg-warning text-dark p-4">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-calendar-plus me-2"></i>Tạo Lịch Hẹn Tái Khám</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="TaoTaiKham" asp-controller="Doctor" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />
                <div class="modal-body p-4 bg-light">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Ngày và Giờ Hẹn Tái Khám</label>
                        <input type="datetime-local" name="ngayTaiKham" class="form-control border-primary" required style="border-radius: 8px;" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:00")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Lý do / Ghi chú tái khám</label>
                        <textarea name="lyDoTaiKham" class="form-control" rows="3" placeholder="Ví dụ: Tái khám sau khi uống hết thuốc để kiểm tra lại chỉ số..." required style="border-radius: 8px;"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-white border-0 px-4 py-3 shadow-top">
                    <button type="button" class="btn btn-outline-secondary px-4 fw-bold rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-warning px-5 fw-bold text-dark shadow-lg rounded-pill">
                        <i class="fa-solid fa-circle-check me-2"></i>Xác nhận Hẹn Tái Khám
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal DICOM Viewer (Hệ thống phân tích hình ảnh Y tế) -->
<div class="modal fade" id="dicomViewerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0 border-bottom border-secondary bg-black text-white p-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-desktop-medical me-2 text-info"></i>Hệ Thống Phân Tích Hình Ảnh Cận Lâm Sàng</h5>
                
                <div class="d-flex align-items-center gap-3 ms-auto me-4">
                    <button class="btn btn-outline-light btn-sm" onclick="dicomZoom(0.1)" title="Phóng to"><i class="fa-solid fa-magnifying-glass-plus"></i></button>
                    <button class="btn btn-outline-light btn-sm" onclick="dicomZoom(-0.1)" title="Thu nhỏ"><i class="fa-solid fa-magnifying-glass-minus"></i></button>
                    <div class="vr bg-secondary mx-1"></div>
                    <button class="btn btn-outline-light btn-sm" onclick="dicomRotate()" title="Xoay 90 độ"><i class="fa-solid fa-rotate-right"></i></button>
                    <button class="btn btn-outline-warning btn-sm" onclick="dicomInvert()" title="Đảo màu âm bản (X-Quang)"><i class="fa-solid fa-circle-half-stroke"></i> Invert</button>
                    <div class="vr bg-secondary mx-1"></div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-sun text-light small"></i>
                        <input type="range" class="form-range" id="dicomBrightness" min="50" max="150" step="10" value="100" style="width: 100px;" oninput="applyDicomFilters()">
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-circle-half-stroke text-light small"></i>
                        <input type="range" class="form-range" id="dicomContrast" min="50" max="150" step="10" value="100" style="width: 100px;" oninput="applyDicomFilters()">
                    </div>
                    <button class="btn btn-danger btn-sm ms-2" onclick="resetDicom()" title="Khôi phục mặc định"><i class="fa-solid fa-rotate-left"></i></button>
                </div>

                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 position-relative overflow-hidden bg-black d-flex justify-content-center align-items-center" id="dicomContainer" style="height: calc(100vh - 70px);">
                <img id="dicomImage" src="" alt="Clinical Image" style="max-width: 100%; max-height: 100%; transition: transform 0.2s, filter 0.2s; cursor: grab;" draggable="false" />
            </div>
        </div>
    </div>
</div>

