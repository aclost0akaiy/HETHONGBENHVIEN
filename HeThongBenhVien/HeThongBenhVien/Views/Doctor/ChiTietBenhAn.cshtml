@model HeThongBenhVien.Models.MedicalRecord
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Chi tiết Bệnh án";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Hồ Sơ Bệnh Án</h2>
            <p class="text-success fw-bold mb-0"><i class="fa-solid fa-check-circle me-1"></i> Đã hoàn tất khám bệnh</p>
        </div>
        <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-outline-primary px-4 py-2" style="border-radius: 10px; font-weight: 500;">
            <i class="fa-solid fa-house me-2"></i> Trở về trang chủ
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card p-5 border-top border-5 border-success">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle me-3" style="font-size: 24px;">
                            <i class="fa-solid fa-file-medical"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-1">Phiếu Khám Chuyên Khoa</h4>
                            <p class="text-muted mb-0 small">Ngày khám: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold fs-5 text-dark">@Model.Appointment?.Patient?.FullName</div>
                        <div class="text-muted small">Mã BN: @Model.Appointment?.Patient?.PatientCode</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="bg-light p-3 rounded-3 h-100 border border-light">
                            <span class="text-muted small fw-bold text-uppercase d-block mb-2">Sinh hiệu</span>
                            <div class="text-dark">@Model.Vitals</div>
                            @{
                                var vitalSignsList = ViewBag.VitalSigns as List<HeThongBenhVien.Models.VitalSign>;
                                var latestVital = vitalSignsList?.FirstOrDefault();
                            }
                            @if (latestVital != null)
                            {
                                <div class="mt-2 pt-2 border-top border-light">
                                    <small class="text-muted"><i class="fa-solid fa-clock me-1"></i>Cập nhật lần cuối: @latestVital.RecordedAt.ToString("HH:mm dd/MM/yyyy") - ĐD: @latestVital.NurseName</small>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light p-3 rounded-3 h-100 border border-light">
                            <span class="text-muted small fw-bold text-uppercase d-block mb-2">Triệu chứng lâm sàng</span>
                            <div class="text-dark">@Model.Symptoms</div>
                        </div>
                    </div>
                </div>

                <div class="bg-primary bg-opacity-10 p-4 rounded-3 mb-4 border border-primary border-opacity-25">
                    <span class="text-primary small fw-bold text-uppercase d-block mb-2"><i class="fa-solid fa-stethoscope me-1"></i> Chẩn đoán bệnh</span>
                    <div class="text-dark fw-bold fs-5">@Model.Diagnosis</div>
                </div>

                <div class="bg-warning bg-opacity-10 p-4 rounded-3 mb-4 border border-warning border-opacity-25">
                    <span class="text-warning small fw-bold text-uppercase d-block mb-2"><i class="fa-solid fa-pills me-1"></i> Hướng điều trị / Đơn thuốc</span>
                    <div class="text-dark" style="white-space: pre-wrap;">@Model.TreatmentPlan</div>
                    
                    @if (ViewBag.Prescription != null && ViewBag.Prescription.PrescriptionDetails != null)
                    {
                        var details = ViewBag.Prescription.PrescriptionDetails as ICollection<HeThongBenhVien.Models.PrescriptionDetail>;
                        if (details != null && details.Count > 0)
                        {
                            <hr class="border-warning opacity-25">
                            <h6 class="fw-bold text-dark mt-3 mb-2"><i class="fa-solid fa-prescription-bottle-medical text-warning me-2"></i>Toa thuốc đã kê:</h6>
                            <ul class="list-group list-group-flush bg-transparent">
                            @foreach(var item in details)
                            {
                                <li class="list-group-item bg-transparent px-0 border-0 py-2" style="border-bottom: 1px dashed rgba(245, 158, 11, 0.25) !important;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="fw-semibold">@item.MedicineName</span> - 
                                            SL: <span class="text-primary fw-bold">@item.Quantity @item.Unit</span> 
                                            <span class="badge bg-light text-dark border ms-2">@string.Format("{0:N0} đ", item.Price) / @item.Unit</span>
                                            <br/><small class="text-muted"><i class="fa-solid fa-circle-info me-1"></i>Cách dùng: @item.DosageInstruction</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="fw-bold text-danger">@string.Format("{0:N0} đ", item.Price * item.Quantity)</span>
                                        </div>
                                    </div>
                                </li>
                            }
                            </ul>
                            <div class="mt-3 p-3 bg-white rounded border d-flex justify-content-between align-items-center shadow-sm">
                                <span class="fw-bold text-secondary text-uppercase"><i class="fa-solid fa-money-bill-wave text-success me-2"></i>Tổng tiền thuốc:</span>
                                <span class="fw-bold text-danger fs-5">@string.Format("{0:N0} VNĐ", details.Sum(d => d.Price * d.Quantity))</span>
                            </div>
                        }
                    }
                </div>

                @if (ViewBag.LabTests != null)
                {
                    var tests = ViewBag.LabTests as ICollection<HeThongBenhVien.Models.LabTest>;
                    if (tests != null && tests.Count > 0)
                    {
                        <div class="bg-info bg-opacity-10 p-4 rounded-3 mb-4 border border-info border-opacity-25">
                            <span class="text-info small fw-bold text-uppercase d-block mb-2"><i class="fa-solid fa-vial-circle-check me-1"></i> Cận Lâm Sàng / Xét Nghiệm</span>
                            <ul class="list-group list-group-flush bg-transparent">
                            @foreach(var test in tests)
                            {
                                <li class="list-group-item bg-transparent px-0 border-info border-opacity-25 py-2" style="border-bottom: 1px dashed rgba(13, 202, 240, 0.25);">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-semibold text-dark">@test.TestName</span>
                                        @if(string.IsNullOrEmpty(test.Result)) {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fa-regular fa-clock me-1"></i>Chờ kết quả</span>
                                        } else {
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check me-1"></i>Đã có KQ</span>
                                        }
                                    </div>
                                    @if(!string.IsNullOrEmpty(test.Result)) {
                                        <div class="mt-2 text-dark bg-white p-2 rounded border border-light">
                                            <strong>Kết quả:</strong> @test.Result
                                        </div>
                                    }
                                </li>
                            }
                            </ul>
                        </div>
                    }
                }

                @if(!string.IsNullOrEmpty(Model.Notes))
                {
                    string displayNotes = Model.Notes
                        .Replace("[KEDONTHUOC]", "✓ Đã chuyển sang Kê đơn thuốc")
                        .Replace("[XETNGHIEM_PENDING]", "⌛ Đang chờ kết quả Xét nghiệm")
                        .Replace("[XETNGHIEM_DONE]", "✓ Đã có kết quả Xét nghiệm")
                        .Replace("[PHAUTHUAT]", "✓ Đã chuyển sang Lịch Mổ / Phẫu thuật")
                        .Replace("[NHAPVIEN]", "✓ Đã Nhập viện nội trú");

                    <div class="bg-light p-4 rounded-3 border border-light">
                        <span class="text-muted small fw-bold text-uppercase d-block mb-2">Ghi chú & Lời dặn / Trạng thái xử lý</span>
                        <div class="text-dark fw-medium" style="white-space: pre-wrap;">@displayNotes</div>
                    </div>
                }

                <div class="text-end mt-5 pt-3 border-top d-flex justify-content-end gap-2 flex-wrap">
                    @if (Model.Appointment?.Status == 7)
                    {
                        <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = Model.Id })" class="btn btn-warning text-dark px-3 py-2 fw-bold">
                            <i class="fa-solid fa-pills me-1"></i> Kê đơn thuốc
                        </a>
                        <a href="@Url.Action("ChiDinhXetNghiem", "Doctor", new { id = Model.Id })" class="btn btn-info text-dark px-3 py-2 fw-bold">
                            <i class="fa-solid fa-vial me-1"></i> Xét nghiệm
                        </a>
                        <a href="@Url.Action("LichMo", "Doctor", new { id = Model.Id })" class="btn btn-danger px-3 py-2 fw-bold">
                            <i class="fa-solid fa-scalpel me-1"></i> Phẫu thuật
                        </a>
                        <a href="@Url.Action("QuanLyGiuong", "Doctor", new { id = Model.Id })" class="btn btn-secondary px-3 py-2 fw-bold">
                            <i class="fa-solid fa-bed me-1"></i> Nhập viện
                        </a>
                        <form action="@Url.Action("XacNhanHoSo", "Doctor")" method="post" class="m-0 ms-3">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success px-4 py-2 fw-bold">
                                <i class="fa-solid fa-check-double me-1"></i> Xác nhận
                            </button>
                        </form>
                    }
                    
                    <button class="btn btn-primary px-4 py-2 fw-bold ms-3" onclick="window.print()">
                        <i class="fa-solid fa-print me-1"></i> In Hồ Sơ
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
