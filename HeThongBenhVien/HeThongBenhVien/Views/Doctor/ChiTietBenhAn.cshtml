@section Scripts {
    <script>
        function loadBeds(deptId) {
            if (!deptId) {
                $('#bedGridContainer').hide();
                return;
            }

            // Reset beds state
            $('.bed-item').removeClass('occupied selected').css('pointer-events', 'auto');
            $('.bed-patient').text('Trống');
            $('#selectedBedNumber').val('');
            $('#btnSubmitAdmission').prop('disabled', true);

            // Load occupied beds from server
            $.get('/Doctor/GetOccupiedBeds', { departmentId: deptId }, function(data) {
                data.forEach(function(item) {
                    let bed = $('#bed-' + item.bedNumber);
                    bed.addClass('occupied').css('pointer-events', 'none');
                    bed.find('.bed-patient').text(item.patientName);
                });
                $('#bedGridContainer').show();
            });
        }

        function selectBed(num) {
            let bed = $('#bed-' + num);
            if (bed.hasClass('occupied')) return;

            $('.bed-item').removeClass('selected');
            bed.addClass('selected');
            $('#selectedBedNumber').val(num);
            $('#btnSubmitAdmission').prop('disabled', false);
        }

        // ===== LƯU TRỮ TRẠNG THÁI VIEWER =====
        let dicomState = {
            scale: 1,
            rotate: 0,
            invert: false,
            brightness: 100,
            contrast: 100,
            panX: 0,
            panY: 0,
            isDragging: false,
            startX: 0,
            startY: 0
        };

        function openDICOMViewer(url) {
            $('#dicomImage').attr('src', url);
            resetDicom();
            var myModal = new bootstrap.Modal(document.getElementById('dicomViewerModal'));
            myModal.show();
        }

        function applyDicomFilters() {
            let img = document.getElementById('dicomImage');
            
            // Transform (Zoom, Rotate, Pan)
            img.style.transform = `translate(${dicomState.panX}px, ${dicomState.panY}px) scale(${dicomState.scale}) rotate(${dicomState.rotate}deg)`;
            
            // Filter (Invert, Brightness, Contrast)
            let invertVal = dicomState.invert ? '100%' : '0%';
            let brightVal = $('#dicomBrightness').val() + '%';
            let contVal = $('#dicomContrast').val() + '%';
            img.style.filter = `invert(${invertVal}) brightness(${brightVal}) contrast(${contVal})`;
        }

        function dicomZoom(delta) {
            dicomState.scale += delta;
            if (dicomState.scale < 0.1) dicomState.scale = 0.1;
            applyDicomFilters();
        }

        function dicomRotate() {
            dicomState.rotate += 90;
            applyDicomFilters();
        }

        function dicomInvert() {
            dicomState.invert = !dicomState.invert;
            applyDicomFilters();
        }

        function resetDicom() {
            dicomState = { scale: 1, rotate: 0, invert: false, brightness: 100, contrast: 100, panX: 0, panY: 0, isDragging: false, startX: 0, startY: 0 };
            $('#dicomBrightness').val(100);
            $('#dicomContrast').val(100);
            applyDicomFilters();
        }

        // Kéo thả hình ảnh (Panning)
        const dicomImg = document.getElementById('dicomImage');
        dicomImg.addEventListener('mousedown', (e) => {
            dicomState.isDragging = true;
            dicomState.startX = e.clientX - dicomState.panX;
            dicomState.startY = e.clientY - dicomState.panY;
            dicomImg.style.cursor = 'grabbing';
        });

        window.addEventListener('mousemove', (e) => {
            if (!dicomState.isDragging) return;
            dicomState.panX = e.clientX - dicomState.startX;
            dicomState.panY = e.clientY - dicomState.startY;
            applyDicomFilters();
        });

        window.addEventListener('mouseup', () => {
            dicomState.isDragging = false;
            dicomImg.style.cursor = 'grab';
        });

        // Hỗ trợ Zoom bằng con lăn chuột
        document.getElementById('dicomContainer').addEventListener('wheel', (e) => {
            e.preventDefault();
            if (e.deltaY < 0) dicomZoom(0.1);
            else dicomZoom(-0.1);
        });
    </script>
}
