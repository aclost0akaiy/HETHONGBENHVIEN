@model HeThongBenhVien.Models.MedicalRecord
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Chi tiết Bệnh án";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Hồ Sơ Bệnh Án</h2>
            <p class="text-success fw-bold mb-0"><i class="fa-solid fa-check-circle me-1"></i> Đã hoàn tất khám bệnh</p>
        </div>
        <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-outline-primary px-4 py-2" style="border-radius: 10px; font-weight: 500;">
            <i class="fa-solid fa-house me-2"></i> Trở về trang chủ
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card p-5 border-top border-5 border-success">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle me-3" style="font-size: 24px;">
                            <i class="fa-solid fa-file-medical"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-1">Phiếu Khám Chuyên Khoa</h4>
                            <p class="text-muted mb-0 small">Ngày khám: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold fs-5 text-dark">@Model.Appointment?.Patient?.FullName</div>
                        <div class="text-muted small">Mã BN: @Model.Appointment?.Patient?.PatientCode</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="bg-light p-3 rounded-3 h-100 border border-light">
                            <span class="text-muted small fw-bold text-uppercase d-block mb-2">Sinh hiệu</span>
                            <div class="text-dark">@Model.Vitals</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light p-3 rounded-3 h-100 border border-light">
                            <span class="text-muted small fw-bold text-uppercase d-block mb-2">Triệu chứng lâm sàng</span>
                            <div class="text-dark">@Model.Symptoms</div>
                        </div>
                    </div>
                </div>

                <div class="bg-primary bg-opacity-10 p-4 rounded-3 mb-4 border border-primary border-opacity-25">
                    <span class="text-primary small fw-bold text-uppercase d-block mb-2"><i class="fa-solid fa-stethoscope me-1"></i> Chẩn đoán bệnh</span>
                    <div class="text-dark fw-bold fs-5">@Model.Diagnosis</div>
                </div>

                <div class="bg-warning bg-opacity-10 p-4 rounded-3 mb-4 border border-warning border-opacity-25">
                    <span class="text-warning small fw-bold text-uppercase d-block mb-2"><i class="fa-solid fa-pills me-1"></i> Hướng điều trị / Đơn thuốc</span>
                    <div class="text-dark" style="white-space: pre-wrap;">@Model.TreatmentPlan</div>
                </div>

                @if(!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="bg-light p-4 rounded-3 border border-light">
                        <span class="text-muted small fw-bold text-uppercase d-block mb-2">Ghi chú & Lời dặn</span>
                        <div class="text-dark fst-italic">@Model.Notes</div>
                    </div>
                }

                <div class="text-end mt-5 pt-3 border-top">
                    <button class="btn btn-primary px-4 py-2" onclick="window.print()">
                        <i class="fa-solid fa-print me-2"></i> In Hồ Sơ
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
