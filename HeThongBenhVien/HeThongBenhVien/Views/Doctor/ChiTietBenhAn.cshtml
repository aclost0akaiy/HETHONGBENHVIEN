@model HeThongBenhVien.Models.MedicalRecord
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Chi tiết Bệnh án";

    // Trạng thái hồ sơ
    bool isCompleted = Model.Appointment?.Status == 5;
    // Bệnh nhân đang ở trong bệnh viện (đã nhập viện và chưa xuất viện)
    bool isAdmitted = Model.AdmissionDate.HasValue && !Model.DischargeDate.HasValue;

    // Tính toán viện phí
    decimal examFee = 150000;
    decimal prescriptionFee = 0;
    var details = ViewBag.Prescription?.PrescriptionDetails as ICollection<HeThongBenhVien.Models.PrescriptionDetail>;
    if (details != null) { prescriptionFee = details.Sum(d => d.Price * d.Quantity); }
    decimal surgeryFee = ViewBag.SurgeryFee?.Price ?? 0;
    
    decimal roomFeeTotal = 0;
    // 1. Tính tiền phòng cho đợt đang nằm viện (nếu có)
    if (Model.AdmissionDate.HasValue && !Model.DischargeDate.HasValue)
    {
        var days = Math.Ceiling((DateTime.Now - Model.AdmissionDate.Value).TotalDays);
        if (days < 1) days = 1;
        roomFeeTotal = Model.RoomFee * (decimal)days;
    }
    
    // 2. Cộng dồn tiền phòng từ các đợt đã xuất viện (nếu có trong Notes)
    if (!string.IsNullOrEmpty(Model.Notes))
    {
        var regex = new System.Text.RegularExpressions.Regex(@"Tiền phòng: ([\d.,]+) VNĐ");
        var matches = regex.Matches(Model.Notes);
        foreach (System.Text.RegularExpressions.Match match in matches)
        {
            string feeString = match.Groups[1].Value.Replace(".", "").Replace(",", "");
            if (decimal.TryParse(feeString, out decimal pastFee))
            {
                roomFeeTotal += pastFee;
            }
        }
    }
    
    decimal totalBill = examFee + prescriptionFee + surgeryFee + roomFeeTotal;
}

<div class="container-fluid p-0 pb-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 800; color: #1e293b;">
                <i class="fa-solid fa-laptop-medical text-primary me-2"></i>Hồ Sơ Bệnh Án Điện Tử
            </h2>
            @if (Model.IsLocked)
            {
                <div class="mt-2">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill"><i class="fa-solid fa-lock me-1"></i> Hồ sơ đã được khóa lưu trữ</span>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill ms-2" title="Chữ ký số có giá trị pháp lý"><i class="fa-solid fa-file-signature me-1"></i> Đã ký số bởi: @Model.DigitalSignature</span>
                </div>
            }
            else if (isCompleted)
            {
                <p class="text-success fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-check-double me-1"></i> Xác nhận thành công</p>
            }
            else
            {
                <p class="text-warning fw-bold mb-0" style="font-size: 1.1rem;"><i class="fa-solid fa-hourglass-half me-1"></i> Đang chờ xác nhận</p>
            }
        </div>
        <a href="@Url.Action("HoSoBenhAn", "Doctor")" class="btn btn-outline-primary px-4 py-2 fw-bold" style="border-radius: 10px; transition: all 0.3s ease;">
            <i class="fa-solid fa-arrow-left me-2"></i> Trở về danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="glass-card shadow-lg rounded-4 overflow-hidden border-0" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                
                <!-- Bệnh nhân Header -->
                <div class="p-4" style="background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%); color: white;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-white text-primary p-3 rounded-circle me-4 shadow d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; font-size: 30px;">
                                <i class="fa-solid fa-user-injured"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-1">@Model.Appointment?.Patient?.FullName</h3>
                                <p class="mb-0 opacity-75 fw-medium">Mã BN: @Model.Appointment?.Patient?.PatientCode &nbsp;|&nbsp; @Model.Appointment?.Patient?.Gender &nbsp;|&nbsp; @Model.Appointment?.Patient?.Age Tuổi</p>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="badge bg-white text-primary px-3 py-2 fs-6 rounded-pill shadow-sm mb-2">
                                Khám Chuyên Khoa
                            </div>
                            <div class="opacity-75 small"><i class="fa-solid fa-calendar-check me-1"></i> Ngày khám: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <!-- Main Content Body -->
                <div class="p-5 bg-white">
                    
                    <!-- Khối 1: Sinh hiệu & Triệu chứng -->
                    <div class="row g-4 mb-5">
                        <div class="col-md-5">
                            <div class="h-100 p-4 rounded-4" style="background: linear-gradient(145deg, #f8fafc, #f1f5f9); border: 1px solid #e2e8f0;">
                                <h6 class="fw-bold text-uppercase text-secondary mb-3" style="letter-spacing: 0.5px;">
                                    <i class="fa-solid fa-heart-pulse text-danger me-2"></i>Sinh hiệu mới nhất
                                </h6>
                                @{
                                    var vitalSignsList = ViewBag.VitalSigns as List<HeThongBenhVien.Models.VitalSign>;
                                    var latestVital = vitalSignsList?.FirstOrDefault();
                                }
                                @if (latestVital != null)
                                {
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <div class="p-2 bg-white rounded shadow-sm border border-light">
                                                <span class="text-muted small d-block">Mạch</span>
                                                <strong class="fs-5 text-dark">@latestVital.Pulse</strong> <small>bpm</small>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="p-2 bg-white rounded shadow-sm border border-light">
                                                <span class="text-muted small d-block">Nhiệt độ</span>
                                                <strong class="fs-5 text-dark">@latestVital.Temperature</strong> <small>°C</small>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="p-2 bg-white rounded shadow-sm border border-light">
                                                <span class="text-muted small d-block">Huyết áp</span>
                                                <strong class="fs-5 text-dark">@latestVital.BloodPressure</strong> <small>mmHg</small>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="p-2 bg-white rounded shadow-sm border border-light">
                                                <span class="text-muted small d-block">SpO2</span>
                                                <strong class="fs-5 text-dark">@latestVital.SpO2</strong> <small>%</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-3 pt-3 border-top text-muted small">
                                        <i class="fa-solid fa-clock me-1"></i>Cập nhật: @latestVital.RecordedAt.ToString("HH:mm") - ĐD: @latestVital.NurseName
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-4 text-muted">
                                        <i class="fa-solid fa-heart-circle-xmark fs-2 mb-2 opacity-50"></i>
                                        <p class="mb-0 italic">Chưa có thông tin sinh hiệu ghi nhận.</p>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="h-100 p-4 rounded-4 shadow-sm" style="background: white; border: 1px solid #e2e8f0;">
                                <h6 class="fw-bold text-uppercase text-secondary mb-3" style="letter-spacing: 0.5px;">
                                    <i class="fa-solid fa-clipboard-list text-primary me-2"></i>Triệu chứng lâm sàng
                                </h6>
                                <p class="text-dark fs-5" style="line-height: 1.6; white-space: pre-wrap;">@Model.Symptoms</p>
                            </div>
                        </div>
                    </div>

                    <!-- Khối 2: Chẩn đoán -->
                    <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #e0f2fe 0%, #f0f9ff 100%); border-left: 5px solid #0ea5e9;">
                        <i class="fa-solid fa-stethoscope position-absolute opacity-10" style="font-size: 8rem; right: -20px; top: -20px; color: #0ea5e9;"></i>
                        <h6 class="fw-bold text-uppercase text-primary mb-2" style="letter-spacing: 0.5px;">
                            <i class="fa-solid fa-user-doctor me-2"></i>Chẩn đoán bệnh
                        </h6>
                        <h4 class="fw-bold text-dark mb-0 ms-4" style="line-height: 1.5;">@Model.Diagnosis</h4>
                    </div>

                    <!-- Khối 3: Hướng điều trị & Đơn thuốc -->
                    <div class="p-4 rounded-4 mb-4 shadow-sm" style="background: #fffdf5; border: 1px solid #fef08a; border-left: 5px solid #eab308;">
                        <h6 class="fw-bold text-uppercase text-warning mb-3" style="letter-spacing: 0.5px;">
                            <i class="fa-solid fa-pills me-2"></i>Hướng điều trị / Đơn thuốc
                        </h6>
                        <div class="text-dark fw-medium ms-4 mb-4" style="white-space: pre-wrap; font-size: 1.1rem;">@Model.TreatmentPlan</div>
                        
                        @if (ViewBag.Prescription != null && ViewBag.Prescription.PrescriptionDetails != null)
                        {
                            var detailsList = ViewBag.Prescription.PrescriptionDetails as ICollection<HeThongBenhVien.Models.PrescriptionDetail>;
                            if (detailsList != null && detailsList.Count > 0)
                            {
                                <div class="bg-white p-4 rounded-3 shadow-sm border border-warning border-opacity-25 mt-3">
                                    <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-prescription-bottle-medical text-warning me-2"></i>Chi tiết toa thuốc:</h6>
                                    <div class="table-responsive">
                                        <table class="table table-borderless table-hover align-middle mb-0">
                                            <thead class="bg-light text-muted small text-uppercase">
                                                <tr>
                                                    <th class="rounded-start">Tên thuốc</th>
                                                    <th>Số lượng</th>
                                                    <th>Cách dùng</th>
                                                    <th class="text-end rounded-end">Thành tiền</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach(var item in detailsList)
                                                {
                                                    <tr style="border-bottom: 1px dashed #e2e8f0;">
                                                        <td class="fw-bold text-dark py-3">@item.MedicineName</td>
                                                        <td><span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1 fs-6">@item.Quantity @item.Unit</span></td>
                                                        <td class="text-muted small"><i class="fa-solid fa-info-circle me-1"></i>@item.DosageInstruction</td>
                                                        <td class="text-end fw-bold text-danger">@string.Format("{0:N0} đ", item.Price * item.Quantity)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="text-end mt-3 pt-3 border-top">
                                        <span class="fw-bold text-secondary text-uppercase me-3">Tổng tiền thuốc:</span>
                                        <span class="fw-bold text-danger fs-4">@string.Format("{0:N0} đ", prescriptionFee)</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Khối 4: Phẫu thuật (Nếu có) -->
                    @if (ViewBag.SurgeryFee != null)
                    {
                        <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #fef2f2 0%, #fff1f2 100%); border-left: 5px solid #ef4444;">
                            <i class="fa-solid fa-scalpel position-absolute opacity-10" style="font-size: 8rem; right: 10px; top: -10px; color: #ef4444;"></i>
                            <h6 class="fw-bold text-uppercase text-danger mb-3" style="letter-spacing: 0.5px;">
                                <i class="fa-solid fa-scissors me-2"></i>Phẫu thuật / Thủ thuật
                            </h6>
                            <div class="row align-items-center ms-2">
                                <div class="col-md-8">
                                    <h4 class="fw-bold text-dark mb-1">@ViewBag.SurgeryFee.FeeName</h4>
                                    <p class="text-muted mb-0"><i class="fa-solid fa-user-doctor me-1"></i> Phẫu thuật viên: <strong class="text-dark">@(ViewBag.Surgeon != null ? ViewBag.Surgeon.FullName : "Chưa phân công")</strong></p>
                                </div>
                                <div class="col-md-4 text-end">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Chi phí phẫu thuật</div>
                                    <h3 class="fw-bold text-danger mb-0">@string.Format("{0:N0} đ", ViewBag.SurgeryFee.Price)</h3>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Khối Cận Lâm Sàng / Xét Nghiệm -->
                    @if (ViewBag.LabTests != null)
                    {
                        var tests = ViewBag.LabTests as ICollection<HeThongBenhVien.Models.LabTest>;
                        if (tests != null && tests.Count > 0)
                        {
                            <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #f0fdfa 0%, #ccfbf1 100%); border-left: 5px solid #14b8a6;">
                                <i class="fa-solid fa-vial-virus position-absolute opacity-10" style="font-size: 8rem; right: 10px; top: -10px; color: #14b8a6;"></i>
                                <h6 class="fw-bold text-uppercase text-teal mb-3" style="letter-spacing: 0.5px; color: #0f766e;">
                                    <i class="fa-solid fa-microscope me-2"></i>Cận Lâm Sàng / Xét Nghiệm
                                </h6>
                                <div class="ms-2 position-relative z-1">
                                    <div class="row g-3">
                                        @foreach(var test in tests)
                                        {
                                            <div class="col-md-6">
                                                <div class="bg-white p-3 rounded-3 shadow-sm border h-100">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <span class="fw-bold text-dark fs-6">@test.TestName</span>
                                                        @if(string.IsNullOrEmpty(test.Result)) {
                                                            <span class="badge bg-warning bg-opacity-25 text-dark px-3 py-1 rounded-pill border border-warning"><i class="fa-regular fa-clock me-1"></i>Chờ KQ</span>
                                                        } else {
                                                            <span class="badge bg-success bg-opacity-25 text-success px-3 py-1 rounded-pill border border-success"><i class="fa-solid fa-check me-1"></i>Đã có KQ</span>
                                                        }
                                                    </div>
                                                    @if(!string.IsNullOrEmpty(test.Result)) {
                                                        <div class="bg-light p-2 rounded small text-dark mt-2 border">
                                                            <span class="text-muted"><i class="fa-solid fa-file-medical-alt me-1"></i>Kết quả:</span> <strong class="ms-1">@test.Result</strong>
                                                        </div>
                                                        @if(!string.IsNullOrEmpty(test.ImageUrl)) {
                                                            <div class="mt-2 text-center bg-dark rounded p-1">
                                                                <a href="@test.ImageUrl" target="_blank" title="Nhấn để xem toàn màn hình">
                                                                    <img src="@test.ImageUrl" class="img-fluid rounded" style="max-height: 150px; object-fit: contain;" alt="Ảnh cận lâm sàng" />
                                                                </a>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    <!-- Khối 5: Nhập viện (Nếu có) -->
                    @if (isAdmitted)
                    {
                        <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(120deg, #f0fdf4 0%, #ecfdf5 100%); border-left: 5px solid #10b981;">
                            <i class="fa-solid fa-bed-pulse position-absolute" style="font-size: 8rem; right: 10px; top: -10px; color: #10b981; opacity: 0.05; z-index: 0; pointer-events: none;"></i>
                            <h6 class="fw-bold text-uppercase text-success mb-3 position-relative z-1" style="letter-spacing: 0.5px;">
                                <i class="fa-solid fa-hospital me-2"></i>Thông tin Lưu Trú Nội Trú
                            </h6>
                            <div class="row ms-2 position-relative z-1">
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <span class="text-muted small d-block">Khoa / Phòng điều trị</span>
                                        <strong class="text-dark fs-5">@(Model.Department?.DepartmentName ?? "N/A")</strong>
                                    </div>
                                    <div>
                                        <span class="text-muted small d-block">Số giường bệnh</span>
                                        <span class="badge bg-success px-3 py-2 fs-6 rounded-pill">Giường @Model.BedNumber</span>
                                    </div>
                                </div>
                                <div class="col-md-4 border-start border-success border-opacity-25 px-4">
                                    <div class="mb-3">
                                        <span class="text-muted small d-block">Thời gian nhập viện</span>
                                        <strong class="text-dark"><i class="fa-solid fa-calendar-check text-success me-1"></i> @Model.AdmissionDate.Value.ToString("HH:mm - dd/MM/yyyy")</strong>
                                    </div>
                                    <div>
                                        <span class="text-muted small d-block">Thời gian xuất viện</span>
                                        @if (Model.DischargeDate.HasValue)
                                        {
                                            <strong class="text-dark"><i class="fa-solid fa-calendar-xmark text-danger me-1"></i> @Model.DischargeDate.Value.ToString("HH:mm - dd/MM/yyyy")</strong>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-1 rounded-pill"><i class="fa-solid fa-spinner fa-spin me-1"></i> Đang điều trị</span>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-4 border-start border-success border-opacity-25 px-4 text-end">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Tạm tính tiền giường</div>
                                    <h3 class="fw-bold text-success mb-0">@string.Format("{0:N0} đ", roomFeeTotal)</h3>
                                    <div class="text-muted small mt-1">(@Model.RoomFee.ToString("N0") đ/ngày)</div>
                                    @if (!isCompleted) {
                                        <div class="mt-3">
                                            <button type="button" class="btn btn-sm btn-outline-success rounded-pill fw-bold px-3 shadow-sm bg-white" data-bs-toggle="modal" data-bs-target="#admissionModel">
                                                <i class="fa-solid fa-bed me-1"></i> Xem / Đổi Giường
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Khối 6: Lịch sử Lưu trú & Nhập viện -->
                    @if (!string.IsNullOrEmpty(Model.Notes) && (Model.Notes.Contains("[NHAPVIEN]") || Model.Notes.Contains("[XUATVIEN]")))
                    {
                        <div class="mt-5">
                            <h6 class="fw-bold text-uppercase text-secondary mb-3" style="letter-spacing: 0.5px;">
                                <i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Lịch sử lưu trú nội trú
                            </h6>
                            <div class="table-responsive rounded-3 border">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr class="small text-muted text-uppercase" style="background: #f8fafc;">
                                            <th class="ps-4" style="width: 30%;">Thông tin lưu trú</th>
                                            <th style="width: 25%;">Thời gian nhập viện</th>
                                            <th style="width: 25%;">Thời gian xuất viện</th>
                                            <th class="text-end pe-4" style="width: 20%;">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var notes = Model.Notes ?? "";
                                            var lines = notes.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                            
                                            for (int i = 0; i < lines.Length; i++)
                                            {
                                                var line = lines[i];
                                                if (line.Contains("[NHAPVIEN]"))
                                                {
                                                    var admitTime = System.Text.RegularExpressions.Regex.Match(line, @"\((.+?)\)").Groups[1].Value;
                                                    string dischargeTime = "---";
                                                    string stayFee = "---";

                                                    if (i + 1 < lines.Length && lines[i+1].Contains("[XUATVIEN]"))
                                                    {
                                                        var nextLine = lines[i+1];
                                                        dischargeTime = System.Text.RegularExpressions.Regex.Match(nextLine, @"\((.+?)\)").Groups[1].Value;
                                                        var rawFee = nextLine.Split('-').LastOrDefault()?.Trim() ?? "---";
                                                        stayFee = System.Text.RegularExpressions.Regex.Replace(rawFee, @"\s*\([\d/:\s]+\)$", "").Trim();
                                                        i++;
                                                    }
                                                    else if (!Model.DischargeDate.HasValue && i == lines.Length - 1)
                                                    {
                                                        dischargeTime = "Đang điều trị";
                                                        stayFee = "Chưa chốt";
                                                    }

                                                    <tr>
                                                        <td class="ps-4">
                                                            <div class="fw-bold"><i class="fa-solid fa-bed-pulse text-primary me-2"></i>Đợt nội trú</div>
                                                            <small class="text-muted ms-4">@(stayFee == "---" ? "Đang nằm viện" : "Đã thanh toán")</small>
                                                        </td>
                                                        <td class="fw-medium text-dark">@admitTime</td>
                                                        <td class="fw-medium text-dark">@dischargeTime</td>
                                                        <td class="text-end pe-4 fw-bold text-danger">@stayFee</td>
                                                    </tr>
                                                }
                                                else if (line.Contains("[XUATVIEN]") && (i == 0 || !lines[i-1].Contains("[NHAPVIEN]")))
                                                {
                                                    var outTime = System.Text.RegularExpressions.Regex.Match(line, @"\((.+?)\)").Groups[1].Value;
                                                    var rawFee = line.Split('-').LastOrDefault()?.Trim() ?? "---";
                                                    
                                                    // Thử tìm xem có thời gian nhập viện bị dư ở cuối không (do lỗi version cũ)
                                                    var admitTimeMatch = System.Text.RegularExpressions.Regex.Match(rawFee, @"\(([\d/:\s]+)\)$");
                                                    var admitTime = admitTimeMatch.Success ? admitTimeMatch.Groups[1].Value : "---";
                                                    
                                                    // Loại bỏ phần thời gian bị dư ở cuối để lấy số tiền sạch
                                                    var fee = System.Text.RegularExpressions.Regex.Replace(rawFee, @"\s*\([\d/:\s]+\)$", "").Trim();
                                                    
                                                    <tr>
                                                        <td class="ps-4">
                                                            <div class="fw-bold"><i class="fa-solid fa-clock-rotate-left text-secondary me-2"></i>Lịch sử cũ</div>
                                                            <small class="text-muted ms-4">Dữ liệu từ phiên bản trước</small>
                                                        </td>
                                                        <td class="text-dark fw-medium">@admitTime</td>
                                                        <td class="fw-medium text-dark">@outTime</td>
                                                        <td class="text-end pe-4 fw-bold text-danger">@fee</td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                <!-- Footer & Buttons -->
                <div class="p-4 bg-light border-top">
                    <!-- Thanh Tổng Doanh Thu / Viện Phí -->
                    <div class="mb-4 bg-dark text-white p-4 rounded-4 shadow" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border: 1px solid #334155;">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <h5 class="mb-1 fw-bold text-uppercase text-warning" style="letter-spacing: 1px;"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Tổng Viện Phí Bệnh Nhân</h5>
                                <div class="d-flex gap-3 small opacity-75 mt-2">
                                    <span>Khám: <strong>@string.Format("{0:N0}đ", examFee)</strong></span>
                                    <span>Thuốc: <strong>@string.Format("{0:N0}đ", prescriptionFee)</strong></span>
                                    <span>Mổ: <strong>@string.Format("{0:N0}đ", surgeryFee)</strong></span>
                                    <span>Giường: <strong>@string.Format("{0:N0}đ", roomFeeTotal)</strong></span>
                                </div>
                            </div>
                            <div class="col-md-6 text-end">
                                <h1 class="mb-0 fw-bold text-warning display-5" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);">@string.Format("{0:N0} VNĐ", totalBill)</h1>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                        @if (!Model.IsLocked)
                        {
                            @if (!isCompleted)
                            {
                                <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = Model.Id })" class="btn btn-warning text-dark px-4 py-2 fw-bold rounded-pill shadow-sm btn-hover">
                                    <i class="fa-solid fa-pills me-1"></i> Kê thuốc
                                </a>
                                <a href="@Url.Action("SinhHieu", "Doctor", new { id = Model.Appointment?.Id })" class="btn btn-primary px-4 py-2 fw-bold text-white rounded-pill shadow-sm btn-hover">
                                    <i class="fa-solid fa-heart-pulse me-1"></i> Sinh hiệu
                                </a>
                                <a href="@Url.Action("LichMo", "Doctor", new { id = Model.Id })" class="btn btn-danger px-4 py-2 fw-bold rounded-pill shadow-sm btn-hover">
                                    <i class="fa-solid fa-scalpel me-1"></i> Phẫu thuật
                                </a>
                                <a href="@Url.Action("ChiDinhXetNghiem", "Doctor", new { id = Model.Id })" class="btn text-white px-4 py-2 fw-bold rounded-pill shadow-sm btn-hover" style="background-color: #14b8a6;">
                                    <i class="fa-solid fa-vial me-1"></i> Xét nghiệm
                                </a>
                                @if (isAdmitted)
                                {
                                    <button type="button" class="btn text-white px-4 py-2 fw-bold rounded-pill shadow-sm btn-hover" data-bs-toggle="modal" data-bs-target="#admissionModel" style="background-color: #0ea5e9;">
                                        <i class="fa-solid fa-bed-pulse me-1"></i> Đổi giường
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-info text-white px-4 py-2 fw-bold rounded-pill shadow-sm btn-hover" data-bs-toggle="modal" data-bs-target="#admissionModel">
                                        <i class="fa-solid fa-bed me-1"></i> Nhập viện
                                    </button>
                                }
                                
                                <form action="@Url.Action("XacNhanHoSo", "Doctor")" method="post" class="m-0 ms-3 border-start ps-3 border-secondary" onsubmit="return confirm('⚠️ Chú ý: Xác nhận hoàn thành sẽ KHÓA HỒ SƠ & KÝ SỐ ĐIỆN TỬ. Bạn sẽ không thể sửa đổi sau khi khóa. Bạn chắc chắn chứ?');">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success px-5 py-2 fw-bold text-white rounded-pill shadow" style="transform: scale(1.05);">
                                        <i class="fa-solid fa-file-signature me-2"></i> Khóa & Ký Số Hồ Sơ
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form action="@Url.Action("ChuyenTaiKham", "Doctor")" method="post" class="m-0 ms-3 border-start ps-3 border-secondary">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-warning px-5 py-2 fw-bold text-dark rounded-pill shadow" style="transform: scale(1.05);">
                                        <i class="fa-solid fa-rotate-left me-2"></i> Chuyển trạng thái Tái Khám
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success m-0 me-3 py-2 px-4 rounded-pill border-0 shadow-sm d-flex align-items-center">
                                <i class="fa-solid fa-shield-check text-success fs-5 me-2"></i>
                                <span class="fw-bold text-success">Hồ sơ đã được lưu trữ an toàn</span>
                            </div>
                        }
                        
                        <button class="btn btn-outline-secondary px-4 py-2 fw-bold ms-3 rounded-pill" onclick="window.print()">
                            <i class="fa-solid fa-print me-1"></i> In
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Modal Nhập Viện -->
<div class="modal fade" id="admissionModel" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden; border: none; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <div class="modal-header bg-primary text-white p-4">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-bed me-2"></i>Chọn Khoa & Giường Bệnh Nằm Viện</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="NhapVienNoiTru" method="post" id="formNhapVien">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="bedNumber" id="selectedBedNumber" value="" />
                <div class="modal-body p-4 bg-light">
                    @if (!(ViewBag.Departments as List<HeThongBenhVien.Models.Department>)?.Any() ?? true)
                    {
                        <div class="alert alert-danger text-center shadow-sm">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> Hệ thống chưa có dữ liệu khoa phòng. Vui lòng liên hệ Admin để thêm mới khoa phòng trước khi nhập viện.
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4">
                            <div class="col-md-6 offset-md-3 text-center">
                                <label class="form-label fw-bold small text-uppercase text-muted mb-2">Bước 1: Chọn Khoa / Phòng nội trú</label>
                                <select name="departmentId" id="deptSelect" class="form-select form-select-lg text-center border-primary shadow-sm" required onchange="loadBeds(this.value)" style="border-radius: 12px;">
                                    <option value="">-- Click để chọn Khoa --</option>
                                    @foreach(var d in ViewBag.Departments as List<HeThongBenhVien.Models.Department>)
                                    {
                                        <option value="@d.Id">@d.DepartmentName (@(d.TotalBeds - d.OccupiedBeds) giường trống)</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div id="bedGridContainer" class="mt-4" style="display:none;">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-3 d-block text-center">Bước 2: Chọn vị trí giường bệnh (Giường trống màu trắng)</label>
                            <div class="bed-scroll-area p-4 bg-white rounded-4 border shadow-inner">
                                <div class="d-flex flex-wrap gap-3 justify-content-center" id="bedGrid">
                                    @for(int i = 1; i <= 50; i++)
                                    {
                                        <div class="bed-item" id="bed-@i" data-bed="@i" onclick="selectBed(@i)">
                                            <div class="bed-icon"><i class="fa-solid fa-bed"></i></div>
                                            <div class="bed-number">G-@i</div>
                                            <div class="bed-patient">Trống</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 text-center">
                            <div class="d-inline-flex gap-4 bg-white p-2 px-4 rounded-pill border shadow-sm">
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#fff; border:1px solid #e2e8f0;"></div> Giường trống</div>
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#fee2e2; border:1px solid #ef4444;"></div> Đã có bệnh</div>
                                <div class="d-flex align-items-center gap-2 small"><div class="legend-box" style="background:#0d6efd; border:1px solid #0044cc;"></div> Đang chọn</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-white border-0 px-4 py-3 shadow-top">
                    <button type="button" class="btn btn-outline-secondary px-4 fw-bold rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" id="btnSubmitAdmission" class="btn btn-primary px-5 fw-bold shadow-lg rounded-pill" disabled>
                        <i class="fa-solid fa-check-circle me-2"></i>Xác nhận Nhập viện
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .btn-hover { transition: all 0.3s ease; }
        .btn-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .legend-box { width:16px; height:16px; border-radius:4px; }
        .bed-scroll-area { max-height: 450px; overflow-y: auto; scrollbar-width: thin; }
        .bed-item { width: 100px; height: 100px; border: 2px solid #e2e8f0; border-radius: 16px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); background: #fff; position: relative; user-select: none; }
        .bed-item:hover { transform: translateY(-5px); border-color: #0d6efd; box-shadow: 0 10px 20px rgba(13, 110, 253, 0.1); }
        .bed-item.occupied { background: #fee2e2; border-color: #ef4444; cursor: not-allowed; opacity: 1; }
        .bed-item.occupied .bed-icon { color: #ef4444; }
        .bed-item.occupied .bed-number { color: #b91c1c; }
        .bed-item.occupied .bed-patient { color: #ef4444; font-weight: 500; }
        .bed-item.selected { background: #0d6efd; border-color: #0044cc; transform: scale(1.05); }
        .bed-item.selected .bed-icon, .bed-item.selected .bed-number, .bed-item.selected .bed-patient { color: #fff; }
        .bed-icon { font-size: 22px; color: #cbd5e1; margin-bottom: 4px; }
        .bed-number { font-weight: 800; font-size: 14px; color: #475569; }
        .bed-patient { font-size: 9px; color: #94a3b8; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
        
        @@media print {
            body { background: white !important; }
            /* Ẩn sidebar, navbar, các nút bấm, footer */
            .sidebar, .navbar, .btn, form, footer, .modal { display: none !important; }
            .glass-card { box-shadow: none !important; border: 1px solid #000 !important; background: white !important; }
            .container-fluid { padding: 0 !important; margin: 0 !important; }
            /* Loại bỏ màu gradient */
            .p-4[style*="linear-gradient"] { background: white !important; border: 1px solid #ccc !important; }
            /* Thêm Header cho PDF */
            body::before {
                content: "PHÒNG KHÁM ĐA KHOA QUỐC TẾ\A Địa chỉ: 123 Đường Y Tế, TP.HCM | SĐT: 1900 1234\A------------------------------------------------------------------\A";
                white-space: pre-wrap;
                font-size: 16pt;
                font-weight: bold;
                text-align: center;
                display: block;
                margin-bottom: 20px;
                color: #000;
            }
            * { color: #000 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .shadow-sm, .shadow-lg, .shadow { box-shadow: none !important; }
            
            /* Thêm phần Footer Ký tên vào cuối trang in */
            body::after {
                content: "\A\A Ngày ..... tháng ..... năm .....\A BÁC SĨ ĐIỀU TRỊ\A (Ký và ghi rõ họ tên)";
                white-space: pre-wrap;
                font-size: 12pt;
                font-weight: bold;
                text-align: right;
                display: block;
                margin-top: 50px;
                padding-right: 50px;
                color: #000;
            }
        }
    </style>
}

@section Scripts {
    <script>
        function loadBeds(deptId) {
            if (!deptId) {
                $('#bedGridContainer').hide();
                return;
            }

            // Reset beds state
            $('.bed-item').removeClass('occupied selected').css('pointer-events', 'auto');
            $('.bed-patient').text('Trống');
            $('#selectedBedNumber').val('');
            $('#btnSubmitAdmission').prop('disabled', true);

            // Load occupied beds from server
            $.get('/Doctor/GetOccupiedBeds', { departmentId: deptId }, function(data) {
                data.forEach(function(item) {
                    let bed = $('#bed-' + item.bedNumber);
                    bed.addClass('occupied').css('pointer-events', 'none');
                    bed.find('.bed-patient').text(item.patientName);
                });
                $('#bedGridContainer').show();
            });
        }

        function selectBed(num) {
            let bed = $('#bed-' + num);
            if (bed.hasClass('occupied')) return;

            $('.bed-item').removeClass('selected');
            bed.addClass('selected');
            $('#selectedBedNumber').val(num);
            $('#btnSubmitAdmission').prop('disabled', false);
        }
    </script>
}
