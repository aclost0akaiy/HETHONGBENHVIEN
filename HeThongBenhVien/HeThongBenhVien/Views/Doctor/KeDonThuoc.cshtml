@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Kê Đơn Thuốc";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Kê Đơn Thuốc</h2>
            <p class="text-muted mb-0">Hệ thống cấp phát và quản lý toa thuốc điện tử.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-pills me-2"></i>Thêm Thuốc Vào Đơn</h5>
                <form>
                    <div class="mb-3">
                        <label class="form-label text-secondary fw-semibold">Tên Thuốc</label>
                        <input type="text" class="form-control" placeholder="Nhập tên thuốc hoặc mã thuốc">
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label text-secondary fw-semibold">Số lượng</label>
                            <input type="number" class="form-control" value="1">
                        </div>
                        <div class="col-6">
                            <label class="form-label text-secondary fw-semibold">Đơn vị</label>
                            <select class="form-select">
                                <option>Viên</option>
                                <option>Vỉ</option>
                                <option>Hộp</option>
                                <option>Lọ</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary fw-semibold">Liều dùng</label>
                        <input type="text" class="form-control" placeholder="VD: Sáng 1 viên, tối 1 viên sau ăn">
                    </div>
                    <button type="button" class="btn btn-primary w-100"><i class="fa-solid fa-plus me-2"></i>Thêm vào toa</button>
                </form>
            </div>
        </div>
        <div class="col-lg-8 mb-4">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold text-dark">Toa Thuốc Hiện Tại</h5>
                    <span class="badge bg-danger rounded-pill px-3 py-2">Bệnh nhân: Nguyễn Văn A</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tên Thuốc</th>
                                <th>SL</th>
                                <th>Đơn vị</th>
                                <th>Liều dùng & Cách dùng</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-bold">Paracetamol 500mg</td>
                                <td>20</td>
                                <td>Viên</td>
                                <td>Uống 1 viên khi đau/sốt, cách nhau 4-6 tiếng</td>
                                <td><button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button></td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Amoxicillin 500mg</td>
                                <td>14</td>
                                <td>Viên</td>
                                <td>Sáng 1 viên, tối 1 viên sau ăn</td>
                                <td><button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-end mt-4">
                    <button class="btn btn-success px-4"><i class="fa-solid fa-print me-2"></i>In Toa Thuốc</button>
                    <button class="btn btn-primary px-4 ms-2"><i class="fa-solid fa-floppy-disk me-2"></i>Lưu Toa</button>
                </div>
            </div>
        </div>
    </div>
</div>
