@model IEnumerable<HeThongBenhVien.Models.User>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Kê Đơn Thuốc";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Kê Đơn Thuốc</h2>
            <p class="text-muted mb-0">Chọn bệnh nhân để tạo hoặc chỉnh sửa toa thuốc.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold text-dark">Danh sách bệnh nhân</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã BN</th>
                                <th>Tên bệnh nhân</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.PatientCode</td>
                                        <td>@item.FullName</td>
                                        <td>@item.Username</td>
                                        <td>@item.Email</td>
                                        <td>
                                            <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = item.Id })" class="btn btn-sm btn-success rounded-pill px-3">Kê đơn</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Không có bệnh nhân nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
