@model IEnumerable<HeThongBenhVien.Models.MedicalRecord>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Lịch Mổ";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Danh Sách Lịch Mổ / Phẫu Thuật</h2>
            <p class="text-muted mb-0">Quản lý các ca phẫu thuật, thủ thuật trong ngày.</p>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="ps-4 py-3 border-0">Phòng Mổ</th>
                    <th class="py-3 border-0">Bệnh Nhân</th>
                    <th class="py-3 border-0">Phẫu Thuật Viên</th>
                    <th class="py-3 border-0">Chẩn Đoán / Tên Phẫu Thuật</th>
                    <th class="pe-4 py-3 border-0">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">Chưa xếp phòng</td>
                        <td>
                            @item.Appointment?.Patient?.FullName <br/>
                            <small class="text-muted">Mã BN: @item.Appointment?.Patient?.PatientCode</small>
                        </td>
                        <td><span class="badge bg-light text-dark border">Chưa phân công</span></td>
                        <td>@item.Diagnosis</td>
                        <td class="pe-4"><span class="badge bg-warning text-dark rounded-pill px-3">Chờ xếp lịch mổ</span></td>
                    </tr>
                }
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Không có bệnh nhân nào đang chờ phẫu thuật.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
