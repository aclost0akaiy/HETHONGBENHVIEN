@model IEnumerable<HeThongBenhVien.Models.MedicalRecord>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Lịch Mổ";
    var recordIdsWithVitals = ViewBag.RecordIdsWithVitals as List<int> ?? new List<int>();
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Danh Sách Lịch Mổ / Phẫu Thuật</h2>
            <p class="text-muted mb-0">Quản lý các ca phẫu thuật, thủ thuật trong ngày.</p>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4 py-3 border-0">STT</th>
                        <th class="py-3 border-0">Bệnh Nhân</th>
                        <th class="py-3 border-0">Phẫu Thuật Viên</th>
                        <th class="py-3 border-0">Chẩn Đoán / Tên Phẫu Thuật</th>
                        <th class="py-3 border-0">Trạng Thái</th>
                        <th class="pe-4 py-3 border-0 text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        var hasVitals = recordIdsWithVitals.Contains(item.Appointment?.Id ?? 0);
                        var statusClass = item.Appointment?.Status switch
                        {
                            9 => "bg-primary",
                            10 => "bg-success",
                            _ => "bg-warning text-dark"
                        };
                        var statusText = item.Appointment?.Status switch
                        {
                            9 => "Đang mổ",
                            10 => "Kết thúc",
                            _ => "Chờ mổ"
                        };

                        <tr>
                            <td class="ps-4">@i</td>
                            <td>
                                <div class="fw-bold">@item.Appointment?.Patient?.FullName</div>
                                <small class="text-muted">Mã BN: @item.Appointment?.Patient?.PatientCode</small>
                            </td>
                            @{
                                var isCompleted = item.Appointment?.Status == 10 || item.Appointment?.Status == 5;
                            }
                            <td>
                                <select name="surgeonId" class="form-select form-select-sm" form="form-@item.Appointment?.Id" @(isCompleted ? "disabled" : "")>
                                    <option value="">-- Chọn Bác Sĩ --</option>
                                    @if (ViewBag.Surgeons != null)
                                    {
                                        foreach (var surgeon in ViewBag.Surgeons)
                                        {
                                            <option value="@surgeon.Id">@surgeon.FullName</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>@item.Diagnosis</td>
                            <td>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge @statusClass rounded-pill px-3">@statusText</span>
                                    <select name="surgeryType" class="form-select form-select-sm w-auto" form="form-@item.Appointment?.Id" @(isCompleted ? "disabled" : "")>
                                        <option value="">-- Loại mổ --</option>
                                        @if (ViewBag.SurgeryTypes != null)
                                        {
                                            foreach (var type in ViewBag.SurgeryTypes)
                                            {
                                                <option value="@type.Id">@type.FeeName (@type.Price.ToString("N0") VNĐ)</option>
                                            }
                                        }
                                    </select>
                                    <a href="@Url.Action("SinhHieu", "Doctor", new { id = item.Appointment?.Id })" class="ms-1 @(hasVitals ? "text-success" : "text-danger")" title="Theo dõi sinh hiệu">
                                        <i class="fa-solid fa-heart-pulse"></i>
                                    </a>
                                </div>
                                @if (!hasVitals)
                                {
                                    <small class="text-danger" style="font-size: 10px;">Chưa nhập sinh hiệu</small>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                @if (item.Appointment?.Status != 10 && item.Appointment?.Status != 5)
                                {
                                    <form asp-action="CapNhatTrangThaiMo" method="post" class="d-inline" id="form-@item.Appointment?.Id">
                                        <input type="hidden" name="id" value="@item.Appointment?.Id" />
                                        @if (item.Appointment?.Status != 9)
                                        {
                                            <input type="hidden" name="status" value="9" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3" @(hasVitals ? "" : "disabled") title="@(hasVitals ? "" : "Vui lòng nhập sinh hiệu trước khi mổ")">Bắt đầu mổ</button>
                                        }
                                        else
                                        {
                                            <input type="hidden" name="status" value="10" />
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Kết thúc</button>
                                        }
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Hoàn tất</span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Không có bệnh nhân nào đang chờ phẫu thuật.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
