@model HeThongBenhVien.Models.Prescription
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Kê Đơn Thuốc";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Kê Đơn Thuốc</h2>
            <p class="text-muted mb-0">Hệ thống cấp phát và quản lý toa thuốc điện tử.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-pills me-2"></i>Thêm Thuốc Vào Đơn</h5>
                <form asp-action="LuuToaThuoc" asp-controller="Doctor" method="post">
                    <input type="hidden" name="prescriptionId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label text-secondary fw-semibold">Chọn Thuốc</label>
                        <select name="medicineId" class="form-select" required>
                            <option value="">-- Chọn thuốc --</option>
                            @if (ViewBag.Medicines != null)
                            {
                                foreach (var med in ViewBag.Medicines as IEnumerable<HeThongBenhVien.Models.Medicine>)
                                {
                                    <option value="@med.Id">@med.Name - @string.Format("{0:N0} đ", med.Price)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4">
                            <label class="form-label text-secondary fw-semibold">Số lượng</label>
                            <input type="number" name="quantity" class="form-control" value="1" min="1" required>
                        </div>
                        <div class="col-4">
                            <label class="form-label text-secondary fw-semibold">Đơn vị</label>
                            <select name="unit" id="unitSelect" class="form-select">
                                <option value="Viên">Viên</option>
                                <option value="Vỉ">Vỉ</option>
                                <option value="Lọ">Lọ</option>
                                <option value="Hộp">Hộp</option>
                                <option value="Ống">Ống</option>
                                <option value="Cái">Cái</option>
                                <option value="Tuýp">Tuýp</option>
                                <option value="Gói">Gói</option>
                                <option value="Chai">Chai</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary fw-semibold">Liều dùng</label>
                        <input type="text" name="dosage" class="form-control" placeholder="VD: Sáng 1 viên, tối 1 viên sau ăn" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-plus me-2"></i>Thêm vào toa</button>
                </form>
            </div>
        </div>
        <div class="col-lg-8 mb-4">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold text-dark">Toa Thuốc Hiện Tại</h5>
                    <span class="badge bg-danger rounded-pill px-3 py-2">Bệnh nhân: @Model.MedicalRecord?.Appointment?.Patient?.FullName</span>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="bg-info bg-opacity-10 p-3 rounded-3 border border-info h-100">
                            <span class="text-info small fw-semibold">Tổng tiền thuốc hiện tại</span>
                            <div class="fs-3 fw-bold text-danger mt-2">@string.Format("{0:N0} đ", Model.PrescriptionDetails.Sum(d => d.Price * d.Quantity))</div>
                            <div class="text-secondary small mt-1">Số loại thuốc: @Model.PrescriptionDetails.Count()</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light p-3 rounded-3 border h-100">
                            <span class="text-secondary small fw-semibold">Tổng số lượng thuốc</span>
                            <div class="fs-3 fw-bold mt-2">@Model.PrescriptionDetails.Sum(d => d.Quantity)</div>
                            <div class="text-secondary small mt-1">Tổng đơn giá tính theo số lượng</div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tên Thuốc</th>
                                <th>SL</th>
                                <th>Đơn vị</th>
                                <th>Liều dùng & Cách dùng</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.PrescriptionDetails)
                            {
                                <tr>
                                    <td class="fw-bold">@detail.MedicineName</td>
                                    <td>@detail.Quantity</td>
                                    <td>@detail.Unit</td>
                                    <td>@detail.DosageInstruction</td>
                                    <td>@string.Format("{0:N0} đ", detail.Price)</td>
                                    <td><strong class="text-danger">@string.Format("{0:N0} đ", detail.Price * detail.Quantity)</strong></td>
                                </tr>
                            }
                            @if (!Model.PrescriptionDetails.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có thuốc nào trong toa.</td>
                                </tr>
                            }
                            else
                            {
                                <tr class="bg-light">
                                    <td colspan="5" class="text-end fw-bold">TỔNG CỘNG:</td>
                                    <td class="fw-bold text-danger fs-5">@string.Format("{0:N0} đ", Model.PrescriptionDetails.Sum(d => d.Price * d.Quantity))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="text-end mt-4">
                    <a href="@Url.Action("ChiTietBenhAn", "Doctor", new { id = Model.MedicalRecordId })" class="btn btn-primary px-4 ms-2"><i class="fa-solid fa-floppy-disk me-2"></i>Lưu Toa</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold text-dark mb-3">Tất cả đơn thuốc trong dữ liệu</h5>
                @{
                    var allDetails = ViewBag.AllPrescriptionDetails as IEnumerable<HeThongBenhVien.Models.PrescriptionDetail>;
                }
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Bệnh nhân</th>
                                <th>Mã hồ sơ</th>
                                <th>Tên thuốc</th>
                                <th>SL</th>
                                <th>Đơn vị</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (allDetails != null && allDetails.Any())
                            {
                                foreach (var item in allDetails)
                                {
                                    <tr>
                                        <td>@item.Prescription?.MedicalRecord?.Appointment?.Patient?.FullName</td>
                                        <td>@item.Prescription?.MedicalRecordId</td>
                                        <td>@item.MedicineName</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.Unit</td>
                                        <td>@string.Format("{0:N0} đ", item.Price)</td>
                                        <td>@string.Format("{0:N0} đ", item.Price * item.Quantity)</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Chưa có đơn thuốc nào trong dữ liệu.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
}
