@model IEnumerable<HeThongBenhVien.Models.Patient>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Danh sách Bệnh nhân";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Danh Sách Bệnh Nhân</h2>
            <p class="text-muted mb-0">Tra cứu và quản lý hồ sơ thông tin bệnh nhân.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4 py-2" style="border-radius: 10px; font-weight: 500;" data-bs-toggle="modal" data-bs-target="#addPatientModal">
                <i class="fa-solid fa-plus me-2"></i> Thêm Bệnh Nhân Mới
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewData["SearchString"]?.ToString()))
    {
        <div class="alert alert-info mb-4">
            Kết quả tìm kiếm cho: <strong>@ViewData["SearchString"]</strong>
        </div>
    }

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 14px;">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 border-0 py-3">Mã BN</th>
                        <th class="border-0 py-3">Họ và Tên</th>
                        <th class="border-0 py-3">Giới tính</th>
                        <th class="border-0 py-3">Tuổi</th>
                        <th class="pe-4 border-0 py-3 text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            string initials = "BN";
                            if (!string.IsNullOrEmpty(item.FullName))
                            {
                                var words = item.FullName.Trim().Split(' ');
                                if (words.Length > 1) {
                                    initials = $"{words[0][0]}{words[words.Length-1][0]}".ToUpper();
                                } else {
                                    initials = item.FullName.Substring(0, 1).ToUpper();
                                }
                            }

                            <tr>
                                <td class="ps-4 font-weight-bold text-primary">@item.PatientCode</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; color: #64748b; font-weight: bold;">@initials</div>
                                        <div style="font-weight: 600; color: #334155;">@item.FullName</div>
                                    </div>
                                </td>
                                <td>@item.Gender</td>
                                <td>@item.Age</td>
                                <td class="pe-4 text-end">
                                    <a href="@Url.Action("HoSoBenhAn", "Doctor", new { searchString = item.PatientCode })" class="btn btn-sm btn-outline-info rounded-pill px-3 me-2" title="Xem hồ sơ"><i class="fa-solid fa-file-medical"></i></a>
                                    <a href="@Url.Action("EditPatient", "Doctor", new { id = item.Id })" class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Chỉnh sửa"><i class="fa-solid fa-pen"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fs-2 mb-3 text-light"></i>
                                <p>Không tìm thấy bệnh nhân nào khớp với từ khóa.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Thêm Bệnh Nhân -->
    <div class="modal fade" id="addPatientModal" tabindex="-1" aria-labelledby="addPatientModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="modal-header border-0 bg-primary bg-opacity-10" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold text-primary" id="addPatientModalLabel"><i class="fa-solid fa-user-plus me-2"></i>Thêm Bệnh Nhân Mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/Doctor/AddPatient" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Mã Bệnh Nhân</label>
                                <input type="text" class="form-control" name="PatientCode" placeholder="Nhập mã BN (VD: BN001)" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Họ và Tên</label>
                                <input type="text" class="form-control" name="FullName" placeholder="Nhập họ và tên" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Giới tính</label>
                                <select class="form-select" name="Gender" required>
                                    <option value="">Chọn giới tính</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Tuổi</label>
                                <input type="number" class="form-control" name="Age" placeholder="Nhập tuổi" required min="1" max="150">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy bỏ</button>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: 8px;"><i class="fa-solid fa-save me-2"></i>Lưu Bệnh Nhân</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
