@using HeThongBenhVien.Models
@model Appointment
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Sinh Hiệu Chi Tiết";
    var history = ViewBag.History as List<VitalSign> ?? new List<VitalSign>();
    var latest = history.FirstOrDefault();
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Bảng Mạch Nhiệt - Sinh Hiệu</h2>
            <p class="text-muted mb-0">Bệnh nhân: <span class="fw-bold text-primary">@Model.Patient?.FullName</span> (@Model.Patient?.PatientCode) - @Model.Patient?.Age Tuổi - @Model.Patient?.Gender</p>
        </div>
        <a href="@Url.Action("SinhHieu", "Doctor")" class="btn btn-outline-secondary rounded-pill">
            <i class="fa-solid fa-arrow-left me-2"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <!-- Vitals Cards -->
        <div class="col-md-3 mb-4">
            <div class="glass-card p-4 text-center border-bottom border-4 border-danger h-100">
                <i class="fa-solid fa-heart-pulse text-danger fs-1 mb-2"></i>
                <h6 class="text-muted mb-1">Mạch</h6>
                <h2 class="fw-bold text-dark m-0">@(latest?.Pulse ?? "--") <span class="fs-6 text-muted fw-normal">l/p</span></h2>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="glass-card p-4 text-center border-bottom border-4 border-warning h-100">
                <i class="fa-solid fa-temperature-half text-warning fs-1 mb-2"></i>
                <h6 class="text-muted mb-1">Nhiệt độ</h6>
                <h2 class="fw-bold text-dark m-0">@(latest?.Temperature ?? "--") <span class="fs-6 text-muted fw-normal">°C</span></h2>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="glass-card p-4 text-center border-bottom border-4 border-primary h-100">
                <i class="fa-solid fa-droplet text-primary fs-1 mb-2"></i>
                <h6 class="text-muted mb-1">Huyết áp</h6>
                <h2 class="fw-bold text-dark m-0">@(latest?.BloodPressure ?? "--") <span class="fs-6 text-muted fw-normal">mmHg</span></h2>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="glass-card p-4 text-center border-bottom border-4 border-info h-100">
                <i class="fa-solid fa-lungs text-info fs-1 mb-2"></i>
                <h6 class="text-muted mb-1">SpO2</h6>
                <h2 class="fw-bold text-dark m-0">@(latest?.SpO2 ?? "--") <span class="fs-6 text-muted fw-normal">%</span></h2>
            </div>
        </div>

        <!-- Input Form -->
        <div class="col-12 mb-4">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3">Nhập chỉ số sinh hiệu mới</h5>
                <form asp-action="LuuSinhHieu" method="post" class="row g-3">
                    <input type="hidden" name="appointmentId" value="@Model.Id" />
                    <div class="col-md-2">
                        <label class="form-label text-muted small">Mạch (l/p)</label>
                        <input type="text" name="pulse" class="form-control" required placeholder="85">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small">Nhiệt độ (°C)</label>
                        <input type="text" name="temperature" class="form-control" required placeholder="37.2">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small">Huyết áp (mmHg)</label>
                        <input type="text" name="bloodPressure" class="form-control" required placeholder="120/80">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small">SpO2 (%)</label>
                        <input type="text" name="spo2" class="form-control" required placeholder="98">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small">Điều dưỡng thực hiện</label>
                        <input type="text" name="nurseName" class="form-control" required placeholder="Tên điều dưỡng">
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Xác nhận</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3">Lịch sử đo sinh hiệu</h5>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Mạch</th>
                                <th>Nhiệt độ</th>
                                <th>Huyết áp</th>
                                <th>SpO2</th>
                                <th>Điều dưỡng đo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in history)
                            {
                                <tr>
                                    <td>@v.RecordedAt.ToString("HH:mm dd/MM/yyyy")</td>
                                    <td>@v.Pulse</td>
                                    <td>@v.Temperature</td>
                                    <td>@v.BloodPressure</td>
                                    <td>@v.SpO2%</td>
                                    <td>@v.NurseName</td>
                                </tr>
                            }
                            @if (!history.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Chưa có dữ liệu sinh hiệu.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
