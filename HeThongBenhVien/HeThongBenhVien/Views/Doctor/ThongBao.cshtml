@model IEnumerable<HeThongBenhVien.Models.Notification>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Thông Báo Lịch Hẹn";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Thông Báo Đặt Lịch</h2>
            <p class="text-muted mb-0">Danh sách các yêu cầu đặt lịch khám mới từ bệnh nhân.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="glass-card overflow-hidden">
                <div class="list-group list-group-flush">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="list-group-item list-group-item-action p-4 border-0 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                            <i class="fa-solid fa-calendar-check text-primary fs-4"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-4">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="mb-0 fw-bold text-dark">Đặt lịch khám mới</h6>
                                            <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <p class="mb-0 text-secondary">@item.Message</p>
                                    </div>
                                    <div class="ms-4">
                                        <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem lịch</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="fa-regular fa-bell-slash fs-1 mb-3"></i>
                            <p>Không có thông báo mới nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
