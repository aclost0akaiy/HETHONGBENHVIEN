@model List<HeThongBenhVien.Models.MedicalRecord>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Trung Tâm Điều Hành - L.I.V.E";
}

@section Styles {
    <style>
        :root {
            --mcc-bg: var(--bg-color);
            --mcc-panel: var(--card-bg);
            --mcc-border: var(--border-color);
            --mcc-text: var(--text-dark);
            --mcc-accent: #0ea5e9;
            --mcc-success: #22c55e;
            --mcc-warning: #eab308;
            --mcc-danger: #ef4444;
        }

        /* Use layout's body background instead of forcing */

        .mcc-container {
            padding: 20px;
            height: calc(100vh - 70px);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--mcc-bg);
        }

        .mcc-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--mcc-border);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .mcc-header-title {
            font-size: 1.5rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .mcc-header-title i {
            color: var(--mcc-accent);
        }

        .mcc-status-bar {
            display: flex;
            gap: 20px;
        }

        .mcc-stat {
            background: var(--mcc-bg);
            padding: 10px 20px;
            border-radius: 8px;
            border: 1px solid var(--mcc-border);
            text-align: center;
        }

        .mcc-stat-val {
            font-size: 1.5rem;
            font-weight: bold;
            font-family: monospace;
            color: var(--mcc-accent);
        }

        .mcc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            flex-grow: 1;
            overflow-y: auto;
            padding-right: 10px;
        }

        /* Custom Scrollbar */
        .mcc-grid::-webkit-scrollbar { width: 8px; }
        .mcc-grid::-webkit-scrollbar-track { background: var(--mcc-bg); }
        .mcc-grid::-webkit-scrollbar-thumb { background: var(--mcc-border); border-radius: 4px; }

        .bed-card {
            background: var(--mcc-panel);
            border: 1px solid var(--mcc-border);
            border-radius: 12px;
            padding: 15px;
            position: relative;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .bed-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--mcc-border);
            padding-bottom: 10px;
        }
        
        .bed-id {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--mcc-text);
        }

        .ews-score {
            background: var(--text-light);
            color: #fff;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .vital-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .vital-box {
            text-align: center;
            padding: 10px;
            background: var(--mcc-bg);
            border-radius: 8px;
            border: 1px solid var(--mcc-border);
        }

        .vital-title {
            font-size: 0.75rem;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .vital-val {
            font-size: 1.8rem;
            font-family: 'Courier New', Courier, monospace;
            font-weight: bold;
        }

        .vital-unit {
            font-size: 0.8rem;
            color: #71717a;
        }

        /* Color States */
        .val-hr { color: var(--mcc-success); }
        .val-spo2 { color: var(--mcc-accent); }
        .val-bp { color: var(--mcc-warning); }
        
        .text-danger-val { color: var(--mcc-danger) !important; }
        
        /* Code Blue Alert */
        @@keyframes emergency-flash {
            0% { box-shadow: inset 0 0 0px var(--mcc-danger), 0 0 0px var(--mcc-danger); border-color: var(--mcc-danger); }
            50% { box-shadow: inset 0 0 50px var(--mcc-danger), 0 0 20px var(--mcc-danger); border-color: var(--mcc-danger); background-color: rgba(239, 68, 68, 0.2); }
            100% { box-shadow: inset 0 0 0px var(--mcc-danger), 0 0 0px var(--mcc-danger); border-color: var(--mcc-danger); }
        }

        .code-blue {
            animation: emergency-flash 0.8s infinite;
        }
        
        .code-blue {
            animation: emergency-flash 0.8s infinite;
        }

    </style>
}

<div class="mcc-container">
    <div class="mcc-header">
        <div class="mcc-header-title">
            <i class="fa-solid fa-satellite-dish fa-fade"></i> MEDICAL COMMAND CENTER (EWS)
        </div>
        <div class="mcc-status-bar">
            <div class="mcc-stat">
                <div class="vital-title">TỔNG BỆNH NHÂN CẤP CỨU</div>
                <div class="mcc-stat-val" id="totalPatients">@Model.Count</div>
            </div>
            <div class="mcc-stat">
                <div class="vital-title">CA NGUY KỊCH (EWS > 7)</div>
                <div class="mcc-stat-val text-danger-val" id="criticalCount">0</div>
            </div>
            <div class="mcc-stat">
                <div class="vital-title">KẾT NỐI HỆ THỐNG</div>
                <div class="mcc-stat-val" style="color:var(--mcc-success)">TỐT</div>
            </div>
        </div>
    </div>

    <!-- Bed Grid -->
    <div class="mcc-grid" id="bedGrid">
        @if (!Model.Any())
        {
            <div style="grid-column: 1/-1; text-align: center; color: var(--text-light); padding: 50px;">
                <i class="fa-solid fa-bed fa-3x mb-3"></i>
                <h4>Không có bệnh nhân nào đang nhập viện</h4>
            </div>
        }
        else
        {
            @foreach (var record in Model)
            {
                var patientName = record.Appointment?.Patient?.FullName ?? "Unknown";
                var deptName = record.Department?.DepartmentName ?? "Khoa Cấp Cứu";
                
                <div class="bed-card" id="bed-@record.Id" data-bednumber="@record.BedNumber" data-department="@deptName">
                    <div class="bed-header">
                        <div class="bed-id">
                            <i class="fa-solid fa-bed me-2 text-secondary"></i>BED @record.BedNumber
                            <div style="font-size: 0.75rem; color: var(--text-light); margin-top: 5px; font-weight: normal;">
                                <i class="fa-regular fa-user me-1"></i> @patientName <br/>
                                <i class="fa-regular fa-hospital me-1"></i> @deptName
                            </div>
                        </div>
                        <div class="ews-score" id="ews-@record.Id">EWS: 0</div>
                    </div>
                    <div class="vital-grid">
                        <div class="vital-box">
                            <div class="vital-title"><i class="fa-solid fa-heart-pulse text-success me-1"></i> HEART RATE</div>
                            <div class="vital-val val-hr" id="hr-@record.Id">--</div>
                            <div class="vital-unit">bpm</div>
                        </div>
                        <div class="vital-box">
                            <div class="vital-title"><i class="fa-solid fa-lungs text-info me-1"></i> SpO2</div>
                            <div class="vital-val val-spo2" id="spo2-@record.Id">--</div>
                            <div class="vital-unit">%</div>
                        </div>
                        <div class="vital-box" style="grid-column: span 2;">
                            <div class="vital-title"><i class="fa-solid fa-droplet text-warning me-1"></i> BLOOD PRESSURE</div>
                            <div class="vital-val val-bp" id="bp-@record.Id">-- / --</div>
                            <div class="vital-unit">mmHg</div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const activeBedIds = [
            @foreach (var record in Model)
            {
                @: "@record.Id",
            }
        ];

        // Initialize SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/commandHub")
            .configureLogging(signalR.LogLevel.Information)
            .build();

        // Xử lý dữ liệu nhận từ SignalR
        connection.on("ReceiveVitalsUpdate", (bedId, hr, spo2, bp, ews) => {
            document.getElementById(`hr-${bedId}`).innerText = hr;
            document.getElementById(`spo2-${bedId}`).innerText = spo2;
            document.getElementById(`bp-${bedId}`).innerText = bp;
            
            const ewsBadge = document.getElementById(`ews-${bedId}`);
            ewsBadge.innerText = `EWS: ${ews}`;
            
            // Color coding based on EWS
            if (ews >= 7) {
                ewsBadge.style.backgroundColor = 'var(--mcc-danger)';
            } else if (ews >= 5) {
                ewsBadge.style.backgroundColor = 'var(--mcc-warning)';
                ewsBadge.style.color = '#000';
            } else {
                ewsBadge.style.backgroundColor = '#3f3f46';
                ewsBadge.style.color = '#fff';
            }
        });

        let codeBlueActive = false;

        connection.on("ReceiveCodeBlue", (bedId, bedNum, deptName) => {
            if(!codeBlueActive) {
                codeBlueActive = true;
                const bed = document.getElementById(`bed-${bedId}`);
                if (bed) bed.classList.add('code-blue');
                
                document.getElementById('criticalCount').innerText = parseInt(document.getElementById('criticalCount').innerText) + 1;
                
                // Reset after 10 seconds for demo loop
                setTimeout(() => {
                    if (bed) bed.classList.remove('code-blue');
                    codeBlueActive = false;
                    document.getElementById('criticalCount').innerText = "0";
                }, 10000);
            }
        });

        // Bắt đầu kết nối
        async function start() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
                startIoTSimulation();
            } catch (err) {
                console.log(err);
                setTimeout(start, 5000);
            }
        }
        
        start();

        // ----------------------------------------------------
        // SIMULATE IOT DEVICES SENDING DATA TO HUB
        // ----------------------------------------------------
        function calculateEWS(hr, spo2) {
            let score = 0;
            if (hr <= 40 || hr >= 131) score += 3;
            else if (hr >= 111 && hr <= 130) score += 2;
            else if (hr <= 50 || (hr >= 91 && hr <= 110)) score += 1;

            if (spo2 <= 91) score += 3;
            else if (spo2 >= 92 && spo2 <= 93) score += 2;
            else if (spo2 >= 94 && spo2 <= 95) score += 1;
            
            return score;
        }

        function startIoTSimulation() {
            if (activeBedIds.length === 0) return;

            // Normal fluctuation
            setInterval(() => {
                if(codeBlueActive) return; // Pause normal update during code blue
                
                activeBedIds.forEach(bedId => {
                    // Random normal values
                    let hr = Math.floor(Math.random() * (90 - 60 + 1) + 60);
                    let spo2 = Math.floor(Math.random() * (100 - 96 + 1) + 96);
                    let sys = Math.floor(Math.random() * (130 - 110 + 1) + 110);
                    let dia = Math.floor(Math.random() * (85 - 70 + 1) + 70);
                    
                    let ews = calculateEWS(hr, spo2);
                    
                    connection.invoke("SendVitalsUpdate", bedId, hr, spo2, `${sys} / ${dia}`, ews)
                        .catch(err => console.error(err.toString()));
                });
            }, 2000); // Cập nhật mỗi 2 giây
            
            // Code Blue trigger simulation after 10 seconds
            setTimeout(() => {
                triggerEmergency();
                setInterval(triggerEmergency, 30000); // Trigger again every 30s
            }, 10000);
        }

        function triggerEmergency() {
            if (activeBedIds.length === 0) return;

            let targetIndex = Math.floor(Math.random() * activeBedIds.length);
            let targetBed = activeBedIds[targetIndex];
            
            let bedEl = document.getElementById(`bed-${targetBed}`);
            let bedNum = bedEl ? bedEl.getAttribute('data-bednumber') : targetBed;
            let deptName = bedEl ? bedEl.getAttribute('data-department') : '';
            
            // Dangerous values (Heart Attack / Arrest)
            let hr = 160;
            let spo2 = 82;
            let sys = 70;
            let dia = 40;
            let ews = calculateEWS(hr, spo2) + 4; // Add points for BP implicitly
            
            connection.invoke("SendVitalsUpdate", targetBed, hr, spo2, `${sys} / ${dia}`, ews);
            connection.invoke("SendCodeBlue", targetBed, bedNum, deptName);
        }
    </script>
}
