@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Kết Quả Cận Lâm Sàng";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Kết Quả Xét Nghiệm</h2>
            <p class="text-muted mb-0">Trả kết quả từ hệ thống LIS/PACS trung tâm.</p>
        </div>
        <div class="input-group w-25">
            <input type="text" class="form-control" placeholder="Nhập mã bệnh nhân...">
            <button class="btn btn-primary"><i class="fa-solid fa-search"></i></button>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3">Loại Xét Nghiệm</th>
                    <th class="py-3">Chỉ Số</th>
                    <th class="py-3">Kết Quả</th>
                    <th class="py-3">Đơn Vị</th>
                    <th class="py-3">Trị Số Bình Thường</th>
                    <th class="pe-4 py-3">Đánh Giá</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-4 fw-bold text-primary">Huyết Học</td>
                    <td>Bạch Cầu (WBC)</td>
                    <td class="fw-bold">7.5</td>
                    <td>G/L</td>
                    <td>4.0 - 10.0</td>
                    <td><span class="badge bg-success rounded-pill px-2">Bình Thường</span></td>
                </tr>
                <tr>
                    <td class="ps-4 fw-bold text-primary">Huyết Học</td>
                    <td>Hồng Cầu (RBC)</td>
                    <td class="fw-bold text-danger">3.1 <i class="fa-solid fa-arrow-down"></i></td>
                    <td>T/L</td>
                    <td>3.8 - 5.8</td>
                    <td><span class="badge bg-danger rounded-pill px-2">Thấp</span></td>
                </tr>
                <tr class="bg-light">
                    <td class="ps-4 fw-bold text-success">Sinh Hóa</td>
                    <td>Glucose Máu</td>
                    <td class="fw-bold text-danger">7.8 <i class="fa-solid fa-arrow-up"></i></td>
                    <td>mmol/L</td>
                    <td>3.9 - 6.4</td>
                    <td><span class="badge bg-warning text-dark rounded-pill px-2">Cao</span></td>
                </tr>
                 <tr class="bg-light">
                    <td class="ps-4 fw-bold text-success">Sinh Hóa</td>
                    <td>Creatinin</td>
                    <td class="fw-bold">80.5</td>
                    <td>umol/L</td>
                    <td>53.0 - 120.0</td>
                    <td><span class="badge bg-success rounded-pill px-2">Bình Thường</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
