@model IEnumerable<HeThongBenhVien.Models.LabTest>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Kết Quả Cận Lâm Sàng";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Cập Nhật Kết Quả Xét Nghiệm</h2>
            <p class="text-muted mb-0">Nhập kết quả xét nghiệm cho các bệnh nhân đang chờ.</p>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3">Bệnh Nhân</th>
                    <th class="py-3">Tên Xét Nghiệm</th>
                    <th class="py-3">Trạng Thái</th>
                    <th class="py-3">Kết Quả</th>
                    <th class="py-3">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">
                            @item.MedicalRecord?.Appointment?.Patient?.FullName <br />
                            <small class="text-muted">Mã BN: @item.MedicalRecord?.Appointment?.Patient?.PatientCode</small>
                        </td>
                        <td>@item.TestName</td>
                        <td>
                            @if (item.Status == "Đã có kết quả")
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Đã có kết quả</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Chờ xét nghiệm</span>
                            }
                        </td>
                        <td class="fw-bold">
                            @item.Result
                        </td>
                        <td>
                            @if (item.Status == "Đã có kết quả")
                            {
                                <a href="@Url.Action("ChiTietBenhAn", "Doctor", new { id = item.MedicalRecordId })" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem Hồ Sơ</a>
                            }
                            else
                            {
                                <form asp-action="CapNhatKetQuaXetNghiem" asp-controller="Doctor" method="post" class="d-flex gap-2 m-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="text" name="ketQua" class="form-control form-control-sm" placeholder="Nhập kết quả..." required />
                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">Cập nhật</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Không có bệnh nhân chờ xét nghiệm.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
