@model IEnumerable<HeThongBenhVien.Models.MedicalRecord>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Quản Lý Giường Bệnh";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Sơ Đồ Giường Bệnh Nội Trú</h2>
            <p class="text-muted mb-0">Danh sách bệnh nhân đã nhập viện.</p>
        </div>
        <div class="d-flex gap-3">
            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-4 py-2" style="border-radius: 10px; font-size: 0.9rem;">
                <i class="fa-solid fa-bed-pulse me-2"></i> Tổng BN nội trú: @Model.Count()
            </span>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="glass-card p-3">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-bold text-muted text-uppercase small">Chọn Khoa:</span>
                        <select id="deptSelector" class="form-select border-primary shadow-sm" style="width: auto; min-width: 280px; border-radius: 12px; font-weight: 600; padding: 0.6rem 1rem;" onchange="location.href='@Url.Action("QuanLyGiuong", "Doctor")?deptId=' + this.value">
                            @foreach(var d in ViewBag.Departments as List<HeThongBenhVien.Models.Department>)
                            {
                                <option value="@d.Id" selected="@(ViewBag.SelectedDeptId == d.Id)">
                                    @d.DepartmentName (@d.OccupiedBeds/@d.TotalBeds Giường)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="ms-auto">
                        <button type="button" class="btn btn-danger px-4 fw-bold shadow-sm" style="border-radius: 10px;" data-bs-toggle="modal" data-bs-target="#occupiedBedsModal">
                            <i class="fa-solid fa-bed-pulse me-2"></i>Giường đang sử dụng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <h5 class="fw-bold text-primary m-0"><i class="fa-solid fa-hotel me-2"></i>Sơ đồ giường bệnh - 50 Giường</h5>
            <div class="d-flex gap-3">
                <div class="d-flex align-items-center gap-2 small"><div style="width:15px;height:15px;background:#e2e8f0;border-radius:3px;"></div> Trống</div>
                <div class="d-flex align-items-center gap-2 small"><div style="width:15px;height:15px;background:#ef4444;border-radius:3px;"></div> Có bệnh nhân</div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-3 justify-content-center" id="bedGrid">
            @{
                var occupiedBeds = ViewBag.CurrentDeptOccupiedBeds as List<HeThongBenhVien.Models.MedicalRecord>;
            }
            @for(int i = 1; i <= 50; i++)
            {
                var record = occupiedBeds?.FirstOrDefault(r => r.BedNumber == i);
                if (record != null)
                {
                    <div class="bed-item occupied" onclick="showAdmissionModal(@record.Id, '@record.Appointment?.Patient?.FullName', '@(record.AdmissionDate?.ToString("o") ?? record.CreatedAt.ToString("o"))')">
                        <div class="bed-icon"><i class="fa-solid fa-bed"></i></div>
                        <div class="bed-number">G-@i</div>
                        <div class="bed-patient text-truncate px-1">@record.Appointment?.Patient?.FullName</div>
                    </div>
                }
                else
                {
                    <div class="bed-item">
                        <div class="bed-icon"><i class="fa-solid fa-bed"></i></div>
                        <div class="bed-number">G-@i</div>
                        <div class="bed-patient">Trống</div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .bed-item { width: 110px; height: 110px; border: 1px solid #e2e8f0; border-radius: 15px; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: all 0.2s; background: #fff; position: relative; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
    .bed-item.occupied { background: #fee2e2; border-color: #ef4444; cursor: pointer; }
    .bed-item.occupied:hover { transform: scale(1.05); z-index: 10; box-shadow: 0 10px 20px rgba(239, 68, 68, 0.1); }
    .bed-item.occupied .bed-icon { color: #ef4444; }
    .bed-item.occupied .bed-number { color: #b91c1c; }
    .bed-item.occupied .bed-patient { color: #ef4444; font-weight: 600; }
    .bed-icon { font-size: 24px; color: #cbd5e1; margin-bottom: 5px; }
    .bed-number { font-weight: 800; font-size: 15px; color: #64748b; }
    .bed-patient { font-size: 11px; color: #94a3b8; margin-top: 4px; width: 100%; text-align: center; }
</style>

<!-- Modal Danh sách giường đang sử dụng -->
<div class="modal fade" id="occupiedBedsModal" tabindex="-1" aria-labelledby="occupiedBedsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <div class="modal-header bg-danger text-white border-0 py-3" style="border-radius: 20px 20px 0 0;">
        <h5 class="modal-title fw-bold" id="occupiedBedsModalLabel"><i class="fa-solid fa-list-check me-2"></i>Danh Sách Giường Đang Sử Dụng</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm rounded-3 overflow-hidden">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0">Số Giường</th>
                        <th class="border-0">Khoa / Phòng</th>
                        <th class="border-0">Bệnh Nhân</th>
                        <th class="border-0">Ngày Nhập Viện</th>
                        <th class="border-0">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var record in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">G-@record.BedNumber</td>
                            <td><span class="badge bg-info bg-opacity-10 text-info fw-bold">@record.Department?.DepartmentName</span></td>
                            <td class="fw-bold">@record.Appointment?.Patient?.FullName</td>
                            <td>@record.AdmissionDate?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="showAdmissionModal(@record.Id, '@record.Appointment?.Patient?.FullName', '@(record.AdmissionDate?.ToString("o") ?? record.CreatedAt.ToString("o"))')">
                                    Chi tiết / Xuất viện
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-bed-pulse fs-1 mb-3 opacity-25"></i>
                                <p>Không có giường nào đang được sử dụng.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
      </div>
      <div class="modal-footer border-0 p-4 pt-0">
        <button type="button" class="btn btn-light px-4 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 10px;">Đóng</button>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="admissionModal" tabindex="-1" aria-labelledby="admissionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <form action="@Url.Action("XuatVien", "Doctor")" method="post">
          <div class="modal-header bg-primary text-white border-0 py-3" style="border-radius: 20px 20px 0 0;">
            <h5 class="modal-title fw-bold" id="admissionModalLabel"><i class="fa-solid fa-bed me-2"></i>Chi Tiết Nội Trú & Thanh Toán</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4">
            <input type="hidden" name="id" id="modalRecordId" value="" />
            
            <div class="row align-items-center mb-4">
                <div class="col-auto">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                        <i class="fa-solid fa-user-doctor fs-3"></i>
                    </div>
                </div>
                <div class="col">
                    <h4 id="modalPatientName" class="fw-bold text-dark mb-1"></h4>
                    <span class="badge bg-danger text-white px-3 py-1">Đang điều trị nội trú</span>
                </div>
            </div>
            
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card border-0 bg-light p-3 h-100" style="border-radius: 15px;">
                        <small class="text-muted text-uppercase fw-bold mb-2 d-block">Thời gian nhập viện</small>
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-clock-rotate-left text-primary"></i>
                            <strong id="modalStartTime" class="fs-5"></strong>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 bg-light p-3 h-100" style="border-radius: 15px;">
                        <small class="text-muted text-uppercase fw-bold mb-2 d-block">Thời gian nằm viện</small>
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-calendar-days text-primary"></i>
                            <strong id="modalDays" class="fs-5">0 ngày</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4" style="background: #f8fafc; border-radius: 15px;">
                <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Tạm tính chi phí phòng</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Đơn giá giường / ngày:</span>
                    <span class="fw-bold text-dark">65.000 VNĐ</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Tổng số ngày:</span>
                    <span id="modalDaysDetail" class="fw-bold text-dark">0 ngày</span>
                </div>
                <hr class="my-3" />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold text-dark fs-5">TỔNG TIỀN PHÒNG:</span>
                    <strong class="text-danger fs-3" id="modalTotalFee">0 VNĐ</strong>
                </div>
            </div>
            
            <div class="alert alert-warning border-0 d-flex align-items-center gap-3 mb-0" style="border-radius: 12px; background: #fffbeb;">
                <i class="fa-solid fa-circle-exclamation text-warning fs-4"></i>
                <div class="small">
                    Lưu ý: Thao tác <strong>Xuất viện</strong> sẽ kết thúc quá trình nội trú và chốt tiền phòng vào hồ sơ bệnh án.
                </div>
            </div>
          </div>
          <div class="modal-footer border-0 p-4 pt-0">
            <button type="button" class="btn btn-light px-4 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 10px;">Đóng</button>
            <button type="submit" class="btn btn-success px-4 py-2 fw-bold shadow-sm" style="border-radius: 10px;">
                <i class="fa-solid fa-person-walking-arrow-right me-2"></i>Xác nhận Xuất viện
            </button>
          </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        function showAdmissionModal(id, name, startTimeIso) {
            $('#modalRecordId').val(id);
            $('#modalPatientName').text(name);
            
            var startTime = new Date(startTimeIso);
            $('#modalStartTime').text(startTime.toLocaleString('vi-VN'));
            
            var now = new Date();
            var diffTime = Math.abs(now - startTime);
            var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            if (diffDays < 1) diffDays = 1;
            
            $('#modalDays').text(diffDays + ' ngày');
            $('#modalDaysDetail').text(diffDays + ' ngày');
            
            var totalFee = diffDays * 65000;
            $('#modalTotalFee').text(totalFee.toLocaleString('vi-VN') + ' VNĐ');
            
            var modal = new bootstrap.Modal(document.getElementById('admissionModal'));
            modal.show();
        }
    </script>
}
