@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Quản Lý Giường Bệnh";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Sơ Đồ Giường Bệnh Nôi Trú</h2>
            <p class="text-muted mb-0">Khoa Nội Tổng Hợp - Tầng 3.</p>
        </div>
        <div class="d-flex gap-3">
            <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2"><i class="fa-solid fa-bed me-1"></i> Trống: 4</span>
            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2"><i class="fa-solid fa-bed-pulse me-1"></i> Có BN: 14</span>
            <span class="badge bg-warning bg-opacity-10 text-warning text-dark border border-warning px-3 py-2"><i class="fa-solid fa-broom me-1"></i> Dọn dẹp: 2</span>
        </div>
    </div>

    <div class="glass-card p-4">
        <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Phòng 301 - VIP</h5>
        <div class="row g-3 mb-5">
            <div class="col-md-2">
                <div class="card bg-danger bg-opacity-10 border-danger border-2 h-100 text-center p-3 rounded-4 shadow-sm" style="cursor: pointer;">
                    <i class="fa-solid fa-bed-pulse text-danger fs-1 mb-2"></i>
                    <h6 class="fw-bold mb-1 text-danger">Giường 01</h6>
                    <small class="text-dark fw-bold d-block text-truncate">BN. Lê Văn Hoàng</small>
                </div>
            </div>
             <div class="col-md-2">
                <div class="card bg-success bg-opacity-10 border-success border-2 h-100 text-center p-3 rounded-4 shadow-sm" style="cursor: pointer;">
                    <i class="fa-solid fa-bed text-success fs-1 mb-2"></i>
                    <h6 class="fw-bold mb-1 text-success">Giường 02</h6>
                    <small class="text-success fw-bold d-block">Trống</small>
                </div>
            </div>
        </div>

        <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Phòng 302 - Thường</h5>
        <div class="row g-3">
            <div class="col-md-2">
                <div class="card bg-danger bg-opacity-10 border-danger border-2 h-100 text-center p-3 rounded-4 shadow-sm" style="cursor: pointer;">
                    <i class="fa-solid fa-bed-pulse text-danger fs-1 mb-2"></i>
                    <h6 class="fw-bold mb-1 text-danger">Giường 03</h6>
                    <small class="text-dark fw-bold d-block text-truncate">BN. Nguyễn Hoa</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning bg-opacity-10 border-warning border-2 h-100 text-center p-3 rounded-4 shadow-sm" style="cursor: pointer;">
                    <i class="fa-solid fa-broom text-warning fs-1 mb-2"></i>
                    <h6 class="fw-bold mb-1 text-warning text-dark">Giường 04</h6>
                    <small class="text-dark fw-bold d-block">Đang vệ sinh</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success bg-opacity-10 border-success border-2 h-100 text-center p-3 rounded-4 shadow-sm" style="cursor: pointer;">
                    <i class="fa-solid fa-bed text-success fs-1 mb-2"></i>
                    <h6 class="fw-bold mb-1 text-success">Giường 05</h6>
                    <small class="text-success fw-bold d-block">Trống</small>
                </div>
            </div>
        </div>
    </div>
</div>
