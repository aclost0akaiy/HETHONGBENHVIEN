@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Bảng điều khiển Bác sĩ Kê đơn";
    var waitingRecords = ViewBag.WaitingRecords as List<HeThongBenhVien.Models.MedicalRecord> ?? new List<HeThongBenhVien.Models.MedicalRecord>();
    var prescriptions = ViewBag.Prescriptions as List<HeThongBenhVien.Models.Prescription> ?? new List<HeThongBenhVien.Models.Prescription>();
    var medicines = ViewBag.AllMedicines as List<HeThongBenhVien.Models.Medicine> ?? new List<HeThongBenhVien.Models.Medicine>();
    var lowStockMedicines = ViewBag.LowStockMedicines as List<HeThongBenhVien.Models.Medicine> ?? new List<HeThongBenhVien.Models.Medicine>();
    var expiringMedicines = ViewBag.ExpiringMedicines as List<HeThongBenhVien.Models.Medicine> ?? new List<HeThongBenhVien.Models.Medicine>();
}

<div class="container-fluid p-0">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 800; color: #1e293b;">
                <i class="fa-solid fa-prescription-bottle-medical text-primary me-2"></i>Bảng Điều Khiển Kê Đơn & Kho Dược
            </h2>
            <p class="text-muted mb-0">Hệ thống duyệt toa thuốc y khoa và quản lý tồn kho dược phẩm.</p>
        </div>
    </div>

    <!-- Cảnh báo Kho Dược -->
    @if (lowStockMedicines.Any())
    {
        <div class="alert alert-danger shadow-sm border-0 border-start border-4 border-danger mb-4" role="alert">
            <div class="d-flex align-items-center mb-2">
                <h5 class="fw-bold text-danger mb-0"><i class="fa-solid fa-triangle-exclamation me-2"></i>Cảnh báo: Thuốc dưới mức tồn kho tối thiểu!</h5>
            </div>
            <ul class="mb-0 ps-4">
                @foreach (var m in lowStockMedicines)
                {
                    <li><strong>@m.Name</strong> - Hiện có: <span class="badge bg-danger">@m.StockQuantity @m.Unit</span> (Hạn mức tối thiểu: @m.MinStock @m.Unit)</li>
                }
            </ul>
        </div>
    }

    @if (expiringMedicines.Any())
    {
        <div class="alert alert-warning shadow-sm border-0 border-start border-4 border-warning mb-4" role="alert">
            <div class="d-flex align-items-center mb-2">
                <h5 class="fw-bold text-warning mb-0"><i class="fa-solid fa-clock-rotate-left me-2"></i>Cảnh báo: Thuốc sắp hết hạn sử dụng (trong 30 ngày tới)!</h5>
            </div>
            <ul class="mb-0 ps-4 text-dark">
                @foreach (var m in expiringMedicines)
                {
                    <li><strong>@m.Name</strong> - Hạn SD: <strong>@(m.ExpiryDate?.ToString("dd/MM/yyyy"))</strong></li>
                }
            </ul>
        </div>
    }

    <!-- Tabs Navigation -->
    <ul class="nav nav-pills mb-4 gap-2 bg-light p-2 rounded-3 d-inline-flex border" id="pills-tab" role="tablist" style="border-radius: 12px !important;">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold px-4 py-2.5 d-flex align-items-center gap-2 rounded-3" id="pills-approval-tab" data-bs-toggle="pill" data-bs-target="#pills-approval" type="button" role="tab" aria-controls="pills-approval" aria-selected="true" style="transition: all 0.3s ease;">
                <i class="fa-solid fa-clipboard-check"></i> Duyệt Đơn Thuốc <span class="badge bg-danger rounded-pill">@waitingRecords.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2.5 d-flex align-items-center gap-2 rounded-3" id="pills-inventory-tab" data-bs-toggle="pill" data-bs-target="#pills-inventory" type="button" role="tab" aria-controls="pills-inventory" aria-selected="false" style="transition: all 0.3s ease;">
                <i class="fa-solid fa-warehouse"></i> Quản Lý Kho Thuốc <span class="badge bg-secondary rounded-pill">@medicines.Count</span>
            </button>
        </li>
    </ul>

    <!-- Tabs Content -->
    <div class="tab-content" id="pills-tabContent">
        <!-- TAB 1: DUYỆT ĐƠN THUỐC -->
        <div class="tab-pane fade show active" id="pills-approval" role="tabpanel" aria-labelledby="pills-approval-tab">
            <div class="row g-4">
                <!-- Chờ Kê Đơn -->
                <div class="col-lg-6">
                    <div class="glass-card p-4 h-100 shadow-sm border border-opacity-10" style="border-radius: 16px; background: white;">
                        <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-spinner text-warning spin-slow"></i> Bệnh Nhân Chờ Kê Đơn
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Bệnh nhân</th>
                                        <th>Chẩn đoán</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (waitingRecords.Any())
                                    {
                                        @foreach (var item in waitingRecords)
                                        {
                                            <tr>
                                                <td class="fw-bold">
                                                    @item.Appointment?.Patient?.FullName <br />
                                                    <small class="text-muted">Mã BN: @item.Appointment?.Patient?.PatientCode</small>
                                                </td>
                                                <td>
                                                    <span class="text-muted d-block text-truncate" style="max-width: 180px;" title="@item.Diagnosis">
                                                        @(string.IsNullOrEmpty(item.Diagnosis) ? "Chưa có chẩn đoán" : item.Diagnosis)
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = item.Id })" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">
                                                        <i class="fa-solid fa-file-prescription me-1"></i> Kê đơn
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center py-5 text-muted">
                                                <i class="fa-solid fa-circle-check text-success fa-2x mb-2"></i>
                                                <p class="mb-0">Đã giải quyết sạch danh sách chờ kê đơn!</p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Đã Kê Đơn -->
                <div class="col-lg-6">
                    <div class="glass-card p-4 h-100 shadow-sm border border-opacity-10" style="border-radius: 16px; background: white;">
                        <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-square-check text-success"></i> Đơn Thuốc Đã Duyệt Gần Đây
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Bệnh nhân</th>
                                        <th>Chẩn đoán</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (prescriptions.Any())
                                    {
                                        @foreach (var item in prescriptions.Take(10))
                                        {
                                            <tr>
                                                <td class="fw-bold">
                                                    @item.MedicalRecord?.Appointment?.Patient?.FullName <br />
                                                    <small class="text-muted">Mã BN: @item.MedicalRecord?.Appointment?.Patient?.PatientCode</small>
                                                </td>
                                                <td>
                                                    <span class="text-muted d-block text-truncate" style="max-width: 180px;" title="@item.MedicalRecord?.Diagnosis">
                                                        @item.MedicalRecord?.Diagnosis
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <div class="d-flex gap-2 justify-content-center">
                                                        <a href="@Url.Action("KeDonThuoc", "Doctor", new { id = item.MedicalRecordId })" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-bold">
                                                            Sửa toa
                                                        </a>
                                                        <a href="@Url.Action("InToaThuoc", "Doctor", new { id = item.Id })" target="_blank" class="btn btn-sm btn-outline-info rounded-pill px-3 fw-bold">
                                                            <i class="fa-solid fa-print"></i> In
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center py-5 text-muted">
                                                Chưa duyệt đơn thuốc nào gần đây.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2: QUẢN LÝ KHO THUỐC -->
        <div class="tab-pane fade" id="pills-inventory" role="tabpanel" aria-labelledby="pills-inventory-tab">
            <!-- Widgets Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="glass-card p-3 border-start border-4 border-primary shadow-sm" style="border-radius: 12px; background: white;">
                        <p class="text-muted fw-bold mb-1 small">Tổng Danh Mục Thuốc</p>
                        <h3 class="fw-bold m-0 text-primary">@medicines.Count</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="glass-card p-3 border-start border-4 border-success shadow-sm" style="border-radius: 12px; background: white;">
                        <p class="text-muted fw-bold mb-1 small">Tổng Số Lượng Tồn Kho</p>
                        <h3 class="fw-bold m-0 text-success">@medicines.Sum(m => m.StockQuantity)</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="glass-card p-3 border-start border-4 border-danger shadow-sm" style="border-radius: 12px; background: white;">
                        <p class="text-muted fw-bold mb-1 small">Thuốc Sắp Hết Tồn Kho</p>
                        <h3 class="fw-bold m-0 text-danger">@lowStockMedicines.Count</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="glass-card p-3 border-start border-4 border-warning shadow-sm" style="border-radius: 12px; background: white;">
                        <p class="text-muted fw-bold mb-1 small">Thuốc Sắp Hết Hạn SD</p>
                        <h3 class="fw-bold m-0 text-warning">@expiringMedicines.Count</h3>
                    </div>
                </div>
            </div>

            <!-- Inventory Panel -->
            <div class="glass-card p-4 shadow-sm border border-opacity-10" style="border-radius: 16px; background: white;">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h5 class="fw-bold text-dark m-0">Danh Sách Kho Dược Phẩm</h5>
                    <div class="d-flex gap-2">
                        <input type="text" id="medSearch" class="form-control form-control-sm rounded-pill px-3" placeholder="Tìm kiếm thuốc..." style="width: 200px;" />
                        <button class="btn btn-primary btn-sm shadow-sm rounded-pill px-3 fw-bold" data-bs-toggle="modal" data-bs-target="#addMedModal">
                            <i class="fas fa-plus me-1"></i> Thêm Thuốc
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="inventoryTable">
                        <thead class="table-light">
                            <tr>
                                <th>Tên Thuốc</th>
                                <th>Danh Mục</th>
                                <th>Đơn Vị</th>
                                <th>Giá bán</th>
                                <th>Tồn Kho</th>
                                <th>Hạn Sử Dụng</th>
                                <th>Nhà Sản Xuất</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (medicines.Any())
                            {
                                @foreach (var item in medicines)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@item.Name</td>
                                        <td><span class="badge bg-info bg-opacity-10 text-info">@item.Category</span></td>
                                        <td>@item.Unit</td>
                                        <td class="text-success fw-bold">@item.Price.ToString("N0") đ</td>
                                        <td>
                                            @if (item.StockQuantity <= item.MinStock)
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">@item.StockQuantity @item.Unit ⚠️</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">@item.StockQuantity @item.Unit</span>
                                            }
                                        </td>
                                        <td>@(item.ExpiryDate.HasValue ? item.ExpiryDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                        <td class="small text-muted">@item.Manufacturer</td>
                                        <td class="text-center">
                                            <form asp-action="KeDonXoaThuoc" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa thuốc này khỏi kho?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2.5">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted">Chưa có dữ liệu thuốc. Vui lòng thêm thuốc mới.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Thêm Thuốc -->
<div class="modal fade" id="addMedModal" tabindex="-1" aria-labelledby="addMedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header bg-primary text-white" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <h5 class="modal-title fw-bold" id="addMedModalLabel"><i class="fas fa-plus me-2"></i>Thêm Thuốc Vào Kho</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="KeDonThemThuoc" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tên Thuốc / Biệt Dược</label>
                            <input name="Name" class="form-control rounded-3" placeholder="Nhập tên thuốc..." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Danh Mục</label>
                            <select name="Category" class="form-select rounded-3">
                                <option>Kháng sinh</option>
                                <option>Giảm đau, Hạ sốt</option>
                                <option>Tim mạch</option>
                                <option>Tiêu hóa</option>
                                <option>Hô hấp</option>
                                <option>Vitamins & Bổ dưỡng</option>
                                <option>Kháng viêm</option>
                                <option>Khác</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Đơn Vị</label>
                            <select name="Unit" class="form-select rounded-3">
                                <option>Viên</option>
                                <option>Hộp</option>
                                <option>Chai</option>
                                <option>Ống</option>
                                <option>Gói</option>
                                <option>Tuýp</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                            <input name="Price" type="number" class="form-control rounded-3" value="1000" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Số lượng nhập kho</label>
                            <input name="StockQuantity" type="number" class="form-control rounded-3" value="100" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Hạn mức tối thiểu</label>
                            <input name="MinStock" type="number" class="form-control rounded-3" value="10" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Hạn Sử Dụng</label>
                            <input name="ExpiryDate" type="date" class="form-control rounded-3" value="@DateTime.Now.AddYears(2).ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Nhà Sản Xuất</label>
                            <input name="Manufacturer" class="form-control rounded-3" placeholder="Ví dụ: Dược Hậu Giang..." />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Lưu nhập kho</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .spin-slow {
        animation: spin 3s linear infinite;
    }
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    .nav-pills .nav-link {
        color: #4b5563;
        background: #f3f4f6;
    }
    .nav-pills .nav-link.active {
        color: white;
        background-color: #0284c7 !important;
    }
    .btn-soft-primary {
        background-color: rgba(37, 99, 235, 0.1);
        color: #2563eb;
    }
    .btn-soft-primary:hover {
        background-color: #2563eb;
        color: white;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('medSearch').addEventListener('keyup', function () {
            var input = this.value.toLowerCase();
            var rows = document.querySelectorAll('#inventoryTable tbody tr');
            rows.forEach(function (row) {
                var text = row.querySelector('td').textContent.toLowerCase();
                if (text.includes(input)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
