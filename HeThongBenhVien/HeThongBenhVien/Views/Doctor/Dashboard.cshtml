                        </div>
                        <!-- Func 5 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("KeDonThuoc", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-pills"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Kê Đơn Thuốc</div>
                            </a>
                        </div>
                        <!-- Func 6 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("ChiDinhXetNghiem", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-flask"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Chỉ Định XN</div>
                            </a>
                        </div>
                        <!-- Func 7 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("KetQuaCanLamSang", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-microscope"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Kết Quả CLS</div>
                            </a>
                        </div>
                        <!-- Func 8 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("SinhHieu", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-heart-pulse"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Sinh Hiệu</div>
                            </a>
                        </div>
                        <!-- Func 9 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("LichSuKham", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-clock-rotate-left"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Lịch Sử Khám</div>
                            </a>
                        </div>
                        <!-- Func 10 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("LichMo", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-dark bg-opacity-10 text-dark rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-scalpel"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Lịch Mổ</div>
                            </a>
                        </div>
                        <!-- Func 11 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("ThongKe", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-chart-pie"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Thống Kê</div>
