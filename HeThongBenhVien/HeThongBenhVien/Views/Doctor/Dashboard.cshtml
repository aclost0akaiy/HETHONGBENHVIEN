            <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="modal-header border-0 bg-success bg-opacity-10" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold text-success" id="confirmOnlineModalLabel"><i class="fa-solid fa-check-circle me-2"></i>Xác Nhận & Gửi SMS</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="ConfirmOnlineAppointment" asp-controller="Doctor" method="post">
                    <div class="modal-body p-4">
                        <input type="hidden" id="confirmAppointmentId" name="appointmentId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Bệnh nhân</label>
                            <input type="text" id="confirmPatientName" class="form-control" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ngày và Giờ Khám</label>
                            <input type="datetime-local" id="confirmAppointmentTime" name="newAppointmentTime" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nội dung SMS</label>
                            <textarea name="message" class="form-control" rows="3" placeholder="Ví dụ: Bệnh viện ABC xác nhận lịch hẹn của bạn vào lúc..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success px-4"><i class="fa-solid fa-paper-plane me-2"></i> Xác nhận & Gửi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetVietnameseDayOfWeek(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "Thứ 2",
            DayOfWeek.Tuesday => "Thứ 3",
            DayOfWeek.Wednesday => "Thứ 4",
            DayOfWeek.Thursday => "Thứ 5",
            DayOfWeek.Friday => "Thứ 6",
            DayOfWeek.Saturday => "Thứ 7",
            DayOfWeek.Sunday => "Chủ Nhật",
            _ => string.Empty,
        };
    }
}

