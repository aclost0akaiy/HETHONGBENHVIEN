                        <!-- Func 4 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("HoSoBenhAn", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-notes-medical"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Hồ Sơ BA</div>
