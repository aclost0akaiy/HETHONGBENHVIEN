    <!-- Modal Xác Nhận Bệnh Nhân -->
    <div class="modal fade" id="identifyPatientModal" tabindex="-1" aria-labelledby="identifyPatientModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="modal-header border-0 bg-success bg-opacity-10" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold text-success" id="identifyPatientModalLabel"><i class="fa-solid fa-user-check me-2"></i>Xác Nhận Bệnh Nhân</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <p class="text-muted mb-4">Sử dụng Camera để xác định nhanh danh tính bệnh nhân đã có trong hệ thống.</p>
                    <div class="mb-3 d-flex gap-2">
                        <button type="button" class="btn btn-outline-info flex-grow-1" onclick="startIdentifyScan('qr')"><i class="fas fa-qrcode me-2"></i>Mã CCCD/BHYT</button>
                        <button type="button" class="btn btn-outline-secondary flex-grow-1" onclick="startIdentifyScan('face')"><i class="fas fa-user-viewfinder me-2"></i>Khuôn Mặt</button>
                    </div>
                    <div id="identifyScanArea" class="mb-3 text-center d-none">
                        <div class="scanner-container mx-auto" style="position: relative; width: 100%; max-width: 640px; height: 480px; background: #000; border-radius: 10px; overflow: hidden; border: 3px solid #10b981; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                            <div id="identifyVideoPlaceholder" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/camera.svg') center/80px no-repeat #1e293b;">
                                <video id="identifyCameraFeed" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; display: none;"></video>
                            </div>
                            <div class="scanner-laser"></div>
                            <div class="scanner-corner corner-tl"></div>
                            <div class="scanner-corner corner-tr"></div>
                            <div class="scanner-corner corner-bl"></div>
                            <div class="scanner-corner corner-br"></div>
                            <div style="position: absolute; bottom: 10px; width: 100%; color: #fff; font-size: 14px; text-shadow: 1px 1px 2px #000; z-index: 10;" id="identifyScanText">
                                <i class="fas fa-circle text-danger blink me-1"></i> Đang khởi động camera...
                            </div>
                        </div>
                        <button type="button" class="btn btn-light mt-3 fw-bold px-4 rounded-pill border" onclick="cancelIdentifyScan()"><i class="fas fa-times"></i> Hủy quét</button>
                    </div>
                    <div id="identifyResult" class="mt-4 text-start d-none p-3 bg-light rounded border border-success">
                        <h5 class="text-success fw-bold mb-3"><i class="fas fa-check-circle me-2"></i>Đã xác nhận</h5>
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-user-circle fa-2x text-secondary me-3"></i>
                            <div>
                                <h6 class="mb-0 fw-bold" id="resPatientName">Nguyễn Văn A</h6>
                                <small class="text-muted" id="resPatientCode">BN12345</small>
                            </div>
                        </div>
                        <p class="mb-1"><small class="fw-bold">Giới tính:</small> <span id="resGender">Nam</span></p>
                        <p class="mb-1"><small class="fw-bold">Tuổi:</small> <span id="resAge">30</span></p>
                        <p class="mb-0"><small class="fw-bold">Mức độ khớp ảnh:</small> <span id="resConfidence" class="text-success">95%</span></p>
                        
                        <div class="row mt-3 mb-2 text-center" id="resImagesContainer" style="display: none;">
                            <div class="col-6">
                                <small class="text-muted fw-bold mb-1 d-block">Ảnh vừa quét</small>
                                <img id="resCapturedImage" src="" class="img-fluid rounded border shadow-sm" style="height: 120px; width: 100%; object-fit: cover;" />
                            </div>
                            <div class="col-6">
                                <small class="text-muted fw-bold mb-1 d-block">Ảnh đã lưu</small>
                                <img id="resStoredImage" src="" class="img-fluid rounded border shadow-sm" style="height: 120px; width: 100%; object-fit: cover;" />
                            </div>
                        </div>
                        <div class="mt-3 pt-3 border-top d-flex gap-2">
                            <a href="#" id="resPatientRecordBtn" class="btn btn-outline-primary flex-grow-1"><i class="fas fa-file-medical me-2"></i>Hồ Sơ Bệnh Án</a>
                            <button type="button" class="btn btn-success flex-grow-1" data-bs-dismiss="modal"><i class="fas fa-check me-2"></i>Hoàn tất</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Khám Bệnh Nhân Mới -->
    <div class="modal fade" id="addAppointmentModal" tabindex="-1" aria-labelledby="addAppointmentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="modal-header border-0 bg-primary bg-opacity-10" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold text-primary" id="addAppointmentModalLabel"><i class="fa-solid fa-notes-medical me-2"></i>Khám Bệnh Nhân Mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="addAppointmentForm" asp-action="CreateAppointment" asp-controller="Doctor" method="post">
                    <input type="hidden" id="FaceDataInput" name="FaceData" value="" />
                    <input type="hidden" id="CCCDInput" name="CCCD" value="" />
                    <div class="modal-body p-4">
                        <div class="mb-3 d-flex gap-2">
                            <button type="button" class="btn btn-outline-info flex-grow-1" onclick="startDoctorScan('qr')"><i class="fas fa-qrcode me-2"></i>Quét CCCD/BHYT</button>
                            <button type="button" class="btn btn-outline-secondary flex-grow-1" onclick="startDoctorScan('face')"><i class="fas fa-user-viewfinder me-2"></i>Quét Khuôn Mặt</button>
                        </div>
                        <div id="doctorScanArea" class="mb-3 text-center d-none">
                            <div class="scanner-container mx-auto" style="position: relative; width: 100%; max-width: 320px; height: 240px; background: #000; border-radius: 10px; overflow: hidden; border: 3px solid #3b82f6; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                                <div id="videoPlaceholder" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/camera.svg') center/50px no-repeat #1e293b;">
                                    <video id="cameraFeed" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; display: none;"></video>
                                </div>
                                <div class="scanner-laser"></div>
                                <div class="scanner-corner corner-tl"></div>
                                <div class="scanner-corner corner-tr"></div>
                                <div class="scanner-corner corner-bl"></div>
                                <div class="scanner-corner corner-br"></div>
                                <div style="position: absolute; bottom: 10px; width: 100%; color: #fff; font-size: 14px; text-shadow: 1px 1px 2px #000; z-index: 10;" id="doctorScanText">
                                    <i class="fas fa-circle text-danger blink me-1"></i> Đang khởi động camera...
                                </div>
                            </div>
                            <button type="button" class="btn btn-success mt-3 fw-bold px-4 rounded-pill shadow-sm" onclick="processScanResult()"><i class="fas fa-camera me-2"></i>Chụp & Nhận Diện</button>
                            <button type="button" class="btn btn-light mt-3 fw-bold px-4 rounded-pill border" onclick="cancelScan()"><i class="fas fa-times"></i></button>
                        </div>
                        
                        <canvas id="scanCanvas" style="display:none;"></canvas>
                        <div class="mb-4 d-flex justify-content-center gap-4">
                            <div id="capturedQRArea" class="border border-2 border-dashed rounded bg-light d-flex flex-column align-items-center justify-content-center text-muted" style="width: 120px; height: 120px; opacity: 0.5; transition: all 0.3s; background-size: cover; background-position: center; position: relative; overflow: hidden;">
                                <i class="fas fa-qrcode fa-2x mb-2" id="iconQR" style="z-index: 2;"></i>
                                <div style="font-size: 0.75rem; z-index: 2;" class="fw-bold bg-white bg-opacity-75 px-2 py-1 rounded shadow-sm" id="textQR">Mã CCCD/BHYT</div>
                            </div>
                            <div id="capturedFaceArea" class="border border-2 border-dashed rounded bg-light d-flex flex-column align-items-center justify-content-center text-muted" style="width: 120px; height: 120px; opacity: 0.5; transition: all 0.3s; background-size: cover; background-position: center; position: relative; overflow: hidden;">
                                <i class="fas fa-user fa-2x mb-2" id="iconFace" style="z-index: 2;"></i>
                                <div style="font-size: 0.75rem; z-index: 2;" class="fw-bold bg-white bg-opacity-75 px-2 py-1 rounded shadow-sm" id="textFace">Khuôn mặt</div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-secondary">Tên bệnh nhân</label>
                                <input type="text" class="form-control" name="PatientName" placeholder="Nhập tên bệnh nhân" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Giới tính</label>
                                <select class="form-select" name="Gender" required>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Tuổi</label>
                                <input type="number" class="form-control" name="Age" placeholder="Nhập tuổi" min="0" max="150" required>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-secondary">Lý do khám</label>
                                <input type="text" class="form-control" name="Reason" placeholder="Nhập lý do khám" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Thời gian khám</label>
                                <input type="datetime-local" class="form-control" name="AppointmentTime" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Trạng thái</label>
                                <select class="form-select" name="Status">
                                    <option value="0">Chưa đến</option>
                                    <option value="1" selected>Đang chờ</option>
                                    <option value="2">Đang khám</option>
                                    <option value="6">Ưu tiên</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy bỏ</button>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: 8px;"><i class="fa-solid fa-plus me-2"></i>Tạo Lịch Khám</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Xác Nhận Lịch Đặt Trực Tuyến -->
    <div class="modal fade" id="confirmOnlineModal" tabindex="-1" aria-labelledby="confirmOnlineModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="modal-header border-0 bg-success bg-opacity-10" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold text-success" id="confirmOnlineModalLabel"><i class="fa-solid fa-check-circle me-2"></i>Xác Nhận & Gửi SMS</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="ConfirmOnlineAppointment" asp-controller="Doctor" method="post">
                    <div class="modal-body p-4">
                        <input type="hidden" id="confirmAppointmentId" name="appointmentId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Bệnh nhân</label>
                            <input type="text" id="confirmPatientName" class="form-control" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ngày và Giờ Khám</label>
                            <input type="datetime-local" id="confirmAppointmentTime" name="newAppointmentTime" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nội dung SMS</label>
                            <textarea name="message" class="form-control" rows="3" placeholder="Ví dụ: Bệnh viện ABC xác nhận lịch hẹn của bạn vào lúc..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success px-4"><i class="fa-solid fa-paper-plane me-2"></i> Xác nhận & Gửi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetVietnameseDayOfWeek(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "Thứ 2",
            DayOfWeek.Tuesday => "Thứ 3",
            DayOfWeek.Wednesday => "Thứ 4",
            DayOfWeek.Thursday => "Thứ 5",
            DayOfWeek.Friday => "Thứ 6",
            DayOfWeek.Saturday => "Thứ 7",
            DayOfWeek.Sunday => "Chủ Nhật",
            _ => string.Empty,
        };
    }
}

