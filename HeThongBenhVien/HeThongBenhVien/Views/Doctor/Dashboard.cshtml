                            </a>
                        </div>
                         <!-- Func 13 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("HenTaiKham", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-rotate-right"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Hẹn Tái Khám</div>
                            </a>
                        </div>
                         <!-- Func 14 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("QuanLyGiuong", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-bed"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">QL Giường</div>
                            </a>
                        </div>
                         <!-- Func 15 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("HoiChanOnline", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-video"></i>
