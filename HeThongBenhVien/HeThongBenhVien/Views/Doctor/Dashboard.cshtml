@using HeThongBenhVien.Models
@model DoctorDashboardViewModel

@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Dashboard Bác sĩ";
}

<div class="container-fluid p-0">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Chào buổi sáng, BS. Nguyễn Văn A!</h2>
            <p class="text-muted mb-0">Dưới đây là tổng quan lịch trình và công việc của bạn trong ngày hôm nay.</p>
        </div>
        <div>
            <button class="btn btn-primary px-4 py-2" style="border-radius: 10px; font-weight: 500;" data-bs-toggle="modal" data-bs-target="#addAppointmentModal">
                <i class="fa-solid fa-plus me-2"></i> Khám Bệnh Nhân Mới
            </button>
        </div>
    </div>

    <!-- Quick Stats Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Tổng bệnh nhân chưa khám</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.TodayPatientsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(14, 165, 233, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0ea5e9; font-size: 20px;">
                        <i class="fa-solid fa-users"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span class="text-success"><i class="fa-solid fa-arrow-trend-up"></i> +3</span> so với hôm qua
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Đã khám xong</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.CompletedPatientsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(16, 185, 129, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #10b981; font-size: 20px;">
                        <i class="fa-solid fa-check-double"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span class="text-success">50%</span> tiến độ ngày
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Trạng thái chờ khám</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.WaitingResultsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(245, 158, 11, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #f59e0b; font-size: 20px;">
                        <i class="fa-solid fa-flask-vial"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span>Cập nhật 5 phút trước</span>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1" style="font-size: 0.8rem;">Trạng thái ưu tiên</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.EmergencyCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(239, 68, 68, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ef4444; font-size: 20px;">
                        <i class="fa-solid fa-truck-medical"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-danger font-weight-bold">
                    <i class="fa-solid fa-circle-exclamation blink"></i> Yêu cầu xử lý ngay
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row">
        <!-- Patient Queue -->
        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="glass-card h-100">
                <div class="d-flex justify-content-between align-items-center p-4 border-bottom">
                    <h6 class="m-0 font-weight-bold" style="color: #1e293b; font-weight: 600;">Danh sách chờ khám tiếp theo</h6>
                    <a href="#" class="text-decoration-none" style="color: #0ea5e9; font-size: 14px; font-weight: 500;">Xem tất cả</a>
                </div>
                <div class="p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 14px;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 border-0">STT</th>
                                    <th class="border-0">Bệnh nhân</th>
                                    <th class="border-0">Lý do khám</th>
                                    <th class="border-0">Thời gian</th>
                                    <th class="border-0">Trạng thái</th>
                                    <th class="pe-4 border-0 text-end">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int stt = 1; }
                                @foreach (var item in Model.UpcomingAppointments)
                                {
                                    string nameParts = item.Patient?.FullName?.Trim() ?? "Unknown";
                                    string initials = "UK";
                                    if (!string.IsNullOrEmpty(nameParts))
                                    {
                                        var words = nameParts.Split(' ');
                                        if (words.Length > 1) {
                                            initials = $"{words[0][0]}{words[words.Length-1][0]}".ToUpper();
                                        } else {
                                            initials = nameParts.Substring(0, 1).ToUpper();
                                        }
                                    }

                                    string statusBadgeClass = item.Status switch
                                    {
                                        0 => "bg-secondary",
                                        1 => "bg-warning text-dark",
                                        2 => "bg-primary",
                                        3 => "bg-info text-dark",
                                        4 => "bg-success",
                                        6 => "bg-danger",
                                        _ => "bg-secondary"
                                    };

                                    string statusText = item.Status switch
                                    {
                                        0 => "Chưa đến",
                                        1 => "Đang chờ",
                                        2 => "Đang khám",
                                        3 => "Có KQ XN",
                                        4 => "Đã khám xong",
                                        6 => "Ưu tiên",
                                        _ => "Không xác định"
                                    };

                                    <tr>
                                        <td class="ps-4 font-weight-bold text-primary">@(stt.ToString("D2"))</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px; color: #64748b; font-weight: bold;">@initials</div>
                                                <div>
                                                    <div style="font-weight: 600; color: #334155;">@item.Patient?.FullName</div>
                                                    <div class="text-muted" style="font-size: 12px;">@item.Patient?.Gender - @item.Patient?.Age T - @item.Patient?.PatientCode</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@item.Reason</td>
                                        <td>@item.AppointmentTime.ToString("hh:mm tt")</td>
                                        <td>
                                            <span class="badge @statusBadgeClass rounded-pill">@statusText</span>
                                            <a href="@Url.Action("SinhHieu", "Doctor", new { id = item.Id })" class="ms-1 text-danger" title="Theo dõi sinh hiệu">
                                                <i class="fa-solid fa-heart-pulse"></i>
                                            </a>
                                        </td>
                                        <td class="pe-4 text-end">
                                            @if (item.Status == 1 || item.Status == 2 || item.Status == 3 || item.Status == 6)
                                            {
                                                <a href="@Url.Action("KhamBenh", "Doctor", new { id = item.Id })" class="btn btn-sm btn-primary rounded-pill px-3">Khám ngay</a>
                                            }
                                            else
                                            {
                                                <a href="#" class="btn btn-sm btn-outline-primary rounded-pill px-3">Chi tiết</a>
                                            }
                                        </td>
                                    </tr>
                                    stt++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Access Menu (Matrix of 15 functionalities) -->
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="glass-card h-100">
                <div class="p-4 border-bottom">
                    <h6 class="m-0 font-weight-bold" style="color: #1e293b; font-weight: 600;">Hệ sinh thái Quản lý Bệnh nhân</h6>
                </div>
                <div class="p-4">
                    <div class="row g-3">
                        <!-- Func 1 -->
                        <div class="col-4 text-center">
                            <a href="@Url.Action("DanhSach", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-users"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">DS Bệnh Nhân</div>
                            </a>
                        </div>
                        <!-- Func 2 -->
                        <div class="col-4 text-center">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#addAppointmentModal" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-user-plus"></i>
                                </div>
                                <div style="font-size: 11px; color: #475569; font-weight: 500;">Tiếp nhận Mới</div>
