@using HeThongBenhVien.Models
@model DoctorDashboardViewModel

@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Dashboard Bác sĩ";
}

<div class="container-fluid p-0">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Chào buổi sáng, BS. Nguyễn Văn A!</h2>
            <p class="text-muted mb-0">Dưới đây là tổng quan lịch trình và công việc của bạn trong ngày hôm nay.</p>
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto mt-3 mt-md-0">
            <button class="btn btn-success px-4 py-2 flex-grow-1" style="border-radius: 10px; font-weight: 500; white-space: nowrap;" data-bs-toggle="modal" data-bs-target="#identifyPatientModal">
                <i class="fa-solid fa-user-check me-2"></i> Xác Nhận Bệnh Nhân
            </button>
            <button class="btn btn-primary px-4 py-2 flex-grow-1" style="border-radius: 10px; font-weight: 500; white-space: nowrap;" data-bs-toggle="modal" data-bs-target="#addAppointmentModal">
                <i class="fa-solid fa-plus me-2"></i> Khám Bệnh Nhân Mới
            </button>
        </div>
    </div>



    <!-- Quick Stats Cards -->
    <div class="row mb-4">
        <div class="col-xl-4 col-md-4 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Tổng bệnh nhân chưa khám</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.TodayPatientsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(14, 165, 233, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0ea5e9; font-size: 20px;">
                        <i class="fa-solid fa-users"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span class="text-success"><i class="fa-solid fa-arrow-trend-up"></i> +3</span> so với hôm qua
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-4 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Đã khám xong</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.CompletedPatientsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(16, 185, 129, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #10b981; font-size: 20px;">
                        <i class="fa-solid fa-check-double"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span class="text-success">50%</span> tiến độ ngày
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-4 mb-4">
            <div class="glass-card hover-card p-4 h-100 border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Lịch khám chưa xác nhận</div>
                        <div class="h3 mb-0 font-weight-bold text-gray-800" style="color: #0f172a; font-weight: 700;">@Model.WaitingResultsCount</div>
                    </div>
                    <div class="icon-circle" style="background: rgba(245, 158, 11, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #f59e0b; font-size: 20px;">
                        <i class="fa-solid fa-flask-vial"></i>
                    </div>
                </div>
                <div class="mt-3 text-sm text-muted">
                    <span>Cập nhật 5 phút trước</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-xl-8 col-lg-7">
            <div class="glass-card h-100 p-4 border-top border-4 border-info">
                <h6 class="font-weight-bold text-info mb-3"><i class="fa-solid fa-chart-line"></i> Lưu Lượng Bệnh Nhân 7 Ngày Qua</h6>
                <div style="position: relative; height: 220px; width: 100%;">
                    <canvas id="patientsChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-5">
            <div class="glass-card h-100 p-4 border-top border-4 border-warning">
                <h6 class="font-weight-bold text-warning mb-3"><i class="fa-solid fa-chart-pie"></i> Tỉ Lệ Bệnh Theo Chuyên Khoa</h6>
                <div style="position: relative; height: 220px; width: 100%;">
                    <canvas id="departmentsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row">
        <div class="col-xl-7 mb-4">
            <div class="glass-card h-100">
                <!-- Nav Tabs -->
                <!-- Nav Pills (Button-like tabs) -->
                <ul class="nav nav-pills gap-2" role="tablist" style="padding: 1rem;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active px-4 py-2 rounded-pill fw-bold shadow-sm" id="schedule-tab" data-bs-toggle="tab" data-bs-target="#schedule-pane" type="button" role="tab" aria-controls="schedule-pane" aria-selected="true" style="transition: all 0.3s;">
                            <i class="fa-solid fa-calendar-days me-2"></i>Lịch trực tháng
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4 py-2 rounded-pill fw-bold shadow-sm" id="appointment-tab" data-bs-toggle="tab" data-bs-target="#appointment-pane" type="button" role="tab" aria-controls="appointment-pane" aria-selected="false" style="transition: all 0.3s; background-color: #f1f5f9; color: #64748b;">
                            <i class="fa-solid fa-list-check me-2"></i>Danh sách chờ khám
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4 py-2 rounded-pill fw-bold shadow-sm" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-pane" type="button" role="tab" aria-controls="pending-pane" aria-selected="false" style="transition: all 0.3s; background-color: #f1f5f9; color: #64748b;">
                            <i class="fa-solid fa-globe me-2"></i>BN Đặt Lịch Khám
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4 py-2 rounded-pill fw-bold shadow-sm" id="confirmed-tab" data-bs-toggle="tab" data-bs-target="#confirmed-pane" type="button" role="tab" aria-controls="confirmed-pane" aria-selected="false" style="transition: all 0.3s; background-color: #f1f5f9; color: #64748b;">
                            <i class="fa-solid fa-check-double me-2"></i>Lịch Hẹn Khám
                        </button>
                    </li>
                </ul>
                
                <style>
                    .nav-pills .nav-link.active {
                        background-color: var(--primary-color) !important;
                        color: white !important;
                    }
                    .nav-pills .nav-link:not(.active):hover {
                        background-color: #e2e8f0 !important;
                    }
                </style>

                <!-- Tab Content -->
                <div class="tab-content">
                    <!-- Schedule Tab -->
                    <div class="tab-pane fade show active" id="schedule-pane" role="tabpanel" aria-labelledby="schedule-tab">
                        <div class="p-4">
                            <form asp-action="Dashboard" method="get" class="bg-white p-3 mb-4 shadow-sm d-flex gap-2 align-items-center flex-wrap" style="border-radius: 12px; border: 1px solid #eaecf4;">
                                <div class="input-group" style="flex: 1 1 100%; min-width: 220px;">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                                    <input type="text" name="searchString" value="@Model.SearchString" class="form-control bg-light border-start-0" placeholder="Tìm kiếm bác sĩ..." />
                                </div>
                                <select name="month" class="form-select bg-light border-0" style="max-width: 120px;" onchange="this.form.submit()">
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i" selected="@(i == Model.CurrentMonth ? "selected" : null)">Tháng @i</option>
                                    }
                                </select>
                                <select name="year" class="form-select bg-light border-0" style="max-width: 110px;" onchange="this.form.submit()">
                                    @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 1; y++)
                                    {
                                        <option value="@y" selected="@(y == Model.CurrentYear ? "selected" : null)">@y</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm px-4">Lọc</button>
                            </form>

                            @{ 
                                int daysInMonth = DateTime.DaysInMonth(Model.CurrentYear, Model.CurrentMonth);
                                var dates = Enumerable.Range(1, daysInMonth).Select(d => new DateTime(Model.CurrentYear, Model.CurrentMonth, d)).ToList();
                                var definedShifts = new List<string> {
                                    "Ca 1 (06:00 - 09:00)",
                                    "Ca 2 (09:00 - 12:00)",
                                    "Ca 3 (12:00 - 15:00)",
                                    "Ca 4 (15:00 - 18:00)",
                                    "Ca 5 (18:00 - 21:00)",
                                    "Ca 6 (21:00 - 24:00)",
                                    "Ca 7 (00:00 - 06:00)"
                                };
                            }

                            <div class="custom-scroll" style="max-height: 500px; overflow-x:auto;">
                                <table class="table table-bordered schedule-table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="shift-col sticky-col text-center align-middle">
                                                <div class="text-primary fw-bold" style="font-size: 1rem;">Ngày & Thứ</div>
                                                <small class="text-muted fw-normal" style="font-size: 0.75rem;">7 ca</small>
                                            </th>
                                            @foreach (var date in dates)
                                            {
                                                <th class="date-col text-center">
                                                    <div class="fs-6 fw-bold @(date.Date == DateTime.Today ? "text-primary" : "text-dark")">
                                                        @date.ToString("dd/MM")
                                                    </div>
                                                    <div class="text-muted fw-normal small">@GetVietnameseDayOfWeek(date)</div>
                                                </th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var shift in definedShifts)
                                        {
                                            <tr>
                                                <td class="shift-col sticky-col align-middle">
                                                    <div class="fw-bold text-dark">@shift.Substring(0, 4)</div>
                                                    <div class="text-muted small">@shift.Substring(5)</div>
                                                </td>
                                                @foreach (var date in dates)
                                                {
                                                    <td class="schedule-cell">
                                                        @{ 
                                                            var matchedSchedules = Model.WorkSchedules
                                                                .Where(m => m.WorkDate.Date == date.Date && (m.ShiftName ?? string.Empty).StartsWith(shift.Substring(0, 4)))
                                                                .OrderBy(m => m.User?.FullName)
                                                                .ToList();
                                                        }
                                                        @if (matchedSchedules.Any())
                                                        {
                                                            <div class="d-flex flex-column gap-1 mt-1">
                                                                @foreach (var item in matchedSchedules)
                                                                {
                                                                    var isCurrent = Model.CurrentUserId.HasValue && item.UserId == Model.CurrentUserId.Value;
                                                                    var displayName = item.User?.FullName ?? item.User?.Username ?? "Không xác định";
                                                                    <span class="badge rounded-pill @(isCurrent ? "bg-success text-white" : "bg-light text-dark")" style="font-size:0.75rem;">
                                                                        <i class="fa-solid fa-user-doctor me-1"></i> @displayName
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="text-muted" style="font-size: 12px;">Trống</div>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Appointment Tab -->
                    <div class="tab-pane fade" id="appointment-pane" role="tabpanel" aria-labelledby="appointment-tab">
                        <div class="p-0">
                            <div class="d-flex justify-content-between align-items-center p-4 border-bottom">
                                <span style="color: #1e293b; font-weight: 600;">Danh sách chờ khám tiếp theo</span>
                                <div class="d-flex gap-2 align-items-center">
                                    <div class="input-group input-group-sm" style="width: 250px;">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                                        <input type="text" id="waitingListSearch" class="form-control border-start-0 bg-light" placeholder="Tìm tên bệnh nhân..." onkeyup="filterWaitingList()">
                                    </div>
                                    <a href="#" class="text-decoration-none" style="color: #0ea5e9; font-size: 14px; font-weight: 500;">Xem tất cả</a>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" id="waitingListTable" style="font-size: 14px;">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 border-0">STT</th>
                                            <th class="border-0">Bệnh nhân</th>
                                            <th class="border-0">Lý do khám</th>
                                            <th class="border-0">Thời gian</th>
                                            <th class="border-0">Trạng thái</th>
                                            <th class="pe-4 border-0 text-end">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int stt = 1; }
                                        @foreach (var item in Model.UpcomingAppointments)
                                        {
                                            string nameParts = item.Patient?.FullName?.Trim() ?? "Unknown";
                                            string initials = "UK";
                                            if (!string.IsNullOrEmpty(nameParts))
                                            {
                                                var words = nameParts.Split(' ');
                                                if (words.Length > 1) {
                                                    initials = $"{words[0][0]}{words[words.Length-1][0]}".ToUpper();
                                                } else {
                                                    initials = nameParts.Substring(0, 1).ToUpper();
                                                }
                                            }

                                            string statusBadgeClass = item.Status switch
                                            {
                                                0 => "bg-secondary",
                                                1 => "bg-warning text-dark",
                                                2 => "bg-primary",
                                                3 => "bg-info text-dark",
                                                4 => "bg-success",
                                                6 => "bg-danger",
                                                8 => "bg-info",
                                                9 => "bg-success",
                                                _ => "bg-secondary"
                                            };

                                            string statusText = item.Status switch
                                            {
                                                0 => "Chưa đến",
                                                1 => "Đang chờ",
                                                2 => "Đang khám",
                                                3 => "Có KQ XN",
                                                4 => "Đã khám xong",
                                                6 => "Ưu tiên",
                                                8 => "Hẹn tái khám",
                                                9 => "Đã xác nhận",
                                                _ => "Không xác định"
                                            };

                                            <tr class="waiting-item">
                                                <td class="ps-4 font-weight-bold text-primary">@(stt.ToString("D2"))</td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px; color: #64748b; font-weight: bold;">@initials</div>
                                                        <div>
                                                            <div class="waiting-name" style="font-weight: 600; color: #334155;">@item.Patient?.FullName</div>
                                                            <div class="text-muted" style="font-size: 12px;">@item.Patient?.Gender - @item.Patient?.Age T - @item.Patient?.PatientCode</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>@item.Reason</td>
                                                <td>@item.AppointmentTime.ToString("hh:mm tt")</td>
                                                <td>
                                                    <span class="badge @statusBadgeClass rounded-pill">@statusText</span>
                                                    <a href="@Url.Action("SinhHieu", "Doctor", new { id = item.Id })" class="ms-1 text-danger" title="Theo dõi sinh hiệu">
                                                        <i class="fa-solid fa-heart-pulse"></i>
                                                    </a>
                                                </td>
                                                <td class="pe-4 text-end">
                                                    @if (item.Status == 0 || item.Status == 1 || item.Status == 2 || item.Status == 3 || item.Status == 6)
                                                    {
                                                        <a href="@Url.Action("KhamBenh", "Doctor", new { id = item.Id })" class="btn btn-sm btn-primary rounded-pill px-3">Khám ngay</a>
                                                    }
                                                    else
                                                    {
                                                        <a href="@Url.Action("ChiTietByAppointment", "Doctor", new { id = item.Id })" class="btn btn-sm btn-outline-primary rounded-pill px-3">Chi tiết</a>
                                                    }
                                                </td>
                                            </tr>
                                            stt++;
                                        }
                                        <tr id="waitingListNoResult" class="d-none">
                                            <td colspan="6" class="text-center py-4 text-muted">Không tìm thấy bệnh nhân nào.</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
                                <span class="text-muted small" id="waitingListInfo">Đang hiển thị...</span>
                                <nav>
                                    <ul class="pagination pagination-sm mb-0" id="waitingListPagination">
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>

                    <!-- Pending Online Appointment Tab -->
                    <div class="tab-pane fade" id="pending-pane" role="tabpanel" aria-labelledby="pending-tab">
                        <div class="p-0">
                            <div class="p-4 border-bottom">
                                <span style="color: #1e293b; font-weight: 600;"><i class="fa-solid fa-globe text-primary me-2"></i>Bệnh nhân đặt lịch trực tuyến (Chưa xác nhận)</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 14px;">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 border-0">Bệnh nhân</th>
                                            <th class="border-0">Lý do khám</th>
                                            <th class="border-0">Thời gian (Mong muốn)</th>
                                            <th class="pe-4 border-0 text-end">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.PendingOnlineAppointments)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <div style="font-weight: 600; color: #334155;">@item.Patient?.FullName</div>
                                                    <div class="text-muted" style="font-size: 12px;">@item.Patient?.Gender - @item.Patient?.Age T - @item.Patient?.CCCD</div>
                                                </td>
                                                <td>@item.Reason</td>
                                                <td><span class="text-primary fw-bold">@item.AppointmentTime.ToString("dd/MM/yyyy HH:mm")</span></td>
                                                <td class="pe-4 text-end">
                                                    <button type="button" class="btn btn-sm btn-success rounded-pill px-3" onclick="openConfirmModal(@item.Id, '@item.Patient?.FullName', '@item.AppointmentTime.ToString("yyyy-MM-ddTHH:mm")')">
                                                        <i class="fa-solid fa-check me-1"></i> Xác nhận & Gửi SMS
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                        @if (!Model.PendingOnlineAppointments.Any())
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-4 text-muted">Không có lịch đặt trực tuyến nào đang chờ.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Confirmed Appointment Tab -->
                    <div class="tab-pane fade" id="confirmed-pane" role="tabpanel" aria-labelledby="confirmed-tab">
                        <div class="p-0">
                            <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                                <span style="color: #1e293b; font-weight: 600;"><i class="fa-solid fa-check-double text-success me-2"></i>Lịch hẹn khám đã xác nhận</span>
                                <small class="text-muted">Sắp xếp theo thời gian đến sớm nhất</small>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 14px;">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 border-0">STT</th>
                                            <th class="border-0">Bệnh nhân</th>
                                            <th class="border-0">Lý do khám</th>
                                            <th class="border-0">Thời gian khám</th>
                                            <th class="border-0">Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int confirmedStt = 1; }
                                        @foreach (var item in Model.ConfirmedAppointments)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-bold text-success">@(confirmedStt.ToString("D2"))</td>
                                                <td>
                                                    <div style="font-weight: 600; color: #334155;">@item.Patient?.FullName</div>
                                                    <div class="text-muted" style="font-size: 12px;">@item.Patient?.Gender - @item.Patient?.Age T - @item.Patient?.PatientCode</div>
                                                </td>
                                                <td>@item.Reason</td>
                                                <td><span class="fw-bold text-primary">@item.AppointmentTime.ToString("dd/MM/yyyy HH:mm")</span></td>
                                                <td>
                                                    <span class="badge bg-success rounded-pill"><i class="fa-solid fa-calendar-check me-1"></i>Đã xác nhận hẹn</span>
                                                </td>
                                            </tr>
                                            confirmedStt++;
                                        }
                                        @if (!Model.ConfirmedAppointments.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-4 text-muted"><i class="fa-solid fa-calendar-xmark me-2 text-muted"></i>Không có lịch hẹn nào được xác nhận.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-5 mb-4">
            <div class="glass-card h-100">
                <div class="p-4 border-bottom">
                    <h6 class="m-0 font-weight-bold" style="color: #1e293b; font-weight: 600;">Hệ sinh thái Quản lý Bệnh nhân</h6>
                </div>
                <div class="p-4">
                    <div class="row g-3">
                        <div class="col-4 text-center">
                            <a href="@Url.Action("DanhSach", "Doctor")" class="d-block text-decoration-none menu-item-box p-2 rounded hover-card" style="transition: all 0.2s;">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-users"></i>
