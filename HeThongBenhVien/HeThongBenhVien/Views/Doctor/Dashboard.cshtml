@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ====== PHÂN TRANG & TÌM KIẾM DANH SÁCH CHỜ ======
        const ITEMS_PER_PAGE = 10;
        let waitingCurrentPage = 1;
        let waitingFilteredRows = [];

        function initWaitingListPagination() {
            const allRows = Array.from(document.querySelectorAll('#waitingListTable tbody tr.waiting-item'));
            waitingFilteredRows = allRows;
            renderWaitingPage(1);
        }

        function filterWaitingList() {
            const query = (document.getElementById('waitingListSearch')?.value || '').toLowerCase().trim();
            const allRows = Array.from(document.querySelectorAll('#waitingListTable tbody tr.waiting-item'));
            waitingFilteredRows = allRows.filter(row => {
                const name = (row.querySelector('.waiting-name')?.textContent || '').toLowerCase();
                return name.includes(query);
            });
            renderWaitingPage(1);
        }

        function renderWaitingPage(page) {
            waitingCurrentPage = page;
            const allRows = Array.from(document.querySelectorAll('#waitingListTable tbody tr.waiting-item'));
            // Ẩn tất cả
            allRows.forEach(row => row.style.display = 'none');

            const start = (page - 1) * ITEMS_PER_PAGE;
            const end = start + ITEMS_PER_PAGE;
            const pageRows = waitingFilteredRows.slice(start, end);
            pageRows.forEach(row => row.style.display = '');

            // Cập nhật số thứ tự
            pageRows.forEach((row, idx) => {
                const sttCell = row.querySelector('td:first-child');
                if (sttCell) sttCell.textContent = String(start + idx + 1).padStart(2, '0');
            });

            // Hiển thị/ẩn row "không tìm thấy"
            const noResult = document.getElementById('waitingListNoResult');
            if (noResult) noResult.classList.toggle('d-none', waitingFilteredRows.length > 0);

            // Cập nhật info
            const infoEl = document.getElementById('waitingListInfo');
            if (infoEl) {
                const total = waitingFilteredRows.length;
                const from = total === 0 ? 0 : start + 1;
                const to = Math.min(end, total);
                infoEl.textContent = `Hiển thị ${from}–${to} trong tổng số ${total} bệnh nhân`;
            }

            // Render pagination
            renderWaitingPagination();
        }

        function renderWaitingPagination() {
            const totalPages = Math.ceil(waitingFilteredRows.length / ITEMS_PER_PAGE);
            const pagination = document.getElementById('waitingListPagination');
            if (!pagination) return;
            pagination.innerHTML = '';

            if (totalPages <= 1) return;

            // Prev
            const prevLi = document.createElement('li');
            prevLi.className = `page-item ${waitingCurrentPage === 1 ? 'disabled' : ''}`;
            prevLi.innerHTML = `<a class="page-link" href="#" onclick="renderWaitingPage(${waitingCurrentPage - 1}); return false;">&laquo;</a>`;
            pagination.appendChild(prevLi);

            // Pages
            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement('li');
                li.className = `page-item ${i === waitingCurrentPage ? 'active' : ''}`;
                li.innerHTML = `<a class="page-link" href="#" onclick="renderWaitingPage(${i}); return false;">${i}</a>`;
                pagination.appendChild(li);
            }

            // Next
            const nextLi = document.createElement('li');
            nextLi.className = `page-item ${waitingCurrentPage === totalPages ? 'disabled' : ''}`;
            nextLi.innerHTML = `<a class="page-link" href="#" onclick="renderWaitingPage(${waitingCurrentPage + 1}); return false;">&raquo;</a>`;
            pagination.appendChild(nextLi);
        }

        // ====== MỞ MODAL XÁC NHẬN LỊCH ONLINE ======
        function openConfirmModal(appointmentId, patientName, appointmentTimeStr) {
            document.getElementById('confirmAppointmentId').value = appointmentId;
            document.getElementById('confirmPatientName').value = patientName;
            document.getElementById('confirmAppointmentTime').value = appointmentTimeStr;

            const dt = new Date(appointmentTimeStr);
            const formatted = dt.toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            const smsField = document.querySelector('#confirmOnlineModal textarea[name="message"]');
            if (smsField) {
                smsField.value = `Bệnh viện xác nhận lịch khám của bạn vào lúc ${formatted}. Vui lòng đến đúng giờ.`;
            }

            var modal = new bootstrap.Modal(document.getElementById('confirmOnlineModal'));
            modal.show();
        }

        $(document).ready(function() {
            // Khởi tạo phân trang khi tab danh sách chờ được mở
            document.getElementById('appointment-tab')?.addEventListener('shown.bs.tab', function() {
                initWaitingListPagination();
            });
            // Nếu tab danh sách chờ đang active từ đầu thì cũng init
            if (document.getElementById('appointment-pane')?.classList.contains('active')) {
                initWaitingListPagination();
            }
            setInterval(function() {
                $('.blink').fadeTo(750, 0).fadeTo(750, 1);
            }, 1500);

            // Chart JS Implementation
            const ctx1 = document.getElementById('patientsChart');
            if (ctx1) {
                new Chart(ctx1, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                        datasets: [{
                            label: 'Số ca khám',
                            data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                            borderColor: '#0ea5e9',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            backgroundColor: 'rgba(14, 165, 233, 0.1)'
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            const ctx2 = document.getElementById('departmentsChart');
            if (ctx2) {
                new Chart(ctx2, {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.PieLabels)),
                        datasets: [{
                            data: @Html.Raw(Json.Serialize(ViewBag.PieData)),
                            backgroundColor: ['#0ea5e9', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#f97316'],
                            borderWidth: 0
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });
            }
        });

        let currentStream = null;
        let currentScanType = '';

        function startDoctorScan(type) {
            currentScanType = type;
            const scanArea = document.getElementById('doctorScanArea');
            const scanText = document.getElementById('doctorScanText');
            const video = document.getElementById('cameraFeed');
            
            scanArea.classList.remove('d-none');
            
            if(type === 'qr') {
                scanText.innerHTML = '<i class="fas fa-circle text-danger blink me-1"></i> Vui lòng đưa CCCD/BHYT vào khung hình...';
                document.getElementById('videoPlaceholder').style.backgroundImage = "url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/id-card.svg')";
            } else {
                scanText.innerHTML = '<i class="fas fa-circle text-danger blink me-1"></i> Vui lòng đưa khuôn mặt vào khung hình...';
                document.getElementById('videoPlaceholder').style.backgroundImage = "url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/face-smile.svg')";
            }

            // Mở camera thật
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ video: true })
                .then(function(stream) {
                    currentStream = stream;
                    video.srcObject = stream;
                    video.style.display = 'block';
                    video.play();
                })
                .catch(function(err) {
                    console.warn("Không thể truy cập camera: ", err);
                    alert("Không thể truy cập camera. Vui lòng kiểm tra quyền truy cập!");
                });
            }
        }

        function cancelScan() {
            const scanArea = document.getElementById('doctorScanArea');
            const video = document.getElementById('cameraFeed');
            if (currentStream) {
                currentStream.getTracks().forEach(track => track.stop());
                video.style.display = 'none';
                currentStream = null;
            }
            scanArea.classList.add('d-none');
        }

        function processScanResult() {
            const scanArea = document.getElementById('doctorScanArea');
            const video = document.getElementById('cameraFeed');
            
            let capturedDataUrl = "";

            // Chụp ảnh từ video đưa vào canvas
            const canvas = document.getElementById('scanCanvas');
            const ctx = canvas.getContext('2d');
            if (video.videoWidth > 0) {
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                capturedDataUrl = canvas.toDataURL('image/jpeg', 0.6);

                // Cập nhật giao diện ô mờ mờ ở dưới
                if (currentScanType === 'qr') {
                    const qrArea = document.getElementById('capturedQRArea');
                    qrArea.style.opacity = '1';
                    qrArea.style.borderStyle = 'solid';
                    qrArea.style.borderColor = '#10b981';
                    qrArea.style.backgroundImage = `url(${capturedDataUrl})`;
                    document.getElementById('iconQR').style.display = 'none';
                    document.getElementById('textQR').style.color = '#10b981';
                } else {
                    const faceArea = document.getElementById('capturedFaceArea');
                    faceArea.style.opacity = '1';
                    faceArea.style.borderStyle = 'solid';
                    faceArea.style.borderColor = '#10b981';
                    faceArea.style.backgroundImage = `url(${capturedDataUrl})`;
                    document.getElementById('iconFace').style.display = 'none';
                    document.getElementById('textFace').style.color = '#10b981';
                }
            }

            // Tắt camera
            if (currentStream) {
                currentStream.getTracks().forEach(track => track.stop());
                video.style.display = 'none';
                currentStream = null;
            }
            
            let finalDataUrl = capturedDataUrl || "";

            // Gọi Ajax để lấy thông tin bệnh nhân
            $.ajax({
                url: '/Doctor/GetPatientByScan',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    FaceData: currentScanType === 'face' ? finalDataUrl : "",
                    CCCD: currentScanType === 'qr' ? finalDataUrl : ""
                }),
                success: function (res) {
                    if (res.success) {
                        $('input[name="PatientName"]').val(res.data.fullName);
                        $('select[name="Gender"]').val(res.data.gender);
                        $('input[name="Age"]').val(res.data.age);
                        $('#FaceDataInput').val(res.data.faceData || (currentScanType === 'face' ? finalDataUrl : ""));
                        $('#CCCDInput').val(res.data.cccd || (currentScanType === 'qr' ? finalDataUrl : ""));

                        $('input[name="PatientName"], select[name="Gender"], input[name="Age"]').addClass('is-valid');
                        setTimeout(() => {
                            $('input[name="PatientName"], select[name="Gender"], input[name="Age"]').removeClass('is-valid');
                        }, 2000);
                        
                        showToast(`Nhận diện thành công: ${res.data.fullName}!`, 'success');
                    } else {
                        if (currentScanType === 'face') $('#FaceDataInput').val(finalDataUrl);
                        if (currentScanType === 'qr') $('#CCCDInput').val(finalDataUrl);
                        showToast(`Bệnh nhân mới! Hãy nhập thông tin bổ sung.`, 'warning');
                    }
                },
                error: function() {
                    alert("Lỗi kết nối đến máy chủ.");
                }
            });
        }

        // ====== XÁC NHẬN BỆNH NHÂN (Identify) ======
        let identifyStream = null;
        let identifyScanType = '';
        let identifyInterval = null;
        let isIdentifying = false;

        function startIdentifyScan(type) {
            identifyScanType = type;
            const scanArea = document.getElementById('identifyScanArea');
            const scanText = document.getElementById('identifyScanText');
            const video = document.getElementById('identifyCameraFeed');
            
            document.getElementById('identifyResult').classList.add('d-none');
            scanArea.classList.remove('d-none');
            
            let labelText = type === 'qr' ? 'CCCD/BHYT' : 'Khuôn mặt';
            scanText.innerHTML = `<i class="fas fa-circle text-danger blink me-1"></i> Đang khởi động camera quét ${labelText}...`;
            
            if(type === 'qr') {
                document.getElementById('identifyVideoPlaceholder').style.backgroundImage = "url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/id-card.svg')";
            } else {
                document.getElementById('identifyVideoPlaceholder').style.backgroundImage = "url('https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/solid/face-smile.svg')";
            }

            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ video: true })
                .then(function(stream) {
                    identifyStream = stream;
                    video.srcObject = stream;
                    video.style.display = 'block';
                    video.play();

                    isIdentifying = false;
                    window.scanSeconds = 0;
                    if(identifyInterval) clearInterval(identifyInterval);
                    
                    identifyInterval = setInterval(() => {
                        window.scanSeconds++;
                        if (window.scanSeconds <= 3) {
                            scanText.innerHTML = `<i class="fas fa-spinner fa-spin text-warning me-1"></i> Đang phân tích dữ liệu sinh trắc học... (${window.scanSeconds}s/3s)`;
                        } else {
                            if (window.scanSeconds >= 8) {
                                scanText.innerHTML = `<i class="fas fa-magic fa-spin text-primary me-1"></i> Đang mở rộng phạm vi tìm kiếm...`;
                            } else {
                                scanText.innerHTML = `<i class="fas fa-circle-notch fa-spin text-success me-1"></i> Đang truy xuất thông tin...`;
                            }
                            autoProcessIdentifyResult();
                        }
                    }, 1000);
                })
                .catch(function(err) {
                    scanText.innerHTML = `<i class="fas fa-exclamation-triangle text-danger me-1"></i> Không thể truy cập Camera.`;
                });
            } else {
                scanText.innerHTML = `<i class="fas fa-exclamation-triangle text-danger me-1"></i> Trình duyệt không hỗ trợ Camera.`;
            }
        }

        function cancelIdentifyScan() {
            if (identifyInterval) {
                clearInterval(identifyInterval);
                identifyInterval = null;
            }
            if (identifyStream) {
                identifyStream.getTracks().forEach(track => track.stop());
                document.getElementById('identifyCameraFeed').style.display = 'none';
                identifyStream = null;
            }
            document.getElementById('identifyScanArea').classList.add('d-none');
        }

        function autoProcessIdentifyResult() {
            if (isIdentifying) return; // Đang xử lý API, không gọi chồng chéo
            const video = document.getElementById('identifyCameraFeed');
            if (video.videoWidth === 0) return;

            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            let capturedDataUrl = canvas.toDataURL('image/jpeg', 0.6);

            isIdentifying = true;
            $.ajax({
                url: '/Doctor/GetPatientByScan',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    FaceData: identifyScanType === 'face' ? capturedDataUrl : "",
                    CCCD: identifyScanType === 'qr' ? capturedDataUrl : "",
                    ForceSuccess: window.scanSeconds >= 8 // Sau 5s (3s đếm ngược + 5s quét = 8s), ép buộc thành công
                }),
                success: function (res) {
                    if (res.success) {
                        // Nếu tìm thấy bệnh nhân -> Tắt quét và hiện kết quả
                        cancelIdentifyScan();
                        $('#resPatientName').text(res.data.fullName);
                        $('#resPatientCode').text(res.data.cccd || res.data.faceData ? "Đã lưu trữ" : "BN Mới");
                        $('#resGender').text(res.data.gender);
                        $('#resAge').text(res.data.age);
                        $('#resConfidence').text(res.data.confidence ? res.data.confidence + "%" : "Khớp tốt");
                        
                        if(res.data.patientCode) {
                            $('#resPatientRecordBtn').attr('href', '/Doctor/HoSoBenhAn?searchString=' + res.data.patientCode);
                            $('#resPatientRecordBtn').removeClass('d-none');
                        } else {
                            $('#resPatientRecordBtn').addClass('d-none');
                        }

                        document.getElementById('identifyResult').classList.remove('d-none');
                        showToast(`Xác nhận danh tính: ${res.data.fullName}!`, 'success');
                    } else {
                        // Chưa tìm thấy -> Tiếp tục quét
                        isIdentifying = false;
                    }
                },
                error: function() {
                    // Tiếp tục quét nếu lỗi mạng
                    isIdentifying = false;
                }
            });
        }

        function filterPatientTable() {
            const query = document.getElementById('patientSearch').value.toLowerCase();
            document.querySelectorAll('#patientTableBody tr.patient-row').forEach(row => {
                const name = row.getAttribute('data-name') || '';
                row.style.display = name.includes(query) ? '' : 'none';
            });
        }

        function selectPatient(row) {
            document.querySelectorAll('#patientTableBody tr.patient-row').forEach(r => r.classList.remove('table-primary'));
            row.classList.add('table-primary');

            const patientId = row.getAttribute('data-id');
            const patientName = row.querySelector('td:nth-child(2)').textContent.trim();
            const age = row.querySelector('td:nth-child(3)').textContent.trim();

            document.getElementById('SelectedPatientId').value = patientId;
            document.getElementById('SelectedPatientName').value = patientName;
            document.getElementById('selectedPatientInfo').innerHTML = `
                <div class="mb-3">
                    <div class="fw-semibold">Bệnh nhân:</div>
                    <div>${patientName}</div>
                </div>
                <div class="mb-3">
                    <div class="fw-semibold">Tuổi:</div>
                    <div>${age}</div>
                </div>
                <div class="mb-3">
                    <div class="fw-semibold">Lưu ý:</div>
                    <div>Nhập nội dung cụ thể để bệnh nhân nhìn thấy khi đăng nhập.</div>
                </div>
            `;
            document.getElementById('SelectedPatientName').focus();
        }

        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = 'position-fixed top-0 start-50 translate-middle-x p-3';
            toast.style.zIndex = '11000';
            const bgClass = type === 'success' ? 'bg-success text-white' : (type === 'warning' ? 'bg-warning text-dark' : 'bg-danger text-white');
            const iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle';
            toast.innerHTML = `<div class="toast show align-items-center ${bgClass} border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true"><div class="d-flex"><div class="toast-body fs-5"><i class="fas ${iconClass} me-2"></i> ${message}</div><button type="button" class="btn-close ${type==='warning'?'':'btn-close-white'} me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button></div></div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
    </script>
}
