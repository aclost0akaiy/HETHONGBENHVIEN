@model HeThongBenhVien.Models.Patient

@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Chỉnh Sửa Bệnh Nhân";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Chỉnh Sửa Bệnh Nhân</h2>
            <p class="text-muted mb-0">Cập nhật thông tin chi tiết của bệnh nhân.</p>
        </div>
        <a href="@Url.Action("DanhSach", "Doctor")" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 10px; font-weight: 500;">
            <i class="fa-solid fa-arrow-left me-2"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9">
            <div class="glass-card p-4 border-top border-4 border-primary">
                <form asp-action="EditPatient" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PatientCode" class="form-label fw-bold text-secondary">Mã Bệnh Nhân</label>
                            <input asp-for="PatientCode" class="form-control bg-light border-0" placeholder="VD: BN001" readonly />
                            <span class="text-muted small">Không thể thay đổi mã bệnh nhân.</span>
                            <span asp-validation-for="PatientCode" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="FullName" class="form-label fw-bold text-secondary">Họ và Tên</label>
                            <input asp-for="FullName" class="form-control bg-light border-0" placeholder="Nhập họ và tên" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Gender" class="form-label fw-bold text-secondary">Giới tính</label>
                            <select asp-for="Gender" class="form-select bg-light border-0">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Age" class="form-label fw-bold text-secondary">Tuổi</label>
                            <input asp-for="Age" type="number" class="form-control bg-light border-0" placeholder="Nhập tuổi" min="0" max="150" />
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>
                        
                        @if (ViewBag.HasAppointment != null && (bool)ViewBag.HasAppointment)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Trạng thái Khám</label>
                                <select name="AppointmentStatus" class="form-select bg-light border-0">
                                    <option value="0" selected="@(ViewBag.LatestAppointmentStatus == 0 ? "selected" : null)">Chưa đến</option>
                                    <option value="1" selected="@(ViewBag.LatestAppointmentStatus == 1 ? "selected" : null)">Chờ khám</option>
                                    <option value="2" selected="@(ViewBag.LatestAppointmentStatus == 2 ? "selected" : null)">Đang khám</option>
                                    <option value="4" selected="@(ViewBag.LatestAppointmentStatus == 4 ? "selected" : null)">Chờ xác nhận (Đã khám)</option>
                                    <option value="5" selected="@(ViewBag.LatestAppointmentStatus == 5 ? "selected" : null)">Hoàn thành điều trị</option>
                                    <option value="8" selected="@(ViewBag.LatestAppointmentStatus == 8 ? "selected" : null)">Hẹn tái khám</option>
                                    <option value="11" selected="@(ViewBag.LatestAppointmentStatus == 11 ? "selected" : null)">Nhập viện</option>
                                </select>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-end border-top pt-4 mt-2">
                        <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm rounded-pill fw-bold">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Lưu Thay Đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @if (ViewBag.LabTests != null)
        {
            var labTests = ViewBag.LabTests as List<HeThongBenhVien.Models.LabTest>;
            <div class="col-xl-8 col-lg-9 mt-4">
                <div class="glass-card p-4 border-top border-4 border-info">
                    <h5 class="fw-bold text-info mb-4"><i class="fa-solid fa-microscope me-2"></i>Lịch sử Xét nghiệm</h5>
                    @if (labTests != null && labTests.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ngày tạo</th>
                                        <th>Tên Xét nghiệm</th>
                                        <th>Kết quả</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var test in labTests)
                                    {
                                        <tr>
                                            <td>@test.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold">@test.TestName</td>
                                            <td>@(string.IsNullOrEmpty(test.Result) ? "Chưa có" : test.Result)</td>
                                            <td>
                                                @if (test.Status == "Chờ xét nghiệm")
                                                {
                                                    <span class="badge bg-warning bg-opacity-25 text-warning rounded-pill px-3">Chờ XN</span>
                                                }
                                                else if (test.Status == "Đang xét nghiệm")
                                                {
                                                    <span class="badge bg-info bg-opacity-25 text-info rounded-pill px-3">Đang XN</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3">Đã có KQ</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fa-solid fa-vial-virus fs-2 mb-2 opacity-50"></i>
                            <p class="mb-0">Bệnh nhân này chưa có dữ liệu xét nghiệm.</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
