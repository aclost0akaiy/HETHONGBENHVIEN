@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Lịch Sử Khám Bệnh";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Dòng Thời Gian Y Tế</h2>
            <p class="text-muted mb-0">Theo dõi toàn bộ lịch sử thăm khám của bệnh nhân.</p>
        </div>
    </div>

    <div class="glass-card p-5">
        <div class="position-relative border-start border-2 border-primary ms-3">
            <!-- Timeline Item 1 -->
            <div class="mb-5 position-relative ms-4">
                <div class="position-absolute bg-primary rounded-circle" style="width: 15px; height: 15px; left: -32px; top: 5px;"></div>
                <div class="text-muted small fw-bold mb-1">02/05/2026 - Khoa Nội Tim Mạch</div>
                <h5 class="fw-bold text-dark">Khám Rối loạn nhịp tim</h5>
                <p class="text-muted mb-2">Chẩn đoán: Rối loạn nhịp xoang, Tăng huyết áp vô căn. Đã kê đơn thuốc 14 ngày.</p>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem bệnh án chi tiết</button>
            </div>

            <!-- Timeline Item 2 -->
            <div class="mb-5 position-relative ms-4">
                <div class="position-absolute bg-success rounded-circle" style="width: 15px; height: 15px; left: -32px; top: 5px;"></div>
                <div class="text-muted small fw-bold mb-1">15/01/2026 - Khoa Cấp Cứu</div>
                <h5 class="fw-bold text-dark">Nhập viện do cơn đau thắt ngực</h5>
                <p class="text-muted mb-2">Thực hiện cấp cứu ban đầu, đo ECG, xét nghiệm Troponin. Chuyển nội trú sau 4 tiếng.</p>
                <button class="btn btn-sm btn-outline-success rounded-pill px-3">Xem hồ sơ cấp cứu</button>
            </div>

            <!-- Timeline Item 3 -->
            <div class="position-relative ms-4">
                <div class="position-absolute bg-secondary rounded-circle" style="width: 15px; height: 15px; left: -32px; top: 5px;"></div>
                <div class="text-muted small fw-bold mb-1">10/08/2025 - Khoa Khám Bệnh</div>
                <h5 class="fw-bold text-dark">Khám sức khỏe tổng quát định kỳ</h5>
                <p class="text-muted mb-0">Các chỉ số bình thường, khuyến cáo giảm tinh bột và theo dõi huyết áp thường xuyên.</p>
            </div>
        </div>
    </div>
</div>
