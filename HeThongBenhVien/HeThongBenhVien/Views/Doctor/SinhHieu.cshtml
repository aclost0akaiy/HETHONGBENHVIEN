@model IEnumerable<HeThongBenhVien.Models.Appointment>
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Theo Dõi Sinh Hiệu";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800" style="font-weight: 700; color: #1e293b;">Theo Dõi Sinh Hiệu Bệnh Nhân</h2>
            <p class="text-muted mb-0">Danh sách các bệnh nhân đang cần theo dõi chỉ số sinh tồn.</p>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="ps-4 py-3 border-0">Bệnh Nhân</th>
                        <th class="py-3 border-0">Giới tính / Tuổi</th>
                        <th class="py-3 border-0">Lý do theo dõi</th>
                        <th class="py-3 border-0">Thời gian</th>
                        <th class="pe-4 py-3 border-0 text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Patient?.FullName</div>
                                <small class="text-muted">Mã BN: @item.Patient?.PatientCode</small>
                            </td>
                            <td>@item.Patient?.Gender / @item.Patient?.Age</td>
                            <td>@item.Reason</td>
                            <td>@item.AppointmentTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="pe-4 text-end">
                                <a href="@Url.Action("SinhHieu", "Doctor", new { id = item.Id })" class="btn btn-sm btn-primary rounded-pill px-3">
                                    <i class="fa-solid fa-file-medical me-1"></i> Nhập sinh hiệu
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Không có bệnh nhân nào cần theo dõi sinh hiệu.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
