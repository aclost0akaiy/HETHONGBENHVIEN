@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - QL Khám Chữa Bệnh</title>
    <!-- Bootstrap 4 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Vue 2 -->
    <script src="https://cdn.jsdelivr.net/npm/vue@2.7.14/dist/vue.js"></script>
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
            overflow: hidden;
        }

        /* Animated Background Shapes */
        .shape {
            position: absolute;
            filter: blur(60px);
            z-index: 0;
            animation: float 10s infinite ease-in-out alternate;
        }
        .shape-1 {
            width: 400px; height: 400px;
            background: rgba(14, 165, 233, 0.3);
            top: -10%; left: -10%;
        }
        .shape-2 {
            width: 300px; height: 300px;
            background: rgba(56, 189, 248, 0.3);
            bottom: -5%; right: -5%;
            animation-delay: -5s;
        }
        .shape-3 {
            width: 250px; height: 250px;
            background: rgba(2, 132, 199, 0.2);
            top: 40%; left: 60%;
            animation-delay: -2s;
        }

        @@keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(30px, 30px) scale(1.1); }
        }

        .login-wrapper {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 420px;
            padding: 45px 40px;
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);

        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-header {
            text-align: center;
            margin-bottom: 35px;
        }

        .login-icon {
            font-size: 3.5rem;
            color: #0ea5e9;
            margin-bottom: 15px;
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-header h2 {
            font-weight: 700;
            color: #0f172a;
            font-size: 1.75rem;
            margin-bottom: 8px;
        }

        .login-header p {
            color: #64748b;
            font-size: 0.95rem;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 25px;
        }

        .input-group-custom i {
            position: absolute;
            left: 18px;
            top: 15px;
            color: #94a3b8;
            transition: color 0.3s;
            font-size: 1.1rem;
        }

        .form-control-custom {
            width: 100%;
            padding: 14px 15px 14px 50px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.9);
            font-size: 1rem;
            color: #334155;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: #0ea5e9;
            box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        }

        .form-control-custom:focus + i,
        .input-group-custom:focus-within i {
            color: #0ea5e9;
        }

        .btn-login {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            border: none;
            color: white;
            padding: 14px;
            font-weight: 600;
            border-radius: 12px;
            width: 100%;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(14, 165, 233, 0.4);
            color: white;
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .form-check {
            display: flex;
            align-items: center;
        }

        .form-check-input {
            margin-top: 0;
            width: 18px;
            height: 18px;
            cursor: pointer;
            border-radius: 4px;
        }

        .form-check-label {
            color: #475569;
            font-size: 0.95rem;
            cursor: pointer;
            margin-left: 8px;
            margin-bottom: 0;
            padding-top: 2px;
            user-select: none;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 6px;
            padding-left: 5px;
            display: block;
            color: #ef4444 !important;
        }
        
        .alert-danger {
            border-radius: 12px;
            font-size: 0.9rem;
            background-color: #fee2e2;
            border-color: #fca5a5;
            color: #991b1b;
        }
    </style>
</head>
<body>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>

    <div id="login-app" class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <i class="fa-solid fa-hospital-user login-icon"></i>
                <h2>QL Khám Chữa Bệnh</h2>
                <p>Đăng nhập để truy cập hệ thống</p>
            </div>

            <!-- Form đăng nhập -->
            <form id="loginForm" method="post" action="/Account/Login" v-on:submit="validateForm">
                @Html.AntiForgeryToken()
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger p-3 mb-4">
                        @Html.ValidationSummary(false, "", new { @class = "mb-0 list-unstyled" })
                    </div>
                }

                <div class="input-group-custom">
                    <input type="text" id="Username" name="Username" v-model="username" class="form-control-custom" placeholder="Tên đăng nhập" required />
                    <i class="fa-solid fa-user"></i>
                    <span v-if="errors.username" class="text-danger"><i class="fa-solid fa-circle-exclamation me-1"></i>{{ errors.username }}</span>
                </div>

                <div class="input-group-custom">
                    <input type="password" id="Password" name="Password" v-model="password" class="form-control-custom" placeholder="Mật khẩu" required />
                    <i class="fa-solid fa-lock"></i>
                    <span v-if="errors.password" class="text-danger"><i class="fa-solid fa-circle-exclamation me-1"></i>{{ errors.password }}</span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="RememberMe" name="RememberMe" value="true" v-model="rememberMe">
                        <label class="form-check-label" for="RememberMe">Ghi nhớ</label>
                    </div>
                    <a href="#" class="text-decoration-none" style="color: #0ea5e9; font-size: 0.95rem; font-weight: 500;">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-login">
                    Đăng Nhập <i class="fa-solid fa-arrow-right ml-2" style="font-size: 0.9rem;"></i>
                </button>
            </form>
        </div>
    </div>

    <script>
        new Vue({
            el: '#login-app',
            data: {
                username: '',
                password: '',
                rememberMe: false,
                errors: {}
            },
            methods: {
                validateForm: function(e) {
                    this.errors = {};
                    if (!this.username) {
                        this.errors.username = 'Vui lòng nhập tên đăng nhập.';
                    }
                    if (!this.password) {
                        this.errors.password = 'Vui lòng nhập mật khẩu.';
                    }
                    
                    if (Object.keys(this.errors).length > 0) {
                        e.preventDefault(); // Dừng submit nếu có lỗi
                    }
                }
            }
        });
    </script>
</body>
</html>
