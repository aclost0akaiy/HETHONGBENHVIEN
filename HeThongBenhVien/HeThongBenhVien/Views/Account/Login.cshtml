@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Bệnh Viện Hoàn Mỹ Đồng Nai</title>
    <!-- Bootstrap 4 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <!-- Vue 2 -->
    <script src="https://cdn.jsdelivr.net/npm/vue@2.7.14/dist/vue.js"></script>
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .login-background {
            /* Thay đổi URL này thành đường dẫn ảnh nền thực tế của bạn */
            background-image: url('/images/hospital-bg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* Overlay trắng mờ phía trên ảnh nền (tùy chọn) */
        .login-background::before {
            content: "";
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(255, 255, 255, 0.4); /* Điều chỉnh độ mờ nền */
        }

        .login-card {
            background-color: rgba(255, 255, 255, 0.95);
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 500px;
            padding: 40px;
            position: relative;
            z-index: 1;
        }

        .login-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-logo img {
            /* Đường dẫn tới logo Bệnh viện Hoàn Mỹ của bạn */
            max-height: 80px;
            width: auto;
        }

        .form-group label {
            color: #008a99; /* Màu xanh ngọc của chữ */
            font-weight: normal;
            margin-bottom: 5px;
        }

        .form-control {
            border: 1px solid #ced4da;
            border-radius: 4px;
            padding: 10px 15px;
        }
        
        .form-control:focus {
            border-color: #008a99;
            box-shadow: 0 0 0 0.2rem rgba(0, 138, 153, 0.25);
        }

        .btn-login {
            background-color: #009eb3; /* Màu nút đăng nhập */
            border-color: #009eb3;
            color: white;
            padding: 8px 30px;
            font-weight: 500;
            border-radius: 4px;
        }

        .btn-login:hover {
            background-color: #008a99;
            border-color: #008a99;
            color: white;
        }
        
        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }
        
        .form-check-label {
            color: #008a99;
        }
    </style>
</head>
<body>
    <div id="login-app" class="login-background">
        <div class="login-card">
            <div class="login-logo">
                <!-- Chèn logo bệnh viện từ máy của bạn vào đây (vd: src="/images/logo.png") -->
                <img src="/images/logo-hoan-my.png" alt="Bệnh Viện Hoàn Mỹ Đồng Nai" />
            </div>

            <!-- Form đăng nhập mặc định của ASP.NET Core -->
            <form id="loginForm" method="post" action="/Account/Login" v-on:submit="validateForm">
                @Html.AntiForgeryToken()
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger p-2 small">
                        @Html.ValidationSummary(false, "", new { @class = "mb-0 list-unstyled" })
                    </div>
                }

                <div class="form-group">
                    <label for="Username">Tên đăng nhập</label>
                    <input type="text" id="Username" name="Username" v-model="username" class="form-control" placeholder="" required />
                    <span v-if="errors.username" class="text-danger">{{ errors.username }}</span>
                </div>

                <div class="form-group">
                    <label for="Password">Mật khẩu</label>
                    <input type="password" id="Password" name="Password" v-model="password" class="form-control" placeholder="" required />
                    <span v-if="errors.password" class="text-danger">{{ errors.password }}</span>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="RememberMe" name="RememberMe" value="true" v-model="rememberMe">
                        <label class="form-check-label" for="RememberMe">Ghi nhớ</label>
                    </div>
                    <button type="submit" class="btn btn-login">Đăng nhập</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        new Vue({
            el: '#login-app',
            data: {
                username: '',
                password: '',
                rememberMe: false,
                errors: {}
            },
            methods: {
                validateForm: function(e) {
                    this.errors = {};
                    if (!this.username) {
                        this.errors.username = 'Vui lòng nhập tên đăng nhập.';
                    }
                    if (!this.password) {
                        this.errors.password = 'Vui lòng nhập mật khẩu.';
                    }
                    
                    if (Object.keys(this.errors).length > 0) {
                        e.preventDefault(); // Dừng submit nếu có lỗi
                    }
                }
            }
        });
    </script>
</body>
</html>
