@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cổng Bệnh Nhân - Đăng Nhập</title>
    <!-- Bootstrap 4 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Vue 2 -->
    <script src="https://cdn.jsdelivr.net/npm/vue@2.7.14/dist/vue.js"></script>
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #ffffff 100%);
            overflow-x: hidden;
        }
        
        .navbar-custom {
            background-color: transparent;
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            position: relative;
            z-index: 10;
        }

        .navbar-brand-custom {
            color: #0b56b9;
            font-weight: 700;
            font-size: 1.35rem;
            text-decoration: none;
        }

        .navbar-brand-custom:hover {
            color: #0b56b9;
            text-decoration: none;
        }

        .nav-tabs-custom {
            display: flex;
            gap: 20px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .nav-tab-item {
            font-weight: 600;
            font-size: 0.95rem;
            color: #0b56b9;
            padding: 8px 0;
            border-bottom: 3px solid #0b56b9;
            cursor: pointer;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .lang-selector {
            color: #475569;
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
        }

        .theme-toggle {
            color: #475569;
            font-size: 1.1rem;
            cursor: pointer;
        }

        .divider-vertical {
            width: 1px;
            height: 20px;
            background-color: #cbd5e1;
        }

        .main-container {
            min-height: calc(100vh - 70px);
            display: flex;
            align-items: center;
            padding: 40px;
            position: relative;
            z-index: 5;
        }

        .left-content {
            padding-right: 40px;
        }

        .security-badge {
            background-color: #dbeafe;
            color: #1d4ed8;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            padding: 6px 14px;
            border-radius: 50px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 25px;
        }

        .left-content h1 {
            font-size: 2.6rem;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.3;
            margin-bottom: 20px;
        }

        .left-content p.subtitle {
            color: #475569;
            font-size: 1.05rem;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .features-grid {
            display: flex;
            gap: 30px;
        }

        .feature-box {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            flex: 1;
        }

        .feature-icon-container {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background-color: #dbeafe;
            color: #1d4ed8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .feature-text h5 {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .feature-text p {
            font-size: 0.88rem;
            color: #64748b;
            margin: 0;
            line-height: 1.4;
        }

        .right-content {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            background: #ffffff;
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.04);
            width: 100%;
            max-width: 460px;
            padding: 40px;
            text-align: center;
        }

        .avatar-circle {
            width: 70px;
            height: 70px;
            border-radius: 20px;
            background-color: #dbeafe;
            color: #1d4ed8;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 20px;
        }

        .login-card h2 {
            font-weight: 700;
            color: #0f172a;
            font-size: 1.6rem;
            margin-bottom: 6px;
        }

        .login-card p.card-subtext {
            color: #64748b;
            font-size: 0.92rem;
            margin-bottom: 30px;
        }

        .form-label-custom {
            text-align: left;
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 8px;
            display: block;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 20px;
        }

        .input-group-custom i {
            position: absolute;
            left: 18px;
            top: 15px;
            color: #94a3b8;
            transition: color 0.3s;
            font-size: 1.1rem;
        }

        .form-control-custom {
            width: 100%;
            padding: 14px 15px 14px 50px;
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            background: #f8fafc;
            font-size: 0.95rem;
            color: #1e293b;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: #0b56b9;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(13, 86, 185, 0.1);
        }

        .form-control-custom:focus + i,
        .input-group-custom:focus-within i {
            color: #0b56b9;
        }

        .btn-login {
            background-color: #0b56b9;
            border: none;
            color: white;
            padding: 14px;
            font-weight: 600;
            border-radius: 12px;
            width: 100%;
            font-size: 1rem;
            letter-spacing: 0.3px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 10px;
        }

        .btn-login:hover {
            background-color: #084393;
            color: white;
        }

        .btn-login:active {
            transform: scale(0.98);
        }

        .form-check {
            display: flex;
            align-items: center;
        }

        .form-check-input {
            margin-top: 0;
            width: 18px;
            height: 18px;
            cursor: pointer;
            border-radius: 4px;
            accent-color: #0b56b9;
        }

        .form-check-label {
            color: #64748b;
            font-size: 0.9rem;
            cursor: pointer;
            margin-left: 8px;
            margin-bottom: 0;
            user-select: none;
        }

        .forgot-link {
            color: #0b56b9;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
        }

        .forgot-link:hover {
            color: #084393;
            text-decoration: none;
        }

        .card-divider {
            border-top: 1px solid #f1f5f9;
            margin: 25px 0 20px 0;
        }

        .register-text {
            font-size: 0.92rem;
            color: #64748b;
        }

        .register-link {
            color: #0b56b9;
            font-weight: 700;
            text-decoration: none;
        }

        .register-link:hover {
            color: #084393;
            text-decoration: none;
        }

        /* Responsive Layout */
        @@media (max-width: 991px) {
            .navbar-custom {
                padding: 15px 20px;
            }
            .main-container {
                flex-direction: column;
                padding: 20px;
                align-items: stretch;
            }
            .left-content {
                padding-right: 0;
                margin-bottom: 40px;
                text-align: center;
            }
            .security-badge {
                justify-content: center;
            }
            .features-grid {
                flex-direction: column;
                align-items: center;
                gap: 20px;
            }
            .feature-box {
                text-align: left;
                width: 100%;
                max-width: 380px;
            }
            .right-content {
                width: 100%;
            }
            .login-card {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Header Navbar -->
    <div class="navbar-custom">
        <a href="/" class="navbar-brand-custom">Cổng Bệnh Nhân</a>
        <ul class="nav-tabs-custom">
            <li class="nav-tab-item">Đăng nhập</li>
        </ul>
        <div class="navbar-right">
            <span class="theme-toggle">
                <i class="fa-regular fa-moon"></i>
            </span>
            <div class="divider-vertical"></div>
        </div>
    </div>

    <!-- Main Container -->
    <div id="login-app" class="container-fluid main-container">
        <div class="row w-100 m-0">
            <!-- Left Column: Marketing Info -->
            <div class="col-lg-6 left-content d-flex flex-column justify-content-center">
                <div>
                    <div class="security-badge">
                        <i class="fa-solid fa-shield-halved"></i> HỆ THỐNG BẢO MẬT 256-BIT
                    </div>
                    <h1>Chăm sóc sức khỏe toàn diện ngay tại nhà.</h1>
                    <p class="subtitle">Truy cập hồ sơ bệnh án, lịch hẹn tái khám và kết quả xét nghiệm một cách nhanh chóng và bảo mật nhất.</p>
                    
                    <div class="features-grid">
                        <div class="feature-box">
                            <div class="feature-icon-container">
                                <i class="fa-regular fa-calendar-check"></i>
                            </div>
                            <div class="feature-text">
                                <h5>Đặt lịch khám</h5>
                                <p>Chọn bác sĩ và giờ khám dễ dàng.</p>
                            </div>
                        </div>
                        <div class="feature-box">
                            <div class="feature-icon-container">
                                <i class="fa-regular fa-file-lines"></i>
                            </div>
                            <div class="feature-text">
                                <h5>Xem hồ sơ</h5>
                                <p>Tra cứu lịch sử khám bệnh mọi lúc.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Login Card -->
            <div class="col-lg-6 right-content">
                <div class="login-card">
                    <div class="avatar-circle">
                        <i class="fa-regular fa-circle-user"></i>
                    </div>
                    <h2>Cổng Bệnh Nhân</h2>
                    <p class="card-subtext">Đăng nhập để xem hồ sơ và lịch hẹn</p>

                    <!-- Login Form -->
                    <form id="loginForm" method="post" action="/Account/PatientLogin" v-on:submit="validateForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger p-3 mb-4 text-left">
                                @Html.ValidationSummary(false, "", new { @class = "mb-0 list-unstyled" })
                            </div>
                        }

                        <div class="text-left">
                            <label class="form-label-custom" for="Username">Tên đăng nhập</label>
                        </div>
                        <div class="input-group-custom">
                            <input type="text" id="Username" name="Username" v-model="username" class="form-control-custom" placeholder="admin_hethong" required />
                            <i class="fa-regular fa-user"></i>
                            <span v-if="errors.username" class="text-danger text-left"><i class="fa-solid fa-circle-exclamation me-1"></i>{{ errors.username }}</span>
                        </div>

                        <div class="text-left">
                            <label class="form-label-custom" for="Password">Mật khẩu</label>
                        </div>
                        <div class="input-group-custom">
                            <input :type="showPassword ? 'text' : 'password'" id="Password" name="Password" v-model="password" class="form-control-custom" placeholder="......" required />
                            <i class="fa-solid fa-lock"></i>
                            <span v-on:click="showPassword = !showPassword" style="position: absolute; right: 18px; top: 15px; color: #94a3b8; cursor: pointer; z-index: 10;">
                                <i :class="showPassword ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye'"></i>
                            </span>
                            <span v-if="errors.password" class="text-danger text-left"><i class="fa-solid fa-circle-exclamation me-1"></i>{{ errors.password }}</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="RememberMe" name="RememberMe" value="true" v-model="rememberMe">
                                <label class="form-check-label" for="RememberMe">Ghi nhớ</label>
                            </div>
                            <a href="#" class="forgot-link">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-login">
                            Đăng Nhập <i class="fa-solid fa-arrow-right-long ml-2" style="font-size: 0.95rem;"></i>
                        </button>

                        <div class="card-divider"></div>

                        <div class="register-text">
                            Chưa có tài khoản? 
                            <a href="/Account/RegisterPatient" class="register-link">Đăng ký ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        new Vue({
            el: '#login-app',
            data: {
                username: '',
                password: '',
                rememberMe: false,
                showPassword: false,
                errors: {}
            },
            methods: {
                validateForm: function(e) {
                    this.errors = {};
                    if (!this.username) {
                        this.errors.username = 'Vui lòng nhập tên đăng nhập.';
                    }
                    if (!this.password) {
                        this.errors.password = 'Vui lòng nhập mật khẩu.';
                    }
                    
                    if (Object.keys(this.errors).length > 0) {
                        e.preventDefault();
                    }
                }
            }
        });
    </script>
</body>
</html>
